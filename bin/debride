#!/usr/bin/env ruby
require "rubygems"
require "bundler/setup"

default_targets = %w[app/models app/services app/jobs app/policies].freeze
default_excludes = %w[
  app/models/application_record.rb
  app/jobs/application_job.rb
  app/policies/application_policy.rb
].freeze

args = ["--rails", "--minimum", ENV.fetch("DEBRIDE_MINIMUM", "3")]
whitelist = File.expand_path("../config/debride.whitelist", __dir__)

args.push("--exclude", default_excludes.join(","))
args.push("--whitelist", whitelist) if File.exist?(whitelist)
args << "--verbose" if ENV["DEBRIDE_VERBOSE"] == "1"

ARGV.replace(args + (ARGV.empty? ? default_targets : ARGV))

load Gem.bin_path("debride", "debride")
