<% content_for :page_title, t('acme.org.preference.resets.title') %>

<section>
  <h1>
    <%= t("acme.org.preference.resets.title") %>
  </h1>

  <p>
    <%= t("acme.org.preference.resets.description") %>
  </p>

  <%= form_with url: zenith.acme_org_preference_reset_path, method: :delete do |f| %>
    <% if @preference&.errors&.any? %>
      <div>
        <ul>
          <% @preference.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= check_box_tag :confirm_reset, "1", @preference&.confirm_reset == "1", required: true %>
      <%= label_tag :confirm_reset, t("acme.org.preference.resets.confirm") %>
    </div>

    <div>
      <%= f.submit t("acme.org.preference.resets.button"),
                   data: { turbo_submits_with: t("acme.org.preferences.submitting") } %>
      <%= link_to t("acme.org.preference.resets.back"),
                  zenith.acme_org_preference_url %>
    </div>
  <% end %>
</section>
