<% content_for :page_title, t("acme.app.preferences.language_settings") %>

<section>
  <h1>
      <%= t("acme.app.preference.language.edit.heading") %>
  </h1>
  <p>
      <%= t("acme.app.preference.language.edit.description") %>
  </p>

  <% selected_language = nil
     language_options = AppPreferenceLanguageOption.order(:id).map do |option|
       label = case option.name
               when "ja" then t("languages.japanese")
               when "en" then t("languages.english")
               else option.name
               end
       value = option.name.to_s.upcase
       selected_language = value if option.id == @preference_language.option_id
       [label, value]
     end %>

  <%= form_with model: @preference_language, scope: :preference_language, url: zenith.acme_app_preference_region_language_path, method: :patch do |f| %>
    <div>
      <%= f.label :option_id,
                  t("acme.app.preference.language.edit.language_label") %>
      <div>
        <%= f.select :option_id,
                     options_for_select(language_options, selected_language),
                     { include_blank: false },
                     {} %>
      </div>
    </div>

    <div>
      <%= f.submit t("acme.app.preferences.update_settings"),
                   data: { turbo_submits_with: t("acme.app.preferences.submitting") } %>
      <%= link_to t("acme.app.preferences.region_settings"), zenith.edit_acme_app_preference_region_path %>
      <%= link_to t("acme.app.preferences.back_to_settings"), zenith.acme_app_preference_url %>
    </div>
  <% end %>
</section>
