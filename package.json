{
  "name": "umaxica-app-jit",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "check": "pnpm run format:check && pnpm run lint",
    "format": "pnpm exec oxfmt --write .",
    "format:check": "pnpm exec oxfmt --check .",
    "lint": "pnpm exec oxlint app/javascript",
    "lint:fix": "pnpm exec oxlint --fix app/javascript",
    "prepare": "vp config"
  },
  "devDependencies": {
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.27.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
