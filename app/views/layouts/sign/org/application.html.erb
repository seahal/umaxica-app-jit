<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (org)", title: (content_for(:page_title) if content_for?(:page_title)) %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "sign/main" %>
  <%= stylesheet_link_tag "sign/org/main" %>
  <%= javascript_importmap_tags %>
  <link rel="icon" href="https://perm.umaxica.org/favicon.ico" sizes="32x32">
</head>
<body>
<div>
  <div>
    <%= render "shared/flash_messages" %>

    <header>
      <div>
        <span>Sign</span>
        <h1>
          <span>(org)</span>
        </h1>
      </div>
      <nav>
        <% unless logged_in? %>
          <%= link_to t("sign.org.layout.nav.sign_up"), new_sign_org_up_url(host: ENV["SIGN_STAFF_URL"]) %>
          <%= link_to t("sign.org.layout.nav.log_in"), new_sign_org_in_url(host: ENV["SIGN_STAFF_URL"]) %>
        <% else %>
          <%= link_to t("sign.org.layout.nav.configuration"), sign_org_configuration_url(host: ENV["SIGN_STAFF_URL"]) %>
          <%= link_to t("sign.org.layout.nav.logout"), edit_sign_org_configuration_out_url(host: ENV["SIGN_STAFF_URL"]) %>
        <% end %>
      </nav>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer>
      <nav>

        <%= link_to t("sign.org.preferences.footer.home"), sign_org_root_path %>

        <%= link_to t("sign.org.preferences.footer.preference"), apex_org_preference_url %>
        <%= link_to t("sign.org.preferences.footer.configuration"), sign_org_configuration_path %>
      </nav>
      <div>
        <%= render "shared/copyright" %>
      </div>
    </footer>
  </div>
</div>
</body>
</html>

<%= link_to t("sign.org.layout.nav.sign_up"), new_sign_org_up_url(host: ENV["SIGN_STAFF_URL"]) %>
<%= link_to t("sign.org.layout.nav.log_in"), new_sign_org_in_url(host: ENV["SIGN_STAFF_URL"]) %>
