<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (org)", title: page_title %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "sign/main" %>
  <%= stylesheet_link_tag "sign/org/main" %>
  <%= javascript_importmap_tags %>
  <%= yield :head %>
</head>
<body>

<header>
  <h1>
    <%= link_to ENV['BRAND_NAME'], sign_org_root_path %> (Org)
  </h1>
  <nav>
    <% if logged_in? %>
      <%= link_to t("sign.org.layout.nav.logout"), edit_sign_org_configuration_out_url(host: ENV["SIGN_STAFF_URL"]) %>
    <% else %>
      <%= link_to t("sign.org.layout.nav.sign_up"), new_sign_org_up_url(host: ENV["SIGN_STAFF_URL"]) %>
      <%= link_to t("sign.org.layout.nav.log_in"), new_sign_org_in_url(host: ENV["SIGN_STAFF_URL"]) %>
    <% end %>
  </nav>
</header>

<hr />

<%= render "shared/flash_messages" %>
<% if show_cookie_banner? %>
  <%= render "shared/cookie_banner" %>
<% end %>

    <main>
  <%= yield %>
</main>

<hr />

<footer>
  <nav>
    <ul>
      <li><%= link_to t("sign.org.preferences.footer.home"), sign_org_root_url %></li>
      <li><%= link_to t("sign.org.preferences.footer.preference"), apex_org_preference_url %></li>
      <li><%= link_to t("sign.org.preferences.footer.configuration"), sign_org_configuration_url %></li>
    </ul>
  </nav>
  <%= render "layouts/shared/footer_theme_controls", scope: :org %>
  <%= render "shared/copyright" %>
</footer>
</body>
</html>
