<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<%= render "layouts/shared/head",
      namespace: "app",
      stylesheets: ["sign/main", "sign/app/main"],
      title: "#{ENV['BRAND_NAME']} (app)" %>

<body class="bg-[hsl(var(--background))] text-[hsl(var(--foreground))]">
<div class="min-h-screen">
  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6">
    <%= render "concern/flash_messages" %>

    <%= render "layouts/shared/header",
          service_name: "Sign",
          namespace: "app",
          home_path: (ENV["EDGE_SERVICE_URL"].present? ? "http://#{ENV["EDGE_SERVICE_URL"]}/" : nil) do %>
      <% unless logged_in? %>
        <%= link_to t("sign.app.layout.nav.sign_up"), new_sign_app_up_url,
                    class: "rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
        <%= link_to t("sign.app.layout.nav.log_in"), new_sign_app_in_url,
                    class: "rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
      <% else %>
        <%= link_to t("sign.app.layout.nav.configuration"), sign_app_configuration_url,
                    class: "rounded-full border border-[hsl(var(--border))] bg-[hsl(var(--card))] px-4 py-2 text-sm font-semibold" %>
        <%= link_to t("sign.app.layout.nav.logout"), edit_sign_app_out_url,
                    class: "rounded-full bg-[hsl(var(--primary))] px-4 py-2 text-sm font-semibold text-[hsl(var(--primary-foreground))]" %>
      <% end %>
    <% end %>

    <main class="flex-1 py-10">
      <%= yield %>
    </main>

    <%= render "layouts/shared/footer" do %>
        <% if ENV["EDGE_SERVICE_URL"].present? %>
          <%= link_to t("sign.app.preferences.footer.home"), sign_app_root_path, class: "transition hover:text-[hsl(var(--primary))]" %>
        <% end %>
        <%= link_to t("sign.app.preferences.footer.preference"), apex_app_preference_url, class: "transition hover:text-[hsl(var(--primary))]" %>
        <%= link_to t("sign.app.preferences.footer.configuration"), sign_app_configuration_path, class: "transition hover:text-[hsl(var(--primary))]" %>
    <% end %>
  </div>
</div>
</body>
</html>
