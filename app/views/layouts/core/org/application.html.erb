<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (org) JP", title: (content_for(:page_title) if content_for?(:page_title)) %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "core/main" %>
  <%= stylesheet_link_tag "core/org/main" %>
  <%= javascript_importmap_tags %>
</head>
<body>
<div>
  <%= render "shared/flash_messages" %>
  <div>
    <header>
      <div>
        <span>Core</span>
        <h1>
          <a href="<%= "#{request.protocol}#{ENV.fetch('CORE_STAFF_URL', 'www.org.localhost')}#{request.port_string}/" %>">Umaxica</a>
          <span>(org)</span>
        </h1>
      </div>
      <nav>
        <% unless logged_in? %>
          <%= link_to t("sign.app.layout.nav.sign_up"), new_sign_org_up_url(host: ENV["SIGN_STAFF_URL"]) %>
          <%= link_to t("sign.app.layout.nav.log_in"), new_sign_org_in_url(host: ENV["SIGN_STAFF_URL"]) %>
        <% else %>
          <%= link_to t("sign.app.layout.nav.configuration"), sign_org_configuration_url(host: ENV["SIGN_STAFF_URL"]) %>
          <%= link_to t("sign.app.layout.nav.logout"), sign_org_configuration_out_url(host: ENV["SIGN_STAFF_URL"]), data: { turbo_method: :delete } %>
        <% end %>
      </nav>
    </header>
<%= render_current_banner(:org) %>
<% if show_cookie_banner? %>
  <%= render "shared/cookie_banner" %>
<% end %>

    <main>
      <%= yield %>
    </main>

    <footer>
      <nav>

        <%= link_to t("core.org.preferences.footer.preference"), apex_org_preference_url %>
        <% if defined?(edit_www_org_preference_cookie_path) %>
          <%= link_to "Cookie", edit_www_org_preference_cookie_path %>
        <% end %>
      </nav>
      <%= render "layouts/shared/footer_theme_controls", scope: :org %>
      <div>
        <%= render "shared/copyright" %>
      </div>
    </footer>
  </div>
</div>
</body>
</html>
