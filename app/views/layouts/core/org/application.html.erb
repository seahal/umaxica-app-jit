<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (org) JP" %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "core/main" %>
  <%= stylesheet_link_tag "core/org/main" %>
  <%= javascript_importmap_tags %>
  <link rel="icon" href="https://perm.umaxica.org/favicon.ico" sizes="32x32">
</head>
<body class="bg-[hsl(var(--background))] text-[hsl(var(--foreground))]">
<div class="min-h-screen">
  <%= render "concern/flash_messages" %>
  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6">
    <%= render "layouts/shared/header",
               service_name: "Core",
               namespace: "org",
               home_path: "http://localhost:4444/" do %>
      <% unless logged_in? %>
        <%= link_to t("sign.app.layout.nav.sign_up"), new_sign_org_up_url(host: ENV["SIGN_STAFF_URL"]),
                    class: "inline-flex h-9 items-center justify-center rounded-md border border-[hsl(var(--input))] bg-[hsl(var(--background))] px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-[hsl(var(--accent))] hover:text-[hsl(var(--accent-foreground))] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
        <%= link_to t("sign.app.layout.nav.log_in"), new_sign_org_in_url(host: ENV["SIGN_STAFF_URL"]),
                    class: "inline-flex h-9 items-center justify-center rounded-md bg-[hsl(var(--primary))] px-4 py-2 text-sm font-medium text-[hsl(var(--primary-foreground))] shadow transition-colors hover:bg-[hsl(var(--primary))]/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
      <% else %>
        <%= link_to t("sign.app.layout.nav.configuration"), sign_org_configuration_url(host: ENV["SIGN_STAFF_URL"]),
                    class: "inline-flex h-9 items-center justify-center rounded-md border border-[hsl(var(--input))] bg-[hsl(var(--background))] px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-[hsl(var(--accent))] hover:text-[hsl(var(--accent-foreground))] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
        <%= link_to t("sign.app.layout.nav.logout"), sign_org_out_url(host: ENV["SIGN_STAFF_URL"]), data: { turbo_method: :delete },
                    class: "inline-flex h-9 items-center justify-center rounded-md border border-[hsl(var(--input))] bg-[hsl(var(--background))] px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-[hsl(var(--accent))] hover:text-[hsl(var(--accent-foreground))] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
      <% end %>
    <% end %>

    <main class="flex-1 py-10">
      <%= yield %>
    </main>

    <%= render "layouts/shared/footer" do %>
      <%= link_to t("core.org.preferences.footer.preference"), apex_org_preference_url, class: "transition hover:text-[hsl(var(--primary))]" %>
      <% if defined?(edit_www_org_preference_cookie_path) %>
        <%= link_to "Cookie", edit_www_org_preference_cookie_path, class: "font-semibold text-[hsl(var(--foreground))]" %>
      <% end %>
    <% end %>
  </div>
</div>
</body>
</html>
