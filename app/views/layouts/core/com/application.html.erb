<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (com) JP", title: (content_for(:page_title) if content_for?(:page_title)) %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "core/main" %>
  <%= stylesheet_link_tag "core/com/main" %>
  <%= javascript_importmap_tags %>
</head>

<body>

<div>    <%= render "shared/flash_messages" %>
  <div>

    <header>
      <div>
        <span>Core</span>
        <h1>

          <a href="<%= "#{request.protocol}#{ENV.fetch('CORE_CORPORATE_URL', 'www.com.localhost')}#{request.port_string}/" %>">Umaxica</a>

          <span>(com)</span>
        </h1>
      </div>
    </header>
<% if show_cookie_banner? %>
  <%= render "shared/cookie_banner" %>
<% end %>

    <main>
      <%= yield %>
    </main>

    <footer>
      <nav>

        <%= link_to t("core.com.preferences.footer.preference"), apex_com_preference_url %>
        <%= link_to t("core.com.layout.nav.contact"), new_core_com_contact_path %>
      </nav>
      <%= render "layouts/shared/footer_theme_controls", scope: :com %>
      <div>
        <%= render "shared/copyright" %>
      </div>
    </footer>
  </div>
</div>
</body>
</html>
