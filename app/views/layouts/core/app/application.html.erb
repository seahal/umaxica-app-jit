<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (app) JP", title: page_title %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "core/main" %>
  <%= stylesheet_link_tag "core/app/main" %>

  <%= javascript_importmap_tags %>

  <link rel="icon" href="https://perm.umaxica.app/favicon.ico" sizes="32x32">

  <%= yield :head %>
</head>

<body>
<div>
  <div>
    <%= render "shared/flash_messages" %>

    <%= render "layouts/shared/header",
               service_name: "Core",
               namespace: "app",
               home_path: "http://localhost:4444/" do %>
      <% unless logged_in? %>
        <%= link_to t("core.app.layout.nav.sign_up"), new_sign_app_up_url %>
        <%= link_to t("core.app.layout.nav.log_in"), new_sign_app_in_url %>
      <% else %>
        <%= link_to t("core.app.layout.nav.configuration"), sign_app_configuration_url %>
        <%= link_to t("core.app.layout.nav.logout"), edit_sign_app_configuration_out_url %>
      <% end %>
    <% end %>
<% if show_cookie_banner? %>
  <%= render "shared/cookie_banner" %>
<% end %>

    <main>
      <%= yield %>
    </main>

    <%= render "layouts/shared/footer" do %>
      <a href="http://localhost:4444/">Home</a>
      <%= link_to t("core.app.preferences.footer.preference"), apex_app_preference_url %>
      <%= link_to t("core.app.layout.nav.contact"), new_core_app_contact_path %>
    <% end %>
  </div>
</div>
</body>
</html>
