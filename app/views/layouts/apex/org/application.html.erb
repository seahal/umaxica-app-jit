<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<%= render "layouts/shared/head",
           namespace: "org",
           stylesheets: ["apex/main", "apex/org/main"],
           title: "#{ENV['BRAND_NAME']} (org) Apex" %>

<body class="bg-[hsl(var(--background))] text-[hsl(var(--foreground))]">
<div class="min-h-screen">
  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6">
    <%= render "concern/flash_messages" %>

    <%= render "layouts/shared/header",
               service_name: "APEX",
               namespace: "org",
               home_path: "http://org.localhost:3000/" do %>
      <% unless logged_in? %>
        <%= link_to t("sign.org.layout.nav.sign_up"), new_sign_org_up_url(host: ENV['SIGN_STAFF_URL']),
                    class: "inline-flex h-9 items-center justify-center rounded-md border border-[hsl(var(--input))] bg-[hsl(var(--background))] px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-[hsl(var(--accent))] hover:text-[hsl(var(--accent-foreground))] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
        <%= link_to t("sign.org.layout.nav.log_in"), new_sign_org_in_url(host: ENV['SIGN_STAFF_URL']),
                    class: "inline-flex h-9 items-center justify-center rounded-md bg-[hsl(var(--primary))] px-4 py-2 text-sm font-medium text-[hsl(var(--primary-foreground))] shadow transition-colors hover:bg-[hsl(var(--primary))]/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
      <% else %>
        <%= link_to t("sign.org.layout.nav.configuration"), sign_org_configuration_url(host: ENV['SIGN_STAFF_URL']),
                    class: "inline-flex h-9 items-center justify-center rounded-md border border-[hsl(var(--input))] bg-[hsl(var(--background))] px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-[hsl(var(--accent))] hover:text-[hsl(var(--accent-foreground))] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
        <%= link_to t("sign.org.layout.nav.logout"), edit_sign_org_out_url(host: ENV['SIGN_STAFF_URL']),
                    class: "inline-flex h-9 items-center justify-center rounded-md border border-[hsl(var(--input))] bg-[hsl(var(--background))] px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-[hsl(var(--accent))] hover:text-[hsl(var(--accent-foreground))] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
      <% end %>
    <% end %>

    <main class="flex-1 py-10">
      <%= yield %>
    </main>

    <nav id="app" class="mt-4 bg-white bg-opacity-50 hover:font-black hover:text-blue-500">
    </nav>

    <%= render "layouts/shared/footer" do %>
      <a class="font-semibold text-[hsl(var(--foreground))]" href="http://org.localhost:3000/"><%= t('apex.org.preferences.footer.home') %></a>
      <%= link_to t('apex.org.preferences.footer.preference'), apex_org_preference_url, class: "font-semibold text-[hsl(var(--foreground))]" %>
      <%= link_to t("apex.org.configurations.title"), apex_org_configuration_path, class: "font-semibold text-[hsl(var(--foreground))]" %>
    <% end %>
  </div>
</div>
</body>
</html>
