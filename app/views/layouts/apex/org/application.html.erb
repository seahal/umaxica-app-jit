<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (org) Apex", title: (content_for(:page_title) if content_for?(:page_title)) %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "apex/main" %>
  <%= stylesheet_link_tag "apex/org/main" %>
  <%= javascript_importmap_tags %>
</head>
<body>
<div>
  <div></div>
  <div></div>
</div>

<div>
  <%= render "shared/flash_messages" %>

  <header>
    <div>
      <div>
        <span>APEX</span>
        <h1>

          <a href="<%= "#{request.protocol}#{ENV.fetch('APEX_STAFF_URL', 'org.localhost')}#{request.port_string}/" %>">Umaxica (org)</a>
        </h1>
      </div>
      <nav>
        <% unless logged_in? %>
          <%= link_to t("sign.org.layout.nav.sign_up"), new_sign_org_up_url(host: ENV['SIGN_STAFF_URL']) %>
          <%= link_to t("sign.org.layout.nav.log_in"), new_sign_org_in_url(host: ENV['SIGN_STAFF_URL']) %>
        <% else %>
          <%= link_to t("sign.org.layout.nav.configuration"), sign_org_configuration_url(host: ENV['SIGN_STAFF_URL']) %>
          <%= link_to t("sign.org.layout.nav.logout"), edit_sign_org_configuration_out_url(host: ENV['SIGN_STAFF_URL']) %>
        <% end %>
      </nav>
    </div>
  </header>
<%= render_current_banner(:org) %>

  <hr>
<% if show_cookie_banner? %>
  <%= render "shared/cookie_banner" %>
<% end %>

    <main>
    <%= yield %>
  </main>

  <nav id="app">
  </nav>

  <hr>

  <footer>
    <nav>
      <a href="<%= "#{request.protocol}#{ENV.fetch('APEX_STAFF_URL', 'org.localhost')}#{request.port_string}/" %>"><%= t('apex.org.preferences.footer.home') %></a>
      <%= link_to t('apex.org.preferences.footer.preference'), apex_org_preference_url %>
      <%= link_to t("apex.org.configurations.title"), apex_org_configuration_path %>
    </nav>
    <%= render "layouts/shared/footer_theme_controls", scope: :org %>
    <div>
      <%= render "shared/copyright" %>
    </div>
  </footer>
</div>
</body>
</html>
