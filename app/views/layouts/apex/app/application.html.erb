<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (app) Apex", title: page_title %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "apex/main" %>
  <%= stylesheet_link_tag "apex/app/main" %>

  <%= javascript_importmap_tags %>
  <%= yield :head %>
</head>

<body>
<div>
  <div>
    <%= render "shared/flash_messages" %>

    <%= render "layouts/shared/header",
               service_name: "APEX",
               namespace: "app",
               home_path: "#{request.protocol}#{ENV.fetch('APEX_SERVICE_URL', 'app.localhost')}#{request.port_string}/" do %>
      <% unless logged_in? %>
        <%= link_to t("sign.app.layout.nav.sign_up"), new_sign_app_up_url(host: ENV['SIGN_SERVICE_URL']) %>
        <%= link_to t("sign.app.layout.nav.log_in"), new_sign_app_in_url(host: ENV['SIGN_SERVICE_URL']) %>
      <% else %>
        <%= link_to t("sign.app.layout.nav.configuration"), sign_app_configuration_url(host: ENV['SIGN_SERVICE_URL']) %>
        <%= link_to t("sign.app.layout.nav.logout"), edit_sign_app_configuration_out_url(host: ENV['SIGN_SERVICE_URL']) %>
      <% end %>
    <% end %>
    <%= render_current_banner(:app) %>
<% if show_cookie_banner? %>
  <%= render "shared/cookie_banner" %>
<% end %>

    <main>
      <%= yield %>
    </main>

    <%= render "layouts/shared/footer", scope: :app do %>
      <a href="<%= "#{request.protocol}#{ENV.fetch('APEX_SERVICE_URL', 'app.localhost')}#{request.port_string}/" %>"><%= t('apex.app.preferences.footer.home') %></a>
      <%= link_to t('apex.app.preferences.footer.preference'), apex_app_preference_url %>
      <%= link_to t("apex.app.configurations.title"), apex_app_configuration_path %>
    <% end %>
  </div>
</div>
</body>
</html>
