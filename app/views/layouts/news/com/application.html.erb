<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (com) Newsroom" %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "news/main" %>
  <%= stylesheet_link_tag "news/com/main" %>
  <%= javascript_importmap_tags %>
  <link rel="icon" href="https://perm.umaxica.com/favicon.ico" sizes="32x32">
</head>

<body>
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>
<% edge_host = ENV["EDGE_CORPORATE_URL"].presence %>

<div>    <%= render "shared/flash_messages" %>
  <div>

    <header>
      <div>
        <span>News</span>
        <h1>
          <% if edge_host.present? %>
            <a href="http://<%= edge_host %>:4444/"><%= code_name %></a>
          <% else %>
            <%= code_name %>
          <% end %>
          (com)
        </h1>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer>
      <nav>
        <% if edge_host.present? %>
          <a href="http://<%= edge_host %>:4444/">Umaxica</a>
        <% end %>
        <%= link_to t("news.com.preferences.footer.preference"), apex_com_preference_url %>
      </nav>
      <div>
        <%= render "shared/copyright" %>
      </div>
    </footer>
  </div>
</div>
</body>
</html>
