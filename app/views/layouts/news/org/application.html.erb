<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (org) Newsroom" %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "news/main" %>
  <%= stylesheet_link_tag "news/org/main" %>
  <%= javascript_importmap_tags %>
  <link rel="icon" href="https://perm.umaxica.org/favicon.ico" sizes="32x32">
</head>
<body class="bg-[hsl(var(--background))] text-[hsl(var(--foreground))]">
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>
<% edge_host = ENV["EDGE_STAFF_URL"].presence %>

<div class="min-h-screen">    <%= render "concern/flash_messages" %>

  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6">

    <%= render "layouts/shared/header",
               service_name: "News",
               namespace: "org",
               home_path: (edge_host.present? ? "http://#{edge_host}:4444/" : nil) %>

    <main class="flex-1 py-10">
      <%= yield %>
    </main>

    <%= render "layouts/shared/footer" do %>
      <% if edge_host.present? %>
        <a class="font-semibold text-[hsl(var(--foreground))]" href="http://<%= edge_host %>:4444/">home</a>
      <% end %>
      <%= link_to t("news.org.preferences.footer.preference"), apex_org_preference_url, class: "transition hover:text-[hsl(var(--primary))]" %>
    <% end %>
  </div>
</div>
</body>
</html>
