<head>
  <%= display_meta_tags site: (defined?(title) ? title : "#{ENV.fetch('BRAND_NAME', 'Umaxica')} (#{namespace})"), title: page_title %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

  <% if local_assigns[:stylesheets] %>
    <% stylesheets.each do |stylesheet| %>
      <%= stylesheet_link_tag stylesheet %>
    <% end %>
  <% end %>

  <%= javascript_importmap_tags %>

  <% if local_assigns[:favicon_url] %>
    <link rel="icon" href="<%= favicon_url %>" sizes="32x32">
  <% else %>
    <link rel="icon" href="https://perm.umaxica.app/favicon.ico" sizes="32x32">
  <% end %>

  <%= yield :head %>
</head>
