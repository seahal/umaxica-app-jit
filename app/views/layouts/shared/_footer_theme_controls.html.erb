<aside
  aria-labelledby="theme-title"
  class="border border-red-300 p-4 rounded"
  data-controller="theme">
  <form>
    <fieldset class="space-y-3">

      <!-- Title -->
      <legend id="theme-title" class="text-sm font-semibold">
        <%= t(".title") %>
      </legend>

      <!-- Description -->
      <p class="text-xs text-gray-600">
        <%= t(".description") %>
      </p>

      <!-- Options -->
      <div class="space-y-2">

        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="radio"
            name="theme"
            value="system"
            class="accent-gray-600"
            data-action="change->theme#select" />
          <span><%= t(".options.system") %></span>
        </label>

        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="radio"
            name="theme"
            value="light"
            class="accent-yellow-500"
            data-action="change->theme#select" />
          <span><%= t(".options.light") %></span>
        </label>

        <label class="flex items-center gap-2 cursor-pointer">
          <input
            type="radio"
            name="theme"
            value="dark"
            class="accent-black"
            data-action="change->theme#select" />
          <span><%= t(".options.dark") %></span>
        </label>

      </div>
    </fieldset>
  </form>
</aside>
