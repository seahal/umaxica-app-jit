<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (app) Documents" %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "docs/app/main" %>
  <%= javascript_importmap_tags %>
  <link rel="icon" href="https://perm.umaxica.app/favicon.ico" sizes="32x32">
</head>

<body class="bg-[hsl(var(--background))] text-[hsl(var(--foreground))]">
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>
<% edge_host = ENV["EDGE_SERVICE_URL"].presence %>

<div class="min-h-screen">    <%= render "concern/flash_messages" %>
  <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6">

    <%= render "layouts/shared/header",
               service_name: "Docs",
               namespace: "app (docs)",
               home_path: (edge_host.present? ? "http://#{edge_host}/" : nil) do %>
      <%# Preservation of existing logic %>
      <%= link_to_if !@user&.active?, "logout?", new_sign_app_up_path,
                     class: "inline-flex h-9 items-center justify-center rounded-md border border-[hsl(var(--input))] bg-[hsl(var(--background))] px-4 py-2 text-sm font-medium shadow-sm transition-colors hover:bg-[hsl(var(--accent))] hover:text-[hsl(var(--accent-foreground))] focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
      <%= link_to_unless @user&.active?, "login?", new_sign_app_up_path,
                         class: "inline-flex h-9 items-center justify-center rounded-md bg-[hsl(var(--primary))] px-4 py-2 text-sm font-medium text-[hsl(var(--primary-foreground))] shadow transition-colors hover:bg-[hsl(var(--primary))]/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-[hsl(var(--ring))]" %>
    <% end %>

    <main class="flex-1 py-10">
      <%= yield %>
    </main>

    <%= render "layouts/shared/footer" do %>
      <% if edge_host.present? %>
        <a class="font-semibold text-[hsl(var(--foreground))]" href="http://<%= edge_host %>/">Home</a>
      <% end %>
      <%= link_to t("docs.app.preferences.footer.preference"), apex_app_preference_url, class: "transition hover:text-[hsl(var(--primary))]" %>
    <% end %>
  </div>
</div>
</body>
</html>
