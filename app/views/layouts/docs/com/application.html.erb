<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV.fetch('BRAND_NAME', 'Umaxica')} (com) Documents", title: page_title %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "docs/main", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "docs/com/main", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <%= yield :head %>
</head>

<body>

<header>
  <nav>
    <%= render "layouts/shared/flash_messages" %>
    <%= render "layouts/shared/current_banner", surface: :com %>
  </nav>
  <div>
    <span>Docs</span>
    <h1>
      <% if edge_host.present? %>
        <a href="http://<%= edge_host %>/"><%= ENV.fetch("BRAND_NAME", "Umaxica") %></a>
      <% else %>
        <%= ENV.fetch("BRAND_NAME", "Umaxica") %>
      <% end %>
      <span>(com)</span>
    </h1>
  </div>
</header>

<main>
  <%= yield %>
</main>

<footer>
  <nav>
    <ul>
      <% if edge_host.present? %>
        <li><a href="http://<%= edge_host %>/"><%= t("docs.com.preferences.footer.home") %></a></li>
      <% end %>
      <li><%= link_to t("docs.com.preferences.footer.preference"), apex_com_preference_url %></li>
    </ul>
  </nav>
  <%= render "layouts/shared/footer_cookie_controls", scope: :com %>
  <%= render "layouts/shared/footer_theme_controls", scope: :com %>
  <div>
    <%= render "layouts/shared/copyright" %>
  </div>
</footer>
</body>
</html>
