<!DOCTYPE html>
<html lang="<%= get_language %>" data-theme="<%= theme_cookie_value %>" class="<%= theme_html_class %>">
<head>
  <%= display_meta_tags site: "#{ENV['BRAND_NAME']} (app) Help Center", title: (content_for(:page_title) if content_for?(:page_title)) %>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="turbo-refresh-method" content="morph">
  <meta name="turbo-refresh-scroll" content="preserve">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "help/main" %>
  <%= stylesheet_link_tag "help/app/main" %>
  <%= javascript_importmap_tags %>
</head>
<body>
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>
<% edge_host = ENV["EDGE_SERVICE_URL"].presence %>

<div>    <%= render "shared/flash_messages" %>

  <div>

    <header>
      <div>
        <span>Help</span>
        <h1>
          <% if edge_host.present? %>
            <a href="http://<%= edge_host %>/"><%= code_name %></a>
          <% else %>
            <%= code_name %>
          <% end %>
          <span>(app)</span>
        </h1>
      </div>
    </header>
<% if show_cookie_banner? %>
  <%= render "shared/cookie_banner" %>
<% end %>

    <main>
      <%= yield %>
    </main>

    <footer>
      <nav>
        <% if edge_host.present? %>
          <a href="http://<%= edge_host %>/">Home</a>
        <% end %>
        <%= link_to t("help.app.preferences.footer.preference"), apex_app_preference_url %>
        <%= link_to "NewsRoom", news_app_root_url %>
        <%= link_to "Document", docs_app_root_url %>
        <%= link_to "Help Center", help_app_root_url %>
      </nav>
      <%= render "layouts/shared/footer_theme_controls", scope: :app %>
      <div>
        <%= render "shared/copyright" %>
      </div>
    </footer>
  </div>
</div>
</body>
</html>
