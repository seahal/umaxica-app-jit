<section class="mx-auto mt-8 max-w-lg rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <h1 class="text-2xl font-semibold text-slate-900">
    <%= t(
          "apex.org.preference.timezone.edit.heading",
          default: t(
            "apex.org.preference.locale.edit.title",
            default: t("apex.org.preferences.timezone_settings"),
          ),
        ) %>
  </h1>
  <p class="mt-2 text-sm text-slate-600">
    <%= t(
          "apex.org.preference.timezone.edit.description",
          default: t(
            "apex.org.preference.locale.edit.description",
          ),
        ) %>
  </p>

  <% timezone_labels = I18n.t("apex.org.preference.locale.edit.timezone_options", default: {}) %>
  <% timezone_options = OrgPreferenceTimezoneOption.order(:id).map do |option|
    label_key = case option.name
                when "Etc/UTC" then "UTC"
                when "Asia/Tokyo" then "JST"
                end
    label = label_key ? timezone_labels[label_key] : nil
    [label.presence || ActiveSupport::TimeZone[option.name]&.to_s || option.name, option.id]
  end %>

  <%= form_with model: @preference_timezone, scope: :preference_timezone, url: apex_org_preference_region_timezone_path, method: :patch, class: "mt-6 space-y-5" do |f| %>
    <div>
      <%= f.label :option_id,
                  t(
                    "apex.org.preference.timezone.edit.timezone_label",
                    default: t("apex.org.preference.locale.edit.timezone_label"),
                  ),
                  class: "block text-sm font-semibold text-slate-700" %>
      <div class="mt-1">
        <%= f.select :option_id,
                     options_for_select(timezone_options, @preference_timezone.option_id),
                     { include_blank: false },
                     { class: "block w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-primary focus:ring-2 focus:ring-primary" } %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit t("apex.org.preferences.update_settings"),
                   data: { turbo_submits_with: t("apex.org.preferences.submitting") },
                   class: "inline-flex items-center justify-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-900/60" %>
      <%= link_to t("apex.org.preferences.region_settings"), edit_apex_org_preference_region_path, class: "text-sm font-semibold text-slate-700 transition hover:text-slate-900" %>
      <%= link_to t("apex.org.preferences.back_to_settings"), apex_org_preference_url, class: "text-sm font-semibold text-slate-700 transition hover:text-slate-900" %>
    </div>
  <% end %>
</section>
