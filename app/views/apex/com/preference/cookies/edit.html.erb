<% content_for :page_title, t('apex.com.preferences.cookie_settings') %>

<section class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white/90 p-8 shadow-sm mb-10">
  <h1 class="text-2xl font-semibold text-slate-900">
    <%= t "apex.com.preference.cookie.edit.h1" %>
  </h1>

  <%= form_with url: apex_com_preference_cookie_url, method: :patch, class: "mt-6 space-y-3" do |f| %>
    <div class="flex items-start gap-3 rounded-lg border border-slate-200 px-4 py-3 text-sm text-slate-700">
      <%= check_box_tag :accept_necessary_cookies, "1", true, disabled: true, class: "mt-1" %>
      <%= label_tag :accept_necessary_cookies,
                    t("apex.com.preference.cookie.edit.accept_necessary_cookies"),
                    class: "font-semibold text-slate-900" %>
    </div>

    <div class="flex items-start gap-3 rounded-lg border border-slate-200 px-4 py-3 text-sm text-slate-700">
      <%= f.check_box :accept_functional_cookies,
                      { checked: @accept_functional_cookies, class: "mt-1" },
                      "1",
                      "0" %>
      <%= f.label :accept_functional_cookies,
                  t("apex.com.preference.cookie.edit.accept_functional_cookies"),
                  class: "font-semibold text-slate-900" %>
    </div>

    <div class="flex items-start gap-3 rounded-lg border border-slate-200 px-4 py-3 text-sm text-slate-700">
      <%= f.check_box :accept_performance_cookies,
                      { checked: @accept_performance_cookies, class: "mt-1" },
                      "1",
                      "0" %>
      <%= f.label :accept_performance_cookies,
                  t("apex.com.preference.cookie.edit.accept_performance_cookies"),
                  class: "font-semibold text-slate-900" %>
    </div>

    <div class="flex items-start gap-3 rounded-lg border border-slate-200 px-4 py-3 text-sm text-slate-700">
      <%= f.check_box :accept_targeting_cookies,
                      { checked: @accept_targeting_cookies, class: "mt-1" },
                      "1",
                      "0" %>
      <%= f.label :accept_targeting_cookies,
                  t("apex.com.preference.cookie.edit.accept_targeting_cookies"),
                  class: "font-semibold text-slate-900" %>
    </div>

    <div class="flex items-center gap-3 pt-3">
      <%= f.submit t("apex.com.preferences.update_settings"),
                   class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800" %>
      <%= link_to t("apex.com.preferences.back_to_settings"),
                  apex_com_preference_path,
                  class: "inline-flex items-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    </div>
  <% end %>
</section>
