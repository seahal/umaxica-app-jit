<% content_for :page_title, t('apex.com.preference.resets.title') %>

<section class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white/90 p-8 shadow-sm mb-10">
  <h1 class="text-2xl font-semibold text-slate-900">
    <%= t("apex.com.preference.resets.title") %>
  </h1>

  <p class="mt-2 text-sm text-slate-600">
    <%= t("apex.com.preference.resets.description") %>
  </p>

  <div class="mt-6 flex items-center gap-3">
    <%= button_to t("apex.com.preference.resets.button"),
                  apex_com_preference_reset_path,
                  method: :delete,
                  data: { confirm: t("apex.com.preference.resets.confirm") },
                  class: "inline-flex items-center rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-red-500" %>
    <%= link_to t("apex.com.preference.resets.back"),
                apex_com_preference_path,
                class: "inline-flex items-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
  </div>
</section>
