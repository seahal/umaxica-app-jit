<% content_for :page_title, t('apex.com.preferences.regions.title') %>

<section>
  <div>
    <div></div>

    <div>
      <h1>
        <%= t("apex.com.preferences.regions.title") %>
      </h1>
      <p>
        <%= t("apex.com.preferences.regions.select_region_prompt") %>
      </p>
    </div>

    <%= form_with model: @preference_region, scope: :preference_region, url: apex_com_preference_region_url, method: :patch,
                  data: { controller: "unsaved-changes",
                          unsaved_changes_message_value: t("common.unsaved_changes") } do |f| %>

      <div>
        <h2>
          <%= t("apex.com.preferences.regions.region_section") %>
        </h2>
        <div>
          <%= f.label :option_id, t("apex.com.preferences.regions.select_region") %>
          <div>
            <%= f.select :option_id,
                         options_for_select(
                           ComPreferenceRegionOption.all.order(:id).map { |o| [t("apex.com.preferences.regions.select_region_selector.#{o.name}"), o.id] },
                           @preference_region.option_id
                          ),
                         { prompt: t("apex.com.preferences.regions.select_region_prompt") } %>
          </div>
        </div>
      </div>

      <div>
        <%= f.submit t("apex.com.preferences.update_settings"),
                     data: { turbo_submits_with: t("apex.com.preferences.submitting") } %>
        <%= link_to t("apex.com.preferences.back_to_settings"),
                    apex_com_preference_url %>
      </div>
    <% end %>

    <div>
      <div>
        <%= link_to edit_apex_com_preference_region_timezone_path(lx: params[:lx], ri: params[:ri]) do %>
          <div>
            <span><%= t("apex.com.preferences.region.timezone.link") %></span>
          </div>
        <% end %>

        <%= link_to edit_apex_com_preference_region_language_path(lx: params[:lx], ri: params[:ri]) do %>
          <div>
            <span><%= t("apex.com.preferences.region.language.link") %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
