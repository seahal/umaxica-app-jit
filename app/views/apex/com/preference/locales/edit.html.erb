<% scope = local_assigns.fetch(:scope, :com).to_s %>
<% content_for :page_title, t("apex.#{scope}.preferences.locale_settings") %>

<section class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white/90 p-8 shadow-sm mb-10">
  <h1 class="text-2xl font-semibold text-slate-900">
    <%= t("apex.#{scope}.preference.locale.edit.title") %>
  </h1>
  <p class="mt-2 text-sm text-slate-600">
    <%= t("apex.#{scope}.preference.locale.edit.description") %>
  </p>

  <% language_options = I18n.t("apex.#{scope}.preference.locale.edit.language_options", default: {}).map do |code, label|
    [label, code]
  end %>
  <% timezone_options = I18n.t("apex.#{scope}.preference.locale.edit.timezone_options", default: {}).map do |identifier, label|
    [label, identifier]
  end %>
  <% selected_language = @current_language.presence || PreferenceRegions::DEFAULT_LANGUAGE %>
  <% selected_timezone = @current_timezone_identifier.presence || PreferenceRegions::DEFAULT_TIMEZONE %>

  <%= form_with url: public_send("apex_#{scope}_preference_locale_path"),
                method: :patch,
                class: "mt-6 space-y-6" do |f| %>
    <div class="space-y-3">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
        <%= t("apex.#{scope}.preference.locale.edit.language_section") %>
      </h2>
      <div class="space-y-2">
        <%= f.label :language,
                    t("apex.#{scope}.preference.locale.edit.language_label"),
                    class: "text-sm font-medium text-slate-700" %>
        <%= f.select :language,
                     options_for_select(language_options, selected_language),
                     { prompt: t("apex.#{scope}.preference.locale.edit.language_prompt") },
                     class: "w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>
    </div>

    <div class="space-y-3">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">
        <%= t("apex.#{scope}.preference.locale.edit.timezone_section") %>
      </h2>
      <div class="space-y-2">
        <%= f.label :timezone,
                    t("apex.#{scope}.preference.locale.edit.timezone_label"),
                    class: "text-sm font-medium text-slate-700" %>
        <%= f.select :timezone,
                     options_for_select(timezone_options, selected_timezone),
                     { prompt: t("apex.#{scope}.preference.locale.edit.timezone_prompt") },
                     class: "w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit t("apex.#{scope}.preference.locale.edit.submit"),
                   data: { turbo_submits_with: t("apex.com.preferences.submitting") },
                   class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800" %>
      <%= link_to t("apex.#{scope}.preferences.back_to_settings"),
                  public_send("apex_#{scope}_preference_path"),
                  class: "inline-flex items-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    </div>
  <% end %>
</section>
