<% content_for :page_title, 'Edit Timezone' %>
<section>
  <h1>
    <%= t(
          "apex.com.preference.timezone.edit.heading",
          default: t(
            "apex.com.preference.locale.edit.title",
            default: t("apex.com.preferences.timezone_settings"))) %>
  </h1>
  <p>
    <%= t(
          "apex.com.preference.timezone.edit.description",
          default: t(
            "apex.com.preference.locale.edit.description")) %>
  </p>
  <% timezone_labels = I18n.t("apex.com.preference.locale.edit.timezone_options", default: {}) %>
  <% timezone_options = ComPreferenceTimezoneOption.order(:id).map do |option|
    label_key = case option.name
                when "Etc/UTC" then "UTC"
                when "Asia/Tokyo" then "JST"
                end
    label = label_key ? timezone_labels[label_key] : nil
    [label.presence || ActiveSupport::TimeZone[option.name]&.to_s || option.name, option.id]
  end %>

  <%= form_with model: @preference_timezone, scope: :preference_timezone, url: apex_com_preference_region_timezone_path, method: :patch do |f| %>
    <div>
      <%= f.label :option_id,
                  t(
                    "apex.com.preference.timezone.edit.timezone_label",
                    default: t("apex.com.preference.locale.edit.timezone_label")) %>
      <div>
        <%= f.select :option_id,
                     options_for_select(timezone_options, @preference_timezone.option_id),
                     { include_blank: false },
                     {} %>
      </div>
    </div>

    <div>
      <%= f.submit t("apex.com.preferences.update_settings"),
                   data: { turbo_submits_with: t("apex.com.preferences.submitting") } %>
      <%= link_to t("apex.com.preferences.region_settings"), edit_apex_com_preference_region_path %>
      <%= link_to t("apex.com.preferences.back_to_settings"), apex_com_preference_url %>
    </div>
  <% end %>
</section>
