<% content_for :page_title, t('apex.com.preferences.language_settings') %>

<section>
  <h1>
    <%= t(
          'apex.com.preference.language.edit.h1',
          default: t(
            'apex.com.preference.locale.edit.title',
            default: t('apex.com.preferences.language_settings'))) %>
  </h1>
  <p>
    <%= t(
          'apex.com.preference.language.edit.description',
          default: t(
            'apex.com.preference.locale.edit.description')) %>
  </p>

  <% selected_language = nil
     language_options = ComPreferenceLanguageOption.order(:id).map do |option|
    label = case option.name
            when "ja" then t("languages.japanese")
            when "en" then t("languages.english")
            else option.name
            end
    value = option.name.to_s.upcase
    selected_language = value if option.id == @preference_language.option_id
    [label, value]
  end %>

  <%= form_with model: @preference_language, scope: :preference_language, url: apex_com_preference_region_language_path, method: :patch do |f| %>
    <div>
      <%= f.label :option_id,
                  t(
                    'apex.com.preference.language.edit.language_label',
                    default: t('apex.com.preference.locale.edit.language_label')) %>
      <div>
        <%= f.select :option_id,
                     options_for_select(language_options, selected_language),
                     {  } %>
      </div>
    </div>

    <div>
      <%= f.submit t('apex.com.preferences.update_settings'),
                   data: { turbo_submits_with: t("apex.com.preferences.submitting") } %>
      <%= link_to t('apex.com.preferences.region_settings'), edit_apex_com_preference_region_path %>
      <%= link_to t('apex.com.preferences.back_to_settings'), apex_com_preference_url %>
    </div>
  <% end %>
</section>
