<% content_for :page_title, t('apex.com.preferences.title') %>

<section class="mx-auto mt-12 mb-20 max-w-xl animate-fade-in-up">
  <div class="rounded-xl border border-slate-200 bg-white shadow-sm dark:bg-slate-900 dark:border-slate-800">
    <div class="px-8 pt-8 pb-6 border-b border-slate-100 dark:border-slate-800">
      <div class="flex items-center gap-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
            <circle cx="12" cy="12" r="3" />
          </svg>
        </div>
        <div>
          <h1 class="text-xl font-semibold tracking-tight text-slate-900 dark:text-white">
            <%= title t("apex.com.preferences.title") %>
          </h1>
          <p class="text-sm text-slate-500 dark:text-slate-400">
            <%= t("apex.com.preferences.description") %>
          </p>
        </div>
      </div>
    </div>

    <div class="divide-y divide-slate-100 dark:divide-slate-800">
      <!-- Region -->
      <%= link_to edit_apex_com_preference_region_path,
                  class: "group flex items-center justify-between px-8 py-4 transition hover:bg-slate-50 dark:hover:bg-slate-800/50" do %>
        <div class="flex items-center gap-4">
          <span class="text-sm font-medium text-slate-700 group-hover:text-slate-900 dark:text-slate-300 dark:group-hover:text-white transition-colors"><%= t("apex.com.preferences.region_settings") %></span>
        </div>
        <div class="text-slate-400 transition-transform group-hover:translate-x-0.5 group-hover:text-slate-600 dark:text-slate-600 dark:group-hover:text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      <% end %>

      <!-- Timezone -->
      <%= link_to edit_apex_com_preference_region_timezone_path,
                  class: "group flex items-center justify-between px-8 py-4 transition hover:bg-slate-50 dark:hover:bg-slate-800/50" do %>
        <div class="flex items-center gap-4">
          <span class="text-sm font-medium text-slate-700 group-hover:text-slate-900 dark:text-slate-300 dark:group-hover:text-white transition-colors"><%= t("apex.com.preferences.timezone_settings") %></span>
        </div>
        <div class="text-slate-400 transition-transform group-hover:translate-x-0.5 group-hover:text-slate-600 dark:text-slate-600 dark:group-hover:text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      <% end %>

      <!-- Language -->
      <%= link_to edit_apex_com_preference_region_language_path,
                  class: "group flex items-center justify-between px-8 py-4 transition hover:bg-slate-50 dark:hover:bg-slate-800/50" do %>
        <div class="flex items-center gap-4">
          <span class="text-sm font-medium text-slate-700 group-hover:text-slate-900 dark:text-slate-300 dark:group-hover:text-white transition-colors"><%= t("apex.com.preferences.language_settings") %></span>
        </div>
        <div class="text-slate-400 transition-transform group-hover:translate-x-0.5 group-hover:text-slate-600 dark:text-slate-600 dark:group-hover:text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      <% end %>

      <!-- Theme -->
      <%= link_to edit_apex_com_preference_theme_path,
                  class: "group flex items-center justify-between px-8 py-4 transition hover:bg-slate-50 dark:hover:bg-slate-800/50" do %>
        <div class="flex items-center gap-4">
          <span class="text-sm font-medium text-slate-700 group-hover:text-slate-900 dark:text-slate-300 dark:group-hover:text-white transition-colors"><%= t("apex.com.preferences.theme_settings") %></span>
        </div>
        <div class="text-slate-400 transition-transform group-hover:translate-x-0.5 group-hover:text-slate-600 dark:text-slate-600 dark:group-hover:text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      <% end %>

      <!-- Cookie -->
      <%= link_to edit_apex_com_preference_cookie_path,
                  class: "group flex items-center justify-between px-8 py-4 transition hover:bg-slate-50 dark:hover:bg-slate-800/50" do %>
        <div class="flex items-center gap-4">
          <span class="text-sm font-medium text-slate-700 group-hover:text-slate-900 dark:text-slate-300 dark:group-hover:text-white transition-colors"><%= t("apex.com.preferences.cookie_settings") %></span>
        </div>
        <div class="text-slate-400 transition-transform group-hover:translate-x-0.5 group-hover:text-slate-600 dark:text-slate-600 dark:group-hover:text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      <% end %>

      <!-- Reset -->
      <%= link_to edit_apex_com_preference_reset_path,
                  class: "group flex items-center justify-between px-8 py-4 transition hover:bg-rose-50/50 dark:hover:bg-rose-900/10" do %>
        <div class="flex items-center gap-4">
          <span class="text-sm font-medium text-slate-700 group-hover:text-rose-600 dark:text-slate-300 dark:group-hover:text-rose-400 transition-colors"><%= t("apex.com.preferences.reset_settings") %></span>
        </div>
        <div class="text-slate-400 transition-transform group-hover:translate-x-0.5 group-hover:text-rose-500 dark:text-slate-600 dark:group-hover:text-rose-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m9 18 6-6-6-6" />
          </svg>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-8 text-center">
    <%= link_to apex_com_root_path(ct: "dr", lx: "en", ri: "us", tz: "jst"),
                class: "inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-800 transition-colors dark:text-slate-400 dark:hover:text-slate-200" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6" />
      </svg>
      <span><%= t("apex.com.preferences.up_link") %></span>
    <% end %>
  </div>
</section>
