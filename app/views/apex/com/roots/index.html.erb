<% content_for :page_title, "#{ENV['BRAND_NAME']} (com)" %>

<section class="mx-auto mb-10 max-w-2xl rounded-2xl border border-slate-200 bg-white/90 p-8 shadow-sm">
  <h1 class="text-2xl font-semibold text-slate-900">
    Welcome to <%= ENV["BRAND_NAME"] %> (com)
  </h1>
  <p class="mt-2 text-sm text-slate-600">
    <%= t("apex.com.preferences.footer.preference") %> へすぐ移動できます。
  </p>

  <ul class="mt-6 space-y-2 text-sm">
    <li>
      <a class="block rounded-lg border border-slate-200 px-4 py-3 text-slate-700 transition hover:border-slate-300 hover:bg-slate-50"
         href="https://<%= ENV['EDGE_CORPORATE_URL'] %>"
         data-turbo-frame="_top">
        <%= t("apex.com.preferences.footer.home") %>
      </a>
    </li>
    <li>
      <%= link_to t("apex.com.preferences.footer.preference"), apex_com_preference_url,
                  class: "block rounded-lg border border-slate-200 px-4 py-3 text-slate-700 transition hover:border-slate-300 hover:bg-slate-50",
                  data: { turbo_frame: "_top" } %>
    </li>
  </ul>
</section>
