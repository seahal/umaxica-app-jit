<% content_for :page_title, "#{ENV['BRAND_NAME']} (com)" %>

<section>
  <h1>
    Welcome to <%= ENV["BRAND_NAME"] %> (com)
  </h1>
  <p>
    <%= t("apex.com.preferences.footer.preference") %> へすぐ移動できます。
  </p>

  <ul>
    <li>
      <a
         href="https://<%= ENV['EDGE_CORPORATE_URL'] %>"
         data-turbo-frame="_top">
        <%= t("apex.com.preferences.footer.home") %>
      </a>
    </li>
    <li>
      <%= link_to t("apex.com.preferences.footer.preference"), apex_com_preference_url,
                  data: { turbo_frame: "_top" } %>
    </li>
  </ul>
</section>
