<div>
  <div>
    <div>
      <div>
        <h1><%= t("news.posts.index.title") %></h1>

        <div>
          <%= t("news.posts.index.count", count: @posts.size) %>
        </div>
      </div>

      <% if @posts.any? %>
        <div>
          <% @posts.each do |post| %>
            <div>
              <%= link_to news_org_v1_post_path(post[:id]),
                          data: { turbo_frame: "post_detail" } do %>
                <h3>
                  <%= post[:title] %>
                </h3>
                <% timestamp = post[:updated_at] || post[:published_at] %>
                <% if timestamp.present? %>
                  <div>
                    <%= l(timestamp, format: :long) %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div>
          <p><%= t("news.posts.index.empty") %></p>
        </div>
      <% end %>
    </div>

    <div>
      <%= turbo_frame_tag "post_detail" do %>
        <div>
          <h3><%= t("news.posts.index.select_title") %></h3>
          <p>
            <%= t("news.posts.index.select_description") %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
