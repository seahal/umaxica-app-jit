<% content_for :page_title, 'クイックステータス' %>
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>

<div>
  <div></div>

  <div>
    <section>
      <div>
        <h2><%= code_name %> Staff Help</h2>
        <p>
          スタッフ向けのサポート窓口です。社内の問い合わせフローや日次の対応手順を確認できます。
        </p>
        <div>
          <% contact_params = request.query_parameters.slice("ct", "lx", "ri", "tz").compact %>
          <% contact_host = ENV.fetch("CORE_STAFF_URL", request.host) %>
          <%= link_to "Contact Support", new_core_org_contact_url(contact_params.merge(host: contact_host)) %>
        </div>
      </div>

      <div>
        <h3>クイックステータス</h3>
        <dl>
          <div>
            <dt>Current language</dt>
            <dd><%= I18n.locale %></dd>
          </div>
          <div>
            <dt>TimeZone</dt>
            <dd><%= params[:tz].to_s.downcase == "utc" ? "utc" : "jst" %></dd>
          </div>
          <div>
            <dt>Hello</dt>
            <dd><%= I18n.t "hello" %></dd>
          </div>
          <div>
            <dt>Local time</dt>
            <dd><%= to_localetime Time.current, "jst" %></dd>
          </div>
          <div>
            <dt>UTC time</dt>
            <dd><%= Time.current.in_time_zone("UTC") %></dd>
          </div>
        </dl>
      </div>
    </section>
  </div>
</div>
