<% content_for :page_title, 'クイックステータス' %>
<% content_for :help_app_react_shell, true %>
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>
<% help_service_host = ENV["HELP_SERVICE_URL"].presence || "" %>
<% docs_service_host = ENV["DOCS_SERVICE_URL"].presence || "" %>
<% news_service_host = ENV["NEWS_SERVICE_URL"].presence || "" %>

<div>
  <div></div>

  <div>
    <div
      id="help-app-react-roots"
      data-code-name="<%= code_name %>"
      data-help-service-url="<%= help_service_host %>"
      data-docs-service-url="<%= docs_service_host %>"
      data-news-service-url="<%= news_service_host %>">
    </div>

    <section>
      <div>
        <h2><%= code_name %> Help Center</h2>
        <p>
          JavaScript を有効にすると、React Aria を使ったインタラクティブな体験をご覧いただけます。
        </p>
        <div>
          <% contact_params = request.query_parameters.slice("ct", "lx", "ri", "tz").compact %>
          <% contact_host = ENV.fetch("CORE_SERVICE_URL", request.host) %>
          <%= link_to "Contact", new_core_app_contact_url(contact_params.merge(host: contact_host)) %>
        </div>
      </div>

      <div>
        <h3>クイックステータス</h3>
        <dl>
          <div>
            <dt>Current language</dt>
            <dd><%= I18n.locale %></dd>
          </div>
          <div>
            <dt>TimeZone</dt>
            <dd><%= params[:tz].to_s.downcase == "utc" ? "utc" : "jst" %></dd>
          </div>
          <div>
            <dt>Hello</dt>
            <dd><%= I18n.t "hello" %></dd>
          </div>
          <div>
            <dt>Local time</dt>
            <dd><%= to_localetime Time.current, "jst" %></dd>
          </div>
          <div>
            <dt>UTC time</dt>
            <dd><%= Time.current.in_time_zone("UTC") %></dd>
          </div>
        </dl>
      </div>
    </section>
  </div>
</div>
