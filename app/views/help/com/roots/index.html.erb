<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>

<div>
  <div></div>

  <div>
    <div id="help-com-react-root"></div>

    <section>
      <div>
        <h2><%= code_name %> Help Center</h2>
        <p>
          法人向けのサポート窓口・手続き案内をまとめています。担当者の連絡先もこちらから確認できます。
        </p>
        <div>
          <% contact_params = request.query_parameters.slice("ct", "lx", "ri", "tz").compact %>
          <% contact_host = ENV.fetch("CORE_CORPORATE_URL", request.host) %>
          <%= link_to "Contact", new_core_com_contact_url(contact_params.merge(host: contact_host)) %>
        </div>
      </div>

      <div>
        <h3>クイックステータス</h3>
        <dl>
          <div>
            <dt>Current language</dt>
            <dd><%= I18n.locale %></dd>
          </div>
          <div>
            <dt>TimeZone</dt>
            <dd><%= params[:tz].to_s.downcase == "utc" ? "utc" : "jst" %></dd>
          </div>
          <div>
            <dt>Hello</dt>
            <dd><%= I18n.t "hello" %></dd>
          </div>
          <div>
            <dt>Local time</dt>
            <dd><%= to_localetime Time.current, "jst" %></dd>
          </div>
          <div>
            <dt>UTC time</dt>
            <dd><%= Time.current.in_time_zone("UTC") %></dd>
          </div>
        </dl>
      </div>
    </section>
  </div>
</div>
