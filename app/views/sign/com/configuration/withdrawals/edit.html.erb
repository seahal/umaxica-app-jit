<% content_for :page_title, t("sign.app.configuration.withdrawal.recovery.page_title") %>

<h1><%= t("sign.app.configuration.withdrawal.recovery.page_title") %></h1>

<p>
  <%= t("sign.app.configuration.withdrawal.recovery.deadline", date: l(@recovery_deadline, format: :long)) %>
</p>

<% if @recoverable %>
  <p><%= t("sign.app.configuration.withdrawal.recovery.available") %></p>

  <%= button_to t("sign.app.configuration.withdrawal.recovery.submit"),
                sign_com_configuration_withdrawal_path(ri: params[:ri]),
                method: :post,
                data: { turbo_confirm: t("sign.app.configuration.withdrawal.recovery.confirm") } %>
<% else %>
  <p><%= t("sign.app.configuration.withdrawal.recovery.unavailable") %></p>
<% end %>

<p>
  <%= link_to t("actions.back"), sign_com_configuration_path(ri: params[:ri]) %>
</p>
