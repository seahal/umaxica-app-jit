<div class="mx-auto mt-24 mb-32 max-w-md animate-fade-in-up">
  <div class="text-center mb-12">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
      <%= t("sign.org.ups.new.heading", default: "Sign::Org::Ups#new") %>
    </h1>
    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
       <%= t("sign.org.ups.new.description", default: "Join the organization.") %>
    </p>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white/80 backdrop-blur-xl shadow-lg ring-1 ring-black/5 dark:bg-slate-900/80 dark:border-slate-800 dark:ring-white/10 p-10 space-y-6">

    <div class="text-center text-sm text-slate-700 dark:text-slate-300">
      <p class="mb-6">
        <%= t("sign.org.ups.new.recruit_prompt", default: "採用を希望しますか？") %>
      </p>
      <%= link_to t("sign.org.ups.new.recruit_link_text"),
                  new_core_org_contact_url(host: ENV.fetch("CORE_STAFF_URL", "core.org.localhost"), category: "recruit", ri: params[:ri], lx: params[:lx]),
                  class: "group relative inline-flex items-center justify-center w-full rounded-xl border border-blue-200 bg-blue-50 px-5 py-3.5 text-sm font-semibold text-blue-700 transition duration-300 hover:border-blue-300 hover:shadow-md hover:text-blue-800 dark:border-blue-900/30 dark:bg-blue-900/20 dark:text-blue-300 dark:hover:border-blue-700" %>
    </div>

    <div class="pt-8 border-t border-slate-100 dark:border-slate-800 text-center">
      <%= link_to apex_org_root_path,
                  class: "inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-slate-500 hover:text-slate-800 transition-colors dark:text-slate-400 dark:hover:text-slate-200" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span><%= t("sign.org.ups.new.back_to_root", default: "うえへ") %></span>
      <% end %>
    </div>
  </div>
</div>
