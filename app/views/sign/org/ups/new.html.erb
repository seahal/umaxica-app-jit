<div class="animate-fade-in-up">
  <div>
    <h1>
      <%= t("sign.org.ups.new.heading") %>
    </h1>
    <p>
      <%= t("sign.org.ups.new.description") %>
    </p>
  </div>

  <div>

    <div>
      <p>
        <%= t("sign.org.ups.new.recruit_prompt") %>
      </p>
      <%= link_to t("sign.org.ups.new.recruit_link_text"),
                  new_core_org_contact_url(host: ENV.fetch("CORE_STAFF_URL", "core.org.localhost"), category: "recruit", ri: params[:ri], lx: params[:lx]) %>
    </div>

    <div>
      <%= link_to apex_org_root_path do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6" />
        </svg>
        <span><%= t("sign.org.ups.new.back_to_root") %></span>
      <% end %>
    </div>
  </div>
</div>
