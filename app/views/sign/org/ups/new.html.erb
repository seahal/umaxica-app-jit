<div class="max-w-xl rounded-2xl border border-slate-200 bg-white/80 p-6 shadow-lg">
  <h1 class="text-3xl font-semibold text-slate-900">
    <%= t("sign.org.ups.new.heading", default: "Sign::Org::Ups#new") %>
  </h1>
  <p class="mt-2 text-sm text-slate-600">
    <%= t("sign.org.ups.new.description", default: "Find me in app/views/sign/org/ups/new.html.erb") %>
  </p>

  <div class="mt-4 space-y-2 text-sm text-slate-700">
    <p>
      <%= t(
            "sign.org.ups.new.recruit_prompt_html",
            default: "採用を希望しますか？ %{link}",
            link: sign_org_recruit_contact_link,
          ).html_safe %>
    </p>
    <p>
      <%= link_to apex_org_root_path(ct: "sy", lx: "ja", ri: "jp", tz: "jst"),
                  class: "inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.4em] text-slate-500" do %>
        <span aria-hidden="true">↑</span>
        <span><%= t("sign.org.ups.new.back_to_root", default: "うえへ") %></span>
      <% end %>
    </p>
  </div>
</div>
