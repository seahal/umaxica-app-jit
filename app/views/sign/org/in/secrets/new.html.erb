<% title t("sign.org.authentication.secret.new.page_title", default: "Secret sign in") %>

<div class="mx-auto max-w-md">
  <div class="text-center mb-8">
    <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-slate-100">
      <svg class="h-7 w-7 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t("sign.org.authentication.secret.new.page_title", default: "Secret sign in") %></h1>
  </div>

  <%= form_with url: sign_org_in_secret_path,
                data: { turbo: false },
                class: "space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |f| %>

    <div class="space-y-2">
      <%= f.label :account_identifiable_information,
                  t("sign.org.authentication.secret.new.pii_label", default: "Account identifiable information"),
                  class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :account_identifiable_information,
                       class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-slate-200" %>
    </div>

    <div class="space-y-2">
      <%= f.label :secret_value,
                  t("sign.org.authentication.secret.new.secret_label", default: "Secret"),
                  class: "block text-sm font-medium text-slate-700" %>
      <%= f.password_field :secret_value,
                           class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-slate-200" %>
    </div>

    <div class="space-y-2">
      <%= f.label :totp_code,
                  t("sign.org.authentication.secret.new.totp_label", default: "TOTP code"),
                  class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :totp_code,
                       class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-slate-200" %>
    </div>

    <%= render "concern/cloudflare_turnstile" %>

    <div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
      <%= f.check_box :confirm_saved,
                      { class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-400 focus:ring-offset-0" },
                      "1", "0" %>
      <%= f.label :confirm_saved,
                  t("sign.org.authentication.secret.new.confirm_label", default: "I have saved the secret"),
                  class: "block text-sm font-medium text-slate-700 cursor-pointer" %>
    </div>

    <div class="flex flex-col gap-3 pt-2">
      <%= f.submit t("actions.submit", default: "Continue"),
                   class: "w-full rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:bg-slate-800 hover:shadow-md active:scale-[0.98]" %>
      <%= link_to t("sign.org.authentication.new.back"), new_sign_org_in_path,
                  class: "flex items-center justify-center w-full rounded-xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
