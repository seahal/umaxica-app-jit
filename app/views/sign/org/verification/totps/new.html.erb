<% title t("sign.org.verification.edit.title") %>

<div>
  <h1><%= t("sign.org.verification.edit.title") %></h1>
  <p><%= t("sign.org.verification.edit.description") %></p>

  <% if @reauth_session.errors.any? %>
    <div>
      <%= @reauth_session.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= form_with url: sign_org_verification_totp_path(ri: params[:ri]), method: :post, data: { turbo: false } do |f| %>
    <%= f.hidden_field :session_id, value: @reauth_session.id, name: "verification[session_id]" %>
    <div>
      <%= f.label :code, t("sign.org.verification.edit.code_label") %>
      <%= f.text_field :code, inputmode: "numeric", autocomplete: "one-time-code", placeholder: t("sign.org.verification.edit.code_placeholder"), name: "verification[code]" %>
    </div>

    <div>
      <%= f.submit t("sign.org.verification.edit.submit") %>
    </div>
  <% end %>

  <div>
    <%= link_to t("sign.org.verification.edit.back"), sign_org_verification_path(ri: params[:ri]) %>
  </div>
</div>
