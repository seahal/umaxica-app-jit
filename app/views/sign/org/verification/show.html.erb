<% content_for :page_title, t("sign.org.verification.index.title") %>
<% title t("sign.org.verification.index.title") %>

<div>
  <div>
    <h1><%= t("sign.org.verification.index.title") %></h1>
  </div>

  <div>
    <h2><%= t("sign.org.verification.new.title") %></h2>
    <p><%= t("sign.org.verification.new.description") %></p>

    <% if flash[:alert] %>
      <div>
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if @available_methods.blank? %>
      <p>passkey/totp を登録してください</p>
    <% else %>
      <div>
        <% if @available_methods.include?(:passkey) %>
          <div>
            <%= link_to t("sign.org.verification.new.methods.passkey"),
                        new_sign_org_verification_passkey_path(ri: params[:ri]) %>
          </div>
        <% end %>

        <% if @available_methods.include?(:totp) %>
          <div>
            <%= link_to t("sign.org.verification.new.methods.totp"),
                        new_sign_org_verification_totp_path(ri: params[:ri]) %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
