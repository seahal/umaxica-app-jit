<% content_for :page_title, 'Edit Language' %>
<section>
  <h1>
      <%= t("apex.org.preference.language.edit.heading") %>
  </h1>
  <p>
      <%= t("apex.org.preference.language.edit.description") %>
  </p>

  <% selected_language = nil
     language_options = OrgPreferenceLanguageOption.order(:id).map do |option|
       label = case option.name
               when "ja" then t("languages.japanese")
               when "en" then t("languages.english")
               else option.name
               end
       value = option.name.to_s.upcase
       selected_language = value if option.id == @preference_language.option_id
       [label, value]
     end %>

  <%= form_with model: @preference_language, scope: :preference_language, url: sign_org_preference_region_language_path, method: :patch do |f| %>
    <div>
      <%= f.label :option_id,
                  t("apex.org.preference.language.edit.language_label") %>
      <div>
        <%= f.select :option_id,
                     options_for_select(language_options, selected_language),
                     {} %>
      </div>
    </div>

    <div>
      <%= f.submit t("apex.org.preferences.update_settings"),
                   data: { turbo_submits_with: t("apex.org.preferences.submitting") } %>
      <%= link_to t("apex.org.preferences.region_settings"), edit_sign_org_preference_region_path %>
      <%= link_to t("apex.org.preferences.back_to_settings"), sign_org_preference_url %>
    </div>
  <% end %>
</section>
