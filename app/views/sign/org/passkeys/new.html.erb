<h1>Passkey authentication</h1>
<p>Sign in with your passkey.</p>

<%= form_with model: @staff_telephone, url: sign_org_authentication_passkey_path, data: { turbo: false } do |form| %>
  <% if @staff_telephone.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(@staff_telephone.errors.count, "error") %> prohibited this sample from being saved:</h2>

      <ul>
        <% @staff_telephone.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :address %>
    <%= form.email_field :address %>
  </div>

  <%= render "shared/cloudflare_turnstile" %>

  <%= form.submit %>
<% end %>

<ul>
  <li><%= link_to "Back", new_sign_org_in_path %></li>
</ul>
