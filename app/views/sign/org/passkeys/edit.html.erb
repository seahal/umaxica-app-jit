<h1>Passkey authentication</h1>
<p>Update your passkey sign-in.</p>

<%= form_with model: @staff_telephone, url: sign_org_authentication_passkey_path, method: :patch, data: { turbo: false } do |form| %>
  <div>
    <%= form.label :address %>
    <%= form.email_field :address %>
  </div>

  <%= render "shared/cloudflare_turnstile" %>

  <%= form.submit %>
<% end %>
