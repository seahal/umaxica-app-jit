<div class="mx-auto max-w-xl">
  <h1 class="text-3xl font-semibold text-slate-900"><%= title t("sign.org.root.title", default: "Welcome") %></h1>
  <p class="mt-2 text-sm text-slate-600"><%= t("sign.org.root.description", default: "Choose an action below") %></p>

  <div class="mt-6 space-y-3 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= link_to t("sign.org.root.registration", default: "Sign Up"),
                new_sign_org_up_path,
                class: "block w-full rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    <%= link_to t("sign.org.root.authentication", default: "Sign In"),
                new_sign_org_in_path,
                class: "block w-full rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
  </div>
</div>
