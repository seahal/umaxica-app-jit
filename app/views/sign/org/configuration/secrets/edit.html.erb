<div>
  <div>
    <div>
      <div>
        <h3><%= t('.title') %></h3>
        <p><%= t('.description') %></p>
      </div>
    </div>
    <div>
      <%= form_with(model: @secret, url: sign_org_configuration_secret_path(@secret), method: :patch) do |form| %>
        <div>
          <% if @secret.errors.any? %>
            <div>
              <div>
                <div>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <h3><%= t('errors.template.header', model: @secret.model_name.human, count: @secret.errors.count) %></h3>
                  <div>
                    <ul role="list">
                      <% @secret.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div>
            <div>
              <%= form.label :name %>
              <div>
                <%= form.text_field :name %>
              </div>
            </div>
          </div>
        </div>
        <div>
          <%= link_to t('actions.cancel'), sign_org_configuration_secrets_path %>
          <%= form.submit t('actions.update') %>
        </div>
      <% end %>
    </div>
  </div>
</div>
