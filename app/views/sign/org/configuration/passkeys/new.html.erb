<% title t("sign.org.configuration.passkeys.new.page_title") %>

<div>
  <div>
    <div>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.2-2.858.571-4.175m5.3 1.25a2 2 0 011.66 0" />
      </svg>
    </div>
    <h1><%= t("sign.org.configuration.passkeys.new.page_title") %></h1>
    <p><%= t("sign.org.configuration.passkeys.new.description") %></p>
  </div>

  <div
       data-controller="passkey-registration"
       data-passkey-registration-options-url-value="<%= options_sign_org_configuration_passkeys_path %>"
       data-passkey-registration-verification-url-value="<%= verification_sign_org_configuration_passkeys_path %>">

    <div>
      <label for="description">
        <%= t("sign.org.configuration.passkeys.new.description_label") %>
      </label>
      <input type="text"
             id="description"
             data-passkey-registration-target="description"
             placeholder="<%= t("sign.org.configuration.passkeys.new.description_placeholder") %>"
             maxlength="100">
    </div>

    <p data-passkey-registration-target="error" class="hidden"></p>
    <p data-passkey-registration-target="status" class="hidden"></p>

    <div>
      <button type="button"
              data-action="click->passkey-registration#register">
        <%= t("sign.org.configuration.passkeys.new.submit") %>
      </button>
      <%= link_to t("sign.common.cancel"), sign_org_configuration_passkeys_path %>
    </div>
  </div>
</div>
