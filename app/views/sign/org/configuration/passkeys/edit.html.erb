<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="text-center mb-8">
    <h1 class="text-2xl font-bold text-slate-900"><%= t('sign.org.configuration.passkeys.edit.title') %></h1>
  </div>

  <%= form_with model: @passkey, url: sign_org_configuration_passkey_path(@passkey), method: :patch, class: "space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |form| %>
    <% if @passkey.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">
              <%= t('errors.messages.validation_errors', count: @passkey.errors.count) %>
            </h3>
            <div class="mt-2 text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% @passkey.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= form.label :description, t('activerecord.attributes.staff_passkey.description'), class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.text_field :description, class: "styled w-full rounded-lg border border-slate-300 px-4 py-3 text-slate-900 placeholder-slate-400 focus:border-slate-500 focus:outline-none focus:ring-1 focus:ring-slate-500", maxlength: 100 %>
    </div>

    <div class="flex flex-col gap-3 pt-2">
      <%= form.submit t('actions.save'), class: "w-full rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:bg-slate-800 hover:shadow-md active:scale-[0.98] cursor-pointer" %>
      <%= link_to t('sign.common.cancel'), sign_org_configuration_passkeys_path, class: "flex items-center justify-center w-full rounded-xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
