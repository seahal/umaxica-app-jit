<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900"><%= t('sign.org.configuration.passkeys.show.title') %></h3>
    </div>
    <div class="border-t border-gray-200">
      <dl>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('activerecord.attributes.staff_passkey.description') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @passkey.description %></dd>
        </div>
        <div class="bg-white px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('activerecord.attributes.staff_passkey.created_at') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= l(@passkey.created_at, format: :long) %></dd>
        </div>
        <div class="bg-gray-50 px-4 py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
          <dt class="text-sm font-medium text-gray-500"><%= t('activerecord.attributes.staff_passkey.sign_count') %></dt>
          <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2"><%= @passkey.sign_count %></dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="mt-6 flex justify-between">
    <%= link_to t('sign.org.configuration.passkeys.show.back'), sign_org_configuration_passkeys_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
    <div class="space-x-4">
      <%= link_to t('actions.edit'), edit_sign_org_configuration_passkey_path(@passkey), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
      <%= link_to t('actions.destroy'), sign_org_configuration_passkey_path(@passkey), data: { turbo_method: :delete, turbo_confirm: t('messages.confirm_destroy') }, class: "text-sm font-medium text-red-600 hover:text-red-500" %>
    </div>
  </div>
</div>
