<% content_for :page_title, t("sign.org.configuration.telephone.new.title") %>

<h1><%= t("sign.org.configuration.telephone.new.title") %></h1>

<%= form_with model: @staff_telephone, url: sign_org_configuration_telephones_registration_path do |form| %>
  <% if @staff_telephone.errors.any? %>
    <div>
      <ul role="list">
        <% @staff_telephone.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :raw_number, t("activerecord.attributes.staff_telephone.number") %>
    <%= form.telephone_field :raw_number, placeholder: "+819012345678" %>
  </div>

  <div>
    <%= link_to t("actions.cancel"), sign_org_configuration_telephones_path %>
    <%= form.submit t("actions.submit") %>
  </div>
<% end %>
