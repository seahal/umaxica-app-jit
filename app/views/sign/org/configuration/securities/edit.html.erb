<div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-zinc-900 dark:text-white">
      <%= t("controller.sign.org.configuration.security.edit.title") %>
    </h1>
    <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
      <%= t("controller.sign.org.configuration.security.edit.description") %>
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <% @security_cards.each do |card| %>
      <article class="flex flex-col justify-between rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm transition hover:border-blue-500 hover:shadow-lg dark:border-zinc-800 dark:bg-zinc-900">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-zinc-500 dark:text-zinc-400">
            <%= card[:title] %>
          </p>
          <p class="mt-3 text-sm text-zinc-600 dark:text-zinc-300">
            <%= card[:description] %>
          </p>
        </div>

        <div class="mt-5">
          <p class="text-xl font-bold text-zinc-900 dark:text-white">
            <%= t("controller.sign.org.configuration.security.states.#{card[:enabled] ? "enabled" : "disabled"}") %>
          </p>
          <% unless card[:stats].nil? %>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">
              <%= card[:stats] %> <%= card[:stats_label] %>
            </p>
          <% end %>
          <div class="mt-4">
            <%= link_to t("controller.sign.org.configuration.security.actions.manage"),
                        card[:path],
                        class: "inline-flex w-full items-center justify-center rounded-md border border-transparent bg-blue-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400" %>
          </div>
        </div>
      </article>
    <% end %>
  </div>

  <section class="mt-10 rounded-2xl border border-zinc-200 bg-zinc-50 p-6 dark:border-zinc-800 dark:bg-zinc-900">
    <div class="text-sm text-zinc-700 dark:text-zinc-200">
      <p>
        <span class="font-semibold text-zinc-900 dark:text-white">
          <%= t("controller.sign.org.configuration.security.review.heading") %>
        </span>
      </p>
      <p class="mt-2">
        <%= t("controller.sign.org.configuration.security.review.last_review") %>
        <span class="font-semibold text-blue-600 dark:text-blue-400">
          <%= @reviewed_at ? l(@reviewed_at, format: :long) : t("controller.sign.org.configuration.security.never") %>
        </span>
      </p>
    </div>

    <div class="mt-4">
      <%= form_with url: sign_org_configuration_security_path, method: :patch, local: true do %>
        <%= submit_tag t("controller.sign.org.configuration.security.actions.review"),
                       class: "inline-flex w-full items-center justify-center rounded-md border border-transparent bg-blue-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-blue-700 dark:bg-blue-500 dark:hover:bg-blue-400" %>
      <% end %>
    </div>
  </section>
</div>
