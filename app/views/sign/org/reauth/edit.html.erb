<% title t("sign.org.reauth.edit.title") %>

<div class="mx-auto max-w-xl px-4 py-10">
  <h1 class="text-2xl font-bold text-slate-900"><%= t("sign.org.reauth.edit.title") %></h1>
  <p class="mt-2 text-sm text-slate-600"><%= t("sign.org.reauth.edit.description") %></p>

  <% if @reauth_session.errors.any? %>
    <div class="mt-6 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800">
      <%= @reauth_session.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= form_with model: @reauth_session, url: sign_org_verification_path(ri: params[:ri]), method: :patch, data: { turbo: false } do |f| %>
    <% if @reauth_session.method == "passkey" %>
      <% options_json = @passkey_request_options ? json_escape(@passkey_request_options.to_json) : "" %>
      <div
        data-controller="reauth-passkey"
        data-reauth-passkey-options-value="<%= options_json %>"
        data-reauth-passkey-challenge-id-value="<%= @passkey_challenge_id.to_s %>">

        <%= f.hidden_field :challenge_id, value: @passkey_challenge_id.to_s, data: { "reauth-passkey-target": "challengeId" } %>
        <%= f.hidden_field :credential_json, value: "", data: { "reauth-passkey-target": "credentialJson" } %>

        <button type="button"
                data-action="click->reauth-passkey#authenticate"
                class="mt-6 inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
          <%= t("sign.org.reauth.edit.authenticate_with_passkey") %>
        </button>
        <p data-reauth-passkey-target="error" class="mt-3 hidden text-sm text-red-600"></p>
        <p data-reauth-passkey-target="status" class="mt-3 hidden text-sm text-slate-600"></p>
      </div>
    <% else %>
      <div class="mt-6">
        <%= f.label :code, t("sign.org.reauth.edit.code_label"), class: "block text-sm font-medium text-slate-900" %>
        <%= f.text_field :code, inputmode: "numeric", autocomplete: "one-time-code", class: "mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: t("sign.org.reauth.edit.code_placeholder") %>
      </div>

      <div class="mt-8">
        <%= f.submit t("sign.org.reauth.edit.submit"), class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
      </div>
    <% end %>
  <% end %>

  <div class="mt-6 flex items-center gap-3">
    <%= link_to t("sign.org.reauth.edit.cancel"), sign_org_verification_path(ri: params[:ri]), data: { turbo_method: :delete, turbo_confirm: t("sign.org.reauth.edit.confirm_cancel") }, class: "text-sm text-slate-600 hover:text-slate-900" %>
  </div>
</div>
