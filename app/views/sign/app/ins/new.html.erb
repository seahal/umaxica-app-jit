<div class="mx-auto mt-24 mb-32 max-w-md animate-fade-in-up">
  <div class="text-center mb-12">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-white">
      <%= t("sign.app.authentication.new.page_title") %>
    </h1>
    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
      <%= t("sign.app.authentication.new.description") %>
    </p>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white/80 backdrop-blur-xl shadow-lg ring-1 ring-black/5 dark:bg-slate-900/80 dark:border-slate-800 dark:ring-white/10 p-10 space-y-6">
    <%= link_to new_sign_app_in_email_path,
                class: "group relative flex items-center w-full rounded-xl border border-slate-200 bg-white px-5 py-3.5 text-sm font-semibold text-slate-700 transition duration-300 hover:border-indigo-300 hover:shadow-md hover:text-indigo-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-indigo-500 dark:hover:text-indigo-400" do %>
      <div class="mr-3 flex h-8 w-8 items-center justify-center rounded-lg bg-slate-50 text-slate-500 group-hover:bg-indigo-50 group-hover:text-indigo-600 dark:bg-slate-700 dark:text-slate-400 dark:group-hover:bg-indigo-900/30 dark:group-hover:text-indigo-400 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </div>
      <span><%= t("sign.app.authentication.new.links.email") %></span>
      <div class="ml-auto text-slate-300 group-hover:translate-x-1 group-hover:text-indigo-500 transition-all dark:text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </div>
    <% end %>

    <%= link_to new_sign_app_in_passkey_path,
                class: "group relative flex items-center w-full rounded-xl border border-slate-200 bg-white px-5 py-3.5 text-sm font-semibold text-slate-700 transition duration-300 hover:border-violet-300 hover:shadow-md hover:text-violet-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-violet-500 dark:hover:text-violet-400" do %>
      <div class="mr-3 flex h-8 w-8 items-center justify-center rounded-lg bg-slate-50 text-slate-500 group-hover:bg-violet-50 group-hover:text-violet-600 dark:bg-slate-700 dark:text-slate-400 dark:group-hover:bg-violet-900/30 dark:group-hover:text-violet-400 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10" />
          <path d="m14 10-2 2-2-2" />
        </svg>
      </div>
      <span><%= t("sign.app.authentication.new.links.passkey") %></span>
      <div class="ml-auto text-slate-300 group-hover:translate-x-1 group-hover:text-violet-500 transition-all dark:text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </div>
    <% end %>

    <%= link_to new_sign_app_in_secret_path,
                class: "group relative flex items-center w-full rounded-xl border border-slate-200 bg-white px-5 py-3.5 text-sm font-semibold text-slate-700 transition duration-300 hover:border-pink-300 hover:shadow-md hover:text-pink-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-pink-500 dark:hover:text-pink-400" do %>
      <div class="mr-3 flex h-8 w-8 items-center justify-center rounded-lg bg-slate-50 text-slate-500 group-hover:bg-pink-50 group-hover:text-pink-600 dark:bg-slate-700 dark:text-slate-400 dark:group-hover:bg-pink-900/30 dark:group-hover:text-pink-400 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" />
        </svg>
      </div>
      <span><%= t("sign.app.authentication.new.links.secret") %></span>
      <div class="ml-auto text-slate-300 group-hover:translate-x-1 group-hover:text-pink-500 transition-all dark:text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </div>
    <% end %>

    <div class="relative my-8">
      <div class="absolute inset-0 flex items-center">
        <span class="w-full border-t border-slate-200 dark:border-slate-700"></span>
      </div>
      <div class="relative flex justify-center text-xs uppercase">
        <span class="bg-white/80 px-2 text-slate-500 dark:bg-slate-900/80 dark:text-slate-400">Or continue with</span>
      </div>
    </div>

    <%= button_to "/auth/google_oauth2",
                  method: :post,
                  data: { turbo: false },
                  class: "group relative flex items-center w-full rounded-xl border border-slate-200 bg-white px-5 py-3.5 text-sm font-semibold text-slate-700 transition duration-300 hover:border-slate-300 hover:shadow-md hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700/50" do %>
      <div class="mr-3 flex h-8 w-8 items-center justify-center">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.84z" fill="#FBBC05" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
        </svg>
      </div>
      <span><%= t("sign.app.authentication.new.links.google") %></span>
    <% end %>

    <%= button_to "/auth/apple",
                  method: :post,
                  data: { turbo: false },
                  class: "group relative flex items-center w-full rounded-xl border border-slate-200 bg-white px-5 py-3.5 text-sm font-semibold text-slate-700 transition duration-300 hover:border-slate-300 hover:shadow-md hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700/50" do %>
      <div class="mr-3 flex h-8 w-8 items-center justify-center text-black dark:text-white">
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.74 1.18 0 2.45-1.02 3.65-.95 1.87.11 3.48 1.18 4.28 2.37-3.81 2.02-3.23 7.8 1.05 9.08-.2.95-.58 2.02-.97 2.6H17.05zM14.68 3.55c.78-.96 1.34-2.17 1.25-3.55-1.25.07-2.73.91-3.56 1.94-.78.91-1.47 2.21-1.31 3.48 1.45.1 2.86-.88 3.62-1.87z" />
        </svg>
      </div>
      <span><%= t("sign.app.authentication.new.links.apple") %></span>
    <% end %>

    <div class="pt-6 text-center">
      <%= link_to new_sign_app_up_path,
                  class: "text-sm font-medium text-indigo-600 hover:text-indigo-500 transition-colors dark:text-indigo-400 dark:hover:text-indigo-300" do %>
        <%= t("sign.app.authentication.new.links.registration") %> &rarr;
      <% end %>
    </div>
  </div>
</div>
