<% content_for :page_title, t("sign.app.verification.index.title") %>
<% title t("sign.app.verification.index.title") %>

<div>
  <div>
    <h1><%= t("sign.app.verification.index.title") %></h1>
  </div>

  <div>
    <h2><%= t("sign.app.verification.new.title") %></h2>
    <p><%= t("sign.app.verification.new.description") %></p>

    <% if flash[:alert] %>
      <div>
        <%= flash[:alert] %>
      </div>
    <% end %>

    <% if @available_methods.blank? %>
      <p>email/passkey/totp を登録してください</p>
    <% else %>
      <div>
        <% if @available_methods.include?(:passkey) %>
          <div>
            <%= link_to t("sign.app.verification.new.methods.passkey"),
                        new_sign_app_verification_passkey_path(
                          ri: params[:ri],
                          scope: @verification_scope,
                          return_to: @verification_return_to
                        ) %>
          </div>
        <% end %>

        <% if @available_methods.include?(:totp) %>
          <div>
            <%= link_to t("sign.app.verification.new.methods.totp"),
                        new_sign_app_verification_totp_path(
                          ri: params[:ri],
                          scope: @verification_scope,
                          return_to: @verification_return_to
                        ) %>
          </div>
        <% end %>

        <% if @available_methods.include?(:email_otp) %>
          <div>
            <%= form_with url: sign_app_verification_emails_path(ri: params[:ri]), method: :post, data: { turbo: false } do |f| %>
              <%= f.hidden_field :scope, value: @verification_scope.presence || params[:scope], name: "verification[scope]" %>
              <%= f.hidden_field :return_to, value: @verification_return_to.presence || params[:return_to], name: "verification[return_to]" %>
              <%= f.submit t("sign.app.verification.new.methods.email_otp") %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div>
    <table>
      <thead>
      <tr>
        <th><%= t("sign.app.verification.index.table.scope") %></th>
        <th><%= t("sign.app.verification.index.table.method") %></th>
        <th><%= t("sign.app.verification.index.table.status") %></th>
        <th><%= t("sign.app.verification.index.table.expires") %></th>
      </tr>
      </thead>
      <tbody>
      <% @reauth_sessions.each do |s| %>
        <tr>
          <td><%= s.scope %></td>
          <td><%= s.method %></td>
          <td><%= s.status %></td>
          <td><%= l(s.expires_at, format: :short) %></td>
        </tr>
      <% end %>
      <% if @reauth_sessions.empty? %>
        <tr>
          <td colspan="4"><%= t("sign.app.verification.index.empty") %></td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
