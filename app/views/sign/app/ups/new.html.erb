<% title t("sign.app.registration.new.page_title") %>
<% product_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME", "Umaxica") } %>

<div class="animate-fade-in-up">
  <div>
    <h1>
      <%= t("sign.app.registration.new.page_title") %>
    </h1>
    <p>
      <%= t("sign.app.registration.new.page_description", product: product_name) %>
    </p>
  </div>

  <div>
    <%= link_to new_sign_app_up_email_path do %>
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </div>
      <span><%= t("sign.app.registration.new.methods.email.cta") %></span>
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </div>
    <% end %>

    <%= link_to new_sign_app_up_telephone_path do %>
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="20" x="5" y="2" rx="2" ry="2" />
          <path d="M12 18h.01" />
        </svg>
      </div>
      <span><%= t("sign.app.registration.new.methods.telephone.cta") %></span>
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6" />
        </svg>
      </div>
    <% end %>

    <div>
      <div>
        <span></span>
      </div>
      <div>
        <span>Or continue with</span>
      </div>
    </div>

    <%= button_to "/auth/google_oauth2",
                  method: :post,
                  data: { turbo: false } do %>
      <div>
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.84z" fill="#FBBC05" />
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
        </svg>
      </div>
      <span><%= t("sign.app.authentication.new.links.google") %></span>
    <% end %>

    <%= button_to "/auth/apple",
                  method: :post,
                  data: { turbo: false } do %>
      <div>
        <svg fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.74 1.18 0 2.45-1.02 3.65-.95 1.87.11 3.48 1.18 4.28 2.37-3.81 2.02-3.23 7.8 1.05 9.08-.2.95-.58 2.02-.97 2.6H17.05zM14.68 3.55c.78-.96 1.34-2.17 1.25-3.55-1.25.07-2.73.91-3.56 1.94-.78.91-1.47 2.21-1.31 3.48 1.45.1 2.86-.88 3.62-1.87z" />
        </svg>
      </div>
      <span><%= t("sign.app.authentication.new.links.apple") %></span>
    <% end %>

    <div>
      <span>
        <%= t("sign.app.registration.new.links.already_have_account") %>
      </span>
      <%= link_to new_sign_app_in_path do %>
        <%= t("sign.app.registration.new.links.sign_in") %> &rarr;
      <% end %>
    </div>
  </div>
</div>
