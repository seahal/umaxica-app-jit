<% title t("sign.app.registration.new.page_title") %>
<% product_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME", "Umaxica") } %>

<h1><%= t("sign.app.registration.new.page_title") %></h1>
<p><%= t("sign.app.registration.new.page_description", product: product_name) %></p>

<ul><li><%= link_to t("sign.app.registration.new.methods.email.cta"), new_sign_app_up_email_path %></li>
<li><%= link_to t("sign.app.registration.new.methods.telephone.cta"), new_sign_app_up_telephone_path %></li>

</ul>

<%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false } do %>
  <%= t("sign.app.authentication.new.links.google") %>
<% end %>

<%= button_to "/auth/apple", method: :post, data: { turbo: false } do %>
  <%= t("sign.app.authentication.new.links.apple") %>
<% end %>

<p><%= t("sign.app.registration.new.links.already_have_account") %></p>
<%= link_to t("sign.app.registration.new.links.sign_in"), new_sign_app_in_path %>
