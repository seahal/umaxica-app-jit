<% title t("sign.app.registration.new.page_title") %>
<% product_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME", "Umaxica") } %>

<div class="mx-auto max-w-xl">
  <h1 class="text-3xl font-semibold text-slate-900"><%= t("sign.app.registration.new.page_title") %></h1>
  <p class="mt-2 text-sm text-slate-600"><%= t("sign.app.registration.new.page_description", product: product_name) %></p>

  <div class="mt-6 space-y-3 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= link_to t("sign.app.registration.new.methods.email.cta"),
                new_sign_app_up_email_path,
                class: "block w-full text-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    <%= link_to t("sign.app.registration.new.methods.telephone.cta"),
                new_sign_app_up_passkey_path,
                class: "block w-full text-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    <%= button_to t("sign.app.authentication.new.links.google"),
                  "/auth/google_oauth2",
                  method: :post,
                  data: { turbo: false },
                  class: "w-full text-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    <%= button_to t("sign.app.authentication.new.links.apple"),
                  "/auth/apple",
                  method: :post,
                  data: { turbo: false },
                  class: "w-full text-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    <%= link_to t("sign.app.registration.new.links.sign_in_text"),
                new_sign_app_in_path,
                class: "block w-full text-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
  </div>

</div>
