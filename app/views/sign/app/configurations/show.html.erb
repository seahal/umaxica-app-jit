<%= render "shared/page_header",
           title: t("sign.app.configuration.show.page_title"),
           description: t("sign.app.configuration.show.description") %>

<div class="space-y-8">
  <!-- Security Section -->
  <section>
    <h2 class="text-xs font-bold text-muted-fg uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.security_settings") %></h2>
    <div class="grid gap-3">
      <%= render "shared/ui/card", class: "p-0" do %>
        <div class="divide-y divide-border">
          <%= link_to sign_app_configuration_totps_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-muted rounded-lg p-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" /><circle cx="12" cy="12" r="3" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.totp") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.totp_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>

          <%= link_to sign_app_configuration_passkeys_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-muted rounded-lg p-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25z" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.passkey") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.passkey_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>

          <%= link_to sign_app_configuration_secrets_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-muted rounded-lg p-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.secret") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.secret_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Account Section -->
  <section>
    <h2 class="text-xs font-bold text-muted-fg uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.account_settings") %></h2>
    <div class="grid gap-3">
      <%= render "shared/ui/card", class: "p-0" do %>
        <div class="divide-y divide-border">
          <%= link_to sign_app_configuration_emails_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-muted rounded-lg p-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.email") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.email_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>

          <%= link_to sign_app_configuration_telephones_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-muted rounded-lg p-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.telephone") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.telephone_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>

          <%= link_to sign_app_configuration_sessions_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-muted rounded-lg p-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75l3 3m0 0l3-3m-3 3v-7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.session") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.session_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <!-- External Services Section -->
  <section>
    <h2 class="text-xs font-bold text-muted-fg uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.external_services") %></h2>
    <div class="grid gap-3">
      <%= render "shared/ui/card", class: "p-0" do %>
        <div class="divide-y divide-border">
          <%= link_to sign_app_configuration_google_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-white p-1 rounded border border-border">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" /><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" /><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05" /><path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.google") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.google_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>

          <%= link_to sign_app_configuration_apple_path, class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
            <div class="flex-shrink-0 bg-black dark:bg-white text-white dark:text-black p-1 rounded border border-border">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.96.95-2.21 1.5-3.53 1.5-1.28 0-2.32-.45-3.14-.45-.84 0-2.01.44-3.14.44-1.33 0-2.62-.64-3.64-1.63-2.12-2.04-2.12-6.57 0-8.61a5.08 5.08 0 014.28-1.55c1.02 0 1.83.33 2.51.33.64 0 1.63-.38 2.81-.38.96 0 2.21.32 3.03 1.01-3.1 1.68-2.6 6.37.52 7.34zM12.03 7.25c-.13-1.99 1.51-3.8 3.33-3.95.23 1.99-1.57 3.86-3.33 3.95z" /></svg>
            </div>
            <div class="ml-4 flex-1 text-left">
              <p class="text-sm font-semibold text-fg"><%= t("controller.sign.app.setting.index.apple") %></p>
              <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.apple_desc") %></p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Others Section -->
  <section>
    <h2 class="text-xs font-bold text-muted-fg uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.others") %></h2>
    <div class="grid gap-3">
       <%= render "shared/ui/card", class: "p-0" do %>
         <div class="divide-y divide-border">
           <%= link_to edit_sign_app_out_path(ri: "jp"), class: "flex items-center p-4 hover:bg-muted/50 transition-colors" do %>
             <div class="flex-shrink-0 bg-muted rounded-lg p-2 text-primary">
               <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
             </div>
             <div class="ml-4 flex-1 text-left">
               <p class="text-sm font-semibold text-fg"><%= t("sign.app.configuration.show.logout") %></p>
               <p class="text-xs text-muted-fg"><%= t("sign.app.configuration.show.logout_desc") %></p>
             </div>
             <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-fg"><path d="m9 18 6-6-6-6" /></svg>
           <% end %>

           <%= link_to sign_app_configuration_withdrawal_path, class: "flex items-center p-4 hover:bg-danger/5 transition-colors" do %>
              <div class="flex-shrink-0 bg-danger/10 rounded-lg p-2 text-danger">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" /><line x1="10" x2="10" y1="11" y2="17" /><line x1="14" x2="14" y1="11" y2="17" /></svg>
              </div>
              <div class="ml-4 flex-1 text-left">
                <p class="text-sm font-semibold text-danger"><%= t("sign.app.configuration.show.withdrawal") %></p>
                <p class="text-xs text-danger/80"><%= t("sign.app.configuration.show.withdrawal_desc") %></p>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-danger/40"><path d="m9 18 6-6-6-6" /></svg>
           <% end %>
         </div>
       <% end %>
    </div>
  </section>

</div>
