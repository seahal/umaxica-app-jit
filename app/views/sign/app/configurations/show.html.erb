<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-zinc-900 dark:text-white tracking-tight font-outfit"><%= t("sign.app.configuration.show.page_title") %></h1>
    <p class="mt-2 text-lg text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.description") %></p>
  </div>

  <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
    <!-- Security Section -->
    <section>
      <h2 class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.security_settings") %></h2>
      <div class="space-y-3">
        <%= link_to sign_app_configuration_totps_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-300 transform hover:-translate-y-0.5" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-blue-50 dark:bg-blue-900/20 rounded-xl p-3 group-hover:bg-blue-100 dark:group-hover:bg-blue-900/40 transition-colors">
              <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"><%= t("controller.sign.app.setting.index.totp") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.totp_desc") %></p>
            </div>
          </div>
        <% end %>

        <%= link_to sign_app_configuration_passkeys_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-300 transform hover:-translate-y-0.5" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-blue-50 dark:bg-blue-900/20 rounded-xl p-3 group-hover:bg-blue-100 dark:group-hover:bg-blue-900/40 transition-colors">
              <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"><%= t("controller.sign.app.setting.index.passkey") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.passkey_desc") %></p>
            </div>
          </div>
        <% end %>

        <%= link_to sign_app_configuration_secrets_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-300 transform hover:-translate-y-0.5" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-blue-50 dark:bg-blue-900/20 rounded-xl p-3 group-hover:bg-blue-100 dark:group-hover:bg-blue-900/40 transition-colors">
              <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"><%= t("controller.sign.app.setting.index.secret") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.secret_desc") %></p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Account Section -->
    <section>
      <h2 class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.account_settings") %></h2>
      <div class="space-y-3">
        <%= link_to sign_app_configuration_emails_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-blue-500 dark:hover:border-blue-500 hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-300 transform hover:-translate-y-0.5" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl p-3 group-hover:bg-indigo-100 dark:group-hover:bg-indigo-900/40 transition-colors">
              <svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors"><%= t("controller.sign.app.setting.index.email") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.email_desc") %></p>
            </div>
          </div>
        <% end %>

        <%= link_to sign_app_configuration_telephones_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-indigo-500 dark:hover:border-indigo-500 hover:shadow-lg hover:shadow-indigo-500/10 transition-all duration-300 transform hover:-translate-y-0.5" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl p-3 group-hover:bg-indigo-100 dark:group-hover:bg-indigo-900/40 transition-colors">
              <svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.47-5.112-3.758-6.582-6.582l1.293-.97c.362-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H3.75A2.25 2.25 0 001.5 4.5v2.25z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors"><%= t("controller.sign.app.setting.index.telephone") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.telephone_desc") %></p>
            </div>
          </div>
        <% end %>

        <%= link_to sign_app_configuration_sessions_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-indigo-500 dark:hover:border-indigo-500 hover:shadow-lg hover:shadow-indigo-500/10 transition-all duration-300 transform hover:-translate-y-0.5" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl p-3 group-hover:bg-indigo-100 dark:group-hover:bg-indigo-900/40 transition-colors">
              <svg class="h-6 w-6 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75l3 3m0 0l3-3m-3 3v-7.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors"><%= t("controller.sign.app.setting.index.session") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.session_desc") %></p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Connected Accounts Section -->
    <section>
      <h2 class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.external_services") %></h2>
      <div class="space-y-3">
        <%= link_to sign_app_configuration_google_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-zinc-500 dark:hover:border-zinc-400 transition-all duration-200" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-white p-2 rounded-xl ring-1 ring-zinc-200 dark:ring-zinc-700">
              <svg class="h-6 w-6" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05" />
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:underline"><%= t("controller.sign.app.setting.index.google") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.google_desc") %></p>
            </div>
          </div>
        <% end %>

        <%= link_to sign_app_configuration_apple_path, class: "group block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-zinc-500 dark:hover:border-zinc-400 transition-all duration-200" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-black dark:bg-white/10 p-2 rounded-xl text-white">
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.05 20.28c-.96.95-2.21 1.5-3.53 1.5-1.28 0-2.32-.45-3.14-.45-.84 0-2.01.44-3.14.44-1.33 0-2.62-.64-3.64-1.63-2.12-2.04-2.12-6.57 0-8.61a5.08 5.08 0 014.28-1.55c1.02 0 1.83.33 2.51.33.64 0 1.63-.38 2.81-.38.96 0 2.21.32 3.03 1.01-3.1 1.68-2.6 6.37.52 7.34zM12.03 7.25c-.13-1.99 1.51-3.8 3.33-3.95.23 1.99-1.57 3.86-3.33 3.95z" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-zinc-900 dark:text-white group-hover:underline"><%= t("controller.sign.app.setting.index.apple") %></p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.show.apple_desc") %></p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <!-- Danger Zone Section -->
    <section>
      <h2 class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.others") %></h2>
      <div class="space-y-3">
        <%= link_to sign_app_configuration_withdrawal_path, class: "group block bg-red-50 dark:bg-red-900/10 rounded-2xl border border-red-100 dark:border-red-900/30 p-4 hover:border-red-500 dark:hover:border-red-500 hover:shadow-lg hover:shadow-red-500/10 transition-all duration-300 transform hover:-translate-y-0.5" do %>
          <div class="flex items-center">
            <div class="flex-shrink-0 bg-red-100 dark:bg-red-900/30 rounded-xl p-3 group-hover:bg-red-200 dark:group-hover:bg-red-900/50 transition-colors">
              <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M22 10.5h-6m-2.25-1.5a4.5 4.5 0 00-4.5-4.5H5.25a4.5 4.5 0 00-4.5 4.5V15a4.5 4.5 0 004.5 4.5h3.75a4.5 4.5 0 004.5-4.5v-1.5M13.5 12H21m0 0l-1.5-1.5M21 12l-1.5 1.5" />
              </svg>
            </div>
            <div class="ml-4">
              <p class="text-sm font-bold text-red-700 dark:text-red-400 group-hover:text-red-800 dark:group-hover:text-red-300 transition-colors"><%= t("sign.app.configuration.show.withdrawal") %></p>
              <p class="text-xs text-red-500 dark:text-red-400/70"><%= t("sign.app.configuration.show.withdrawal_desc") %></p>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  </div>
  <div class="mt-8 text-center sm:text-left">
    <%= link_to sign_app_root_path, class: "inline-flex items-center gap-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>

  <div class="mt-8 border-t border-zinc-200 dark:border-zinc-800 pt-8">
    <h2 class="text-xs font-bold text-zinc-500 dark:text-zinc-400 uppercase tracking-widest mb-4 px-1"><%= t("sign.app.configuration.show.session_header") %></h2>
    <%= link_to edit_sign_app_out_path(ri: "jp"), class: "group block w-full bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-4 hover:border-indigo-500 dark:hover:border-indigo-500 hover:shadow-lg hover:shadow-indigo-500/10 transition-all duration-300" do %>
      <div class="flex items-center justify-center">
        <svg class="h-6 w-6 text-zinc-400 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" />
        </svg>
        <span class="ml-2 text-sm font-bold text-zinc-600 dark:text-zinc-300 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors"><%= t("sign.app.configuration.show.logout") %></span>
      </div>
    <% end %>
  </div>
</div>
