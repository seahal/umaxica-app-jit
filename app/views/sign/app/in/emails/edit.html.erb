<% content_for :page_title, t("sign.app.authentication.email.edit.page_title") %>
<div>
  <div>
    <div>
      <div>
        <h1>
          <%= t("sign.app.authentication.email.edit.page_title") %>
        </h1>
        <p>
          <%= t("sign.app.authentication.email.edit.description") %>
        </p>
      </div>

      <%= form_with model: @user_email,
                    url: sign_app_in_email_path,
                    method: :patch,
                    data: {
                      turbo: false,
                      controller: "otp-resend",
                      otp_resend_endpoint_value: sign_app_web_v1_in_email_otp_path,
                      otp_resend_state_value: @otp_resend_state,
                      otp_resend_button_label_value: t("otp.resend.button"),
                      otp_resend_sent_message_value: t("otp.resend.sent"),
                      otp_resend_too_soon_message_value: t("otp.resend.too_soon"),
                      otp_resend_failed_message_value: t("otp.resend.failed"),
                    } do |form| %>
        <%= hidden_field_tag :rd, params[:rd] if params[:rd].present? %>

        <% if @user_email.errors.any? %>
          <div class="animate-shake">
            <ul>
              <% @user_email.errors.each do |error| %>
                <li>
                  <span><%= error.full_message %></span>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div>
          <%= form.label :pass_code %>
          <div>
            <%= form.text_field :pass_code,
                                placeholder: "● ● ● ● ● ●",
                                maxlength: 6,
                                autocomplete: "one-time-code",
                                inputmode: "numeric",
                                pattern: "[0-9]*",
                                data: { otp_resend_target: "input" },
                                required: true %>
            <div></div>
          </div>
        </div>

        <div>
          <button type="button" data-action="otp-resend#resend" data-otp-resend-target="button">
            <%= t("otp.resend.button") %>
          </button>
          <p data-otp-resend-target="status"></p>
        </div>

        <div>
          <%= form.submit t("sign.app.authentication.passkey.new.submit") %>
        </div>
      <% end %>

      <div>
        <%= link_to new_sign_app_in_email_path(rd: params[:rd]) do %>
          <span><%= t("sign.app.authentication.email.edit.return_page") %></span>
        <% end %>
      </div>
    </div>
  </div>

  <style>
      @keyframes shake {
          0%, 100% {
              transform: translateX(0);
          }
          25% {
              transform: translateX(-4px);
          }
          75% {
              transform: translateX(4px);
          }
      }

      .animate-shake {
          animation: shake 0.4s cubic-bezier(.36, .07, .19, .97) both;
      }

      /* Center code in input with tracking by using indent of same amount */
      .indent-\[0\.75em\] {
          text-indent: 0.75em;
      }
  </style>

  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
