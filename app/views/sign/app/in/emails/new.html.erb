<div class="mx-auto max-w-xl">
  <% title t("sign.app.authentication.email.new.page_title") %>
  <h1 class="text-3xl font-semibold text-slate-900"><%= t("sign.app.authentication.email.new.page_title") %></h1>

  <%= form_with model: @user_email,
                url: sign_app_in_email_path,
                data: { turbo: false },
                class: "mt-6 space-y-5 rounded-xl border border-slate-200 bg-white p-6 shadow-sm" do |form| %>
    <%= hidden_field_tag :rd, params[:rd] if params[:rd].present? %>

    <% if @user_email.errors.any? %>
      <div id="error_explanation" class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <h2 class="font-semibold"><%= pluralize(@user_email.errors.count, "error") %> prohibited this sample from being saved:</h2>
        <ul class="mt-2 list-disc pl-5">
          <% @user_email.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="space-y-2">
      <%= form.label :address, class: "text-sm font-medium text-slate-700" %>
      <%= form.email_field :address,
                           class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
    </div>

    <%= render "concern/cloudflare_turnstile" %>

    <div class="flex items-center gap-3">
      <%= form.submit t("actions.submit", default: "Continue"),
                      class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800" %>
      <%= link_to t("sign.app.authentication.new.back"), new_sign_app_in_path,
                  class: "inline-flex items-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
