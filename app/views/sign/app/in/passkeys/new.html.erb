<% title t("sign.app.authentication.passkey.new.page_title") %>

<div>
  <div>
    <h1><%= t("sign.app.authentication.passkey.new.page_title") %></h1>
    <p><%= t("sign.app.authentication.passkey.new.description") %></p>
  </div>

  <div
       data-controller="passkey-authentication"
       data-passkey-authentication-options-url-value="<%= options_sign_app_in_passkeys_path %>"
       data-passkey-authentication-verification-url-value="<%= verification_sign_app_in_passkeys_path %>"
       data-passkey-authentication-identifier-param-value="identifier">

    <div>
      <label for="identifier">
        <%= t("sign.app.authentication.passkey.new.pii_label") %>
      </label>
      <input type="text"
             id="identifier"
             data-passkey-authentication-target="identifier"
             placeholder="<%= t("sign.app.authentication.passkey.new.pii_placeholder") %>"
             autocomplete="username webauthn"
             required>
    </div>

    <p data-passkey-authentication-target="error" class="hidden"></p>
    <p data-passkey-authentication-target="status" class="hidden"></p>

    <div>
      <button type="button"
              data-action="click->passkey-authentication#authenticate">
        <%= t("sign.app.authentication.passkey.new.submit") %>
      </button>
      <%= link_to t("sign.app.authentication.new.back"), new_sign_app_in_path %>
    </div>
  </div>
</div>
