<% title t("sign.app.authentication.passkey.new.page_title") %>

<div class="mx-auto max-w-md">
  <div class="text-center mb-8">
    <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-slate-100">
      <svg class="h-7 w-7 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.2-2.858.571-4.175m5.3 1.25a2 2 0 011.66 0" />
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t("sign.app.authentication.passkey.new.page_title") %></h1>
    <p class="mt-2 text-sm text-slate-600"><%= t("sign.app.authentication.passkey.new.description") %></p>
  </div>

  <div class="space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex flex-col gap-3 pt-2">
      <button type="button" class="w-full rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:bg-slate-800 hover:shadow-md active:scale-[0.98]">
        <%= t("sign.app.authentication.passkey.new.submit", default: "パスキーでログイン") %>
      </button>
      <%= link_to t("sign.app.authentication.new.back"), new_sign_app_in_path,
                  class: "flex items-center justify-center w-full rounded-xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50" %>
    </div>
  </div>
</div>
