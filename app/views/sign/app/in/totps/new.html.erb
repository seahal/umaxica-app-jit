<% title t("sign.app.authentication.totp.new.page_title") %>

<div>
  <div>
    <h1><%= t("sign.app.authentication.totp.new.page_title") %></h1>
    <p><%= t("sign.app.authentication.totp.new.description") %></p>
  </div>

  <%= form_with model: @totp_form,
                url: sign_app_in_totp_path,
                data: { turbo: false } do |f| %>

    <% if @totp_form.errors.any? %>
      <div>
        <h2><%= t("errors.messages.validation_failed") %></h2>
        <ul>
          <% @totp_form.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= hidden_field_tag :rd, params[:rd] if params[:rd].present? %>

    <div>
      <%= f.label :token, t("sign.app.authentication.totp.new.token_label") %>
      <%= f.text_field :token,
                       placeholder: "000000",
                       maxlength: 6,
                       inputmode: "numeric",
                       autocomplete: "one-time-code" %>
    </div>

    <div>
      <%= f.submit t("actions.submit") %>
      <%= link_to new_sign_app_in_secret_path(rd: params[:rd]) do %>
        <%= t("sign.app.authentication.totp.new.use_secret") %>
        <% if @secret_hints.present? %>
          <span>(<%= @secret_hints.join(", ") %>)</span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
