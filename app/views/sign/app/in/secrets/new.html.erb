<% title t("sign.app.authentication.secret.new.page_title") %>

<div>
  <div>
    <div>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
      </svg>
    </div>
    <h1><%= t("sign.app.authentication.secret.new.page_title") %></h1>
    <p><%= t("sign.app.authentication.secret.new.description") %></p>
  </div>

  <%= form_with model: @secret_form,
                url: sign_app_in_secret_path,
                data: { turbo: false } do |f| %>

    <% if @secret_form.errors.any? %>
      <div>
        <h2><%= t("errors.messages.validation_failed") %></h2>
        <ul>
          <% @secret_form.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= hidden_field_tag :rd, params[:rd] if params[:rd].present? %>

    <% if @secret_hints.present? %>
      <div>
        <p><%= t("sign.app.authentication.secret.new.hints") %></p>
        <p><%= @secret_hints.join(", ") %></p>
      </div>
    <% end %>

    <% if @secret_form.respond_to?(:account_identifiable_information) %>
      <div>
        <%= f.label :account_identifiable_information,
                    t("sign.app.authentication.secret.new.pii_label") %>
        <%= f.text_field :account_identifiable_information,
                         placeholder: t("sign.app.authentication.secret.new.pii_placeholder"),
                         autocomplete: "username" %>
      </div>
    <% end %>

    <div>
      <%= f.label :secret_value,
                  t("sign.app.authentication.secret.new.secret_label") %>
      <%= f.password_field :secret_value,
                           placeholder: "••••••••••••••••",
                           autocomplete: "current-password" %>
    </div>

    <%= render "shared/cloudflare_turnstile" %>

    <div>
      <%= f.check_box :confirm_saved,
                      {  },
                      "1", "0" %>
      <div>
        <%= f.label :confirm_saved,
                    t("sign.app.authentication.secret.new.confirm_label") %>
        <p><%= t("sign.app.authentication.secret.new.confirm_hint") %></p>
      </div>
    </div>

    <div>
      <%= f.submit t("actions.submit") %>
      <% if @secret_hints.present? %>
        <%= link_to new_sign_app_in_totp_path(rd: params[:rd]) do %>
          <%= t("sign.app.authentication.secret.new.use_totp") %>
        <% end %>
      <% end %>
      <%= link_to new_sign_app_in_path do %>
        <%= t("sign.app.authentication.new.back") %>
      <% end %>
    </div>
  <% end %>
</div>
