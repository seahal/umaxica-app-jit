<% title t("sign.app.authentication.secret.new.page_title") %>

<div class="mx-auto max-w-md">
  <div class="text-center mb-8">
    <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-slate-100">
      <svg class="h-7 w-7 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-slate-900"><%= t("sign.app.authentication.secret.new.page_title") %></h1>
    <p class="mt-2 text-sm text-slate-600"><%= t("sign.app.authentication.secret.new.description") %></p>
  </div>

  <%= form_with model: @secret_form,
                url: sign_app_in_secret_path,
                data: { turbo: false },
                class: "space-y-5 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm" do |f| %>

    <% if @secret_form.errors.any? %>
      <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
        <h2 class="font-semibold"><%= t("errors.messages.validation_failed") %></h2>
        <ul class="mt-1 list-disc pl-5 text-red-600">
          <% @secret_form.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= hidden_field_tag :rd, params[:rd] if params[:rd].present? %>

    <% if @secret_hints.present? %>
      <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500"><%= t("sign.app.authentication.secret.new.hints") %></p>
        <p class="mt-1 font-mono text-slate-900"><%= @secret_hints.join(", ") %></p>
      </div>
    <% end %>

    <% if @secret_form.respond_to?(:account_identifiable_information) %>
      <div class="space-y-2">
        <%= f.label :account_identifiable_information,
                    t("sign.app.authentication.secret.new.pii_label"),
                    class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :account_identifiable_information,
                         placeholder: t("sign.app.authentication.secret.new.pii_placeholder"),
                         autocomplete: "username",
                         class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>
    <% end %>

    <div class="space-y-2">
      <%= f.label :secret_value,
                  t("sign.app.authentication.secret.new.secret_label"),
                  class: "block text-sm font-medium text-slate-700" %>
      <%= f.password_field :secret_value,
                           placeholder: "••••••••••••••••",
                           autocomplete: "current-password",
                           class: "w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-900 transition-colors placeholder:text-slate-400 focus:border-slate-400 focus:bg-white focus:outline-none focus:ring-2 focus:ring-slate-200" %>
    </div>

    <%= render "shared/cloudflare_turnstile" %>

    <div class="flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
      <%= f.check_box :confirm_saved,
                      { class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-400 focus:ring-offset-0" },
                      "1", "0" %>
      <div>
        <%= f.label :confirm_saved,
                    t("sign.app.authentication.secret.new.confirm_label"),
                    class: "block text-sm font-medium text-slate-700 cursor-pointer" %>
        <p class="mt-0.5 text-xs text-slate-500"><%= t("sign.app.authentication.secret.new.confirm_hint") %></p>
      </div>
    </div>

    <div class="flex flex-col gap-3 pt-2">
      <%= f.submit t("actions.submit"),
                   class: "w-full rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition-all duration-200 hover:bg-slate-800 hover:shadow-md active:scale-[0.98]" %>
      <% if @secret_hints.present? %>
        <%= link_to new_sign_app_in_totp_path(rd: params[:rd]),
                    class: "flex items-center justify-center w-full rounded-xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50" do %>
          <%= t("sign.app.authentication.secret.new.use_totp") %>
        <% end %>
      <% end %>
      <%= link_to new_sign_app_in_path,
                  class: "flex items-center justify-center w-full rounded-xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition-all duration-200 hover:border-slate-300 hover:bg-slate-50" do %>
        <%= t("sign.app.authentication.new.back") %>
      <% end %>
    </div>
  <% end %>
</div>
