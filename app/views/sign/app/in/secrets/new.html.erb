<div class="mx-auto max-w-xl">
  <h1 class="text-3xl font-semibold text-slate-900"><%= title t("sign.app.authentication.secret.new.page_title", default: "Secret sign in") %></h1>

  <%= form_with url: sign_app_in_secret_path, data: { turbo: false }, class: "mt-6 space-y-5 rounded-xl border border-slate-200 bg-white p-6 shadow-sm" do |f| %>
    <div class="space-y-2">
      <%= f.label :account_identifiable_information,
                  t("sign.app.authentication.secret.new.pii_label", default: "Account identifiable information"),
                  class: "text-sm font-medium text-slate-700" %>
      <%= f.text_field :account_identifiable_information,
                       class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
    </div>

    <div class="space-y-2">
      <%= f.label :secret_value,
                  t("sign.app.authentication.secret.new.secret_label", default: "Secret"),
                  class: "text-sm font-medium text-slate-700" %>
      <%= f.password_field :secret_value,
                           class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-900 shadow-sm focus:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
    </div>
    <%= render "concern/cloudflare_turnstile" %>
    <div class="flex items-start gap-3 rounded-lg border border-slate-200 bg-slate-50 px-3 py-3">
      <%= f.check_box :confirm_saved, { class: "mt-1 h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-400" }, "1", "0" %>
      <%= f.label :confirm_saved,
                  t("sign.app.authentication.secret.new.confirm_label", default: "I have saved the secret"),
                  class: "text-sm font-medium text-slate-700" %>
    </div>

    <div class="flex items-center gap-3">
      <%= f.submit t("actions.submit", default: "Continue"),
                   class: "inline-flex items-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800" %>
      <%= link_to t("sign.app.authentication.new.back"), new_sign_app_in_path,
                  class: "inline-flex items-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
