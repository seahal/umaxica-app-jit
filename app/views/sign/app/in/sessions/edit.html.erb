<% content_for :page_title, t("session_limit.edit.title", default: "セッション管理") %>

<section class="mx-auto max-w-2xl">
  <div class="relative overflow-hidden rounded-3xl border border-white/20 bg-white/80 p-8 shadow-2xl backdrop-blur-xl ring-1 ring-black/5 sm:p-10">
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-amber-50/50 via-white/50 to-orange-50/50 opacity-100"></div>

    <div class="mb-8">
      <div class="mb-4 flex items-center gap-3">
        <div class="rounded-xl bg-amber-100 p-3">
          <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight text-slate-900">
          <%= t("session_limit.edit.title", default: "セッション上限に達しました") %>
        </h1>
      </div>
      <p class="text-base text-slate-600 leading-relaxed">
        <%= t("session_limit.edit.description", default: "同時にログインできるセッション数の上限に達しています。ログインを続行するには、無効化するセッションを選択してください。") %>
      </p>
    </div>

    <% if flash[:alert].present? %>
      <div class="mb-6 rounded-xl bg-red-50 p-4 ring-1 ring-red-200">
        <div class="flex items-center gap-3">
          <svg class="h-5 w-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
          <p class="text-sm font-medium text-red-700"><%= flash[:alert] %></p>
        </div>
      </div>
    <% end %>

    <%= form_with url: sign_app_in_email_session_path, method: :patch, class: "space-y-6" do |f| %>
      <div class="rounded-2xl bg-white/50 p-6 ring-1 ring-slate-900/5">
        <h2 class="mb-4 text-xs font-bold uppercase tracking-wider text-slate-400">
          <%= t("session_limit.edit.active_sessions", default: "アクティブなセッション") %>
        </h2>

        <% if @active_sessions.present? %>
          <div class="space-y-3">
            <% @active_sessions.each do |session| %>
              <label class="flex cursor-pointer items-center gap-4 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200 transition-all hover:ring-slate-300 has-[:checked]:ring-2 has-[:checked]:ring-amber-500">
                <input type="checkbox"
                       name="revoke_session_ids[]"
                       value="<%= session.id %>"
                       class="h-5 w-5 rounded border-slate-300 text-amber-600 focus:ring-amber-500">
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />
                    </svg>
                    <span class="text-sm font-medium text-slate-900">
                      <%= t("session_limit.edit.session_label", default: "セッション") %> #<%= session.public_id.first(8) %>...
                    </span>
                  </div>
                  <div class="mt-1 flex items-center gap-4 text-xs text-slate-500">
                    <span>
                      <%= t("session_limit.edit.created_at", default: "作成日時") %>:
                      <%= l(session.created_at, format: :short) rescue session.created_at.strftime("%Y/%m/%d %H:%M") %>
                    </span>
                    <% if session.last_used_at %>
                      <span>
                        <%= t("session_limit.edit.last_used", default: "最終使用") %>:
                        <%= l(session.last_used_at, format: :short) rescue session.last_used_at.strftime("%Y/%m/%d %H:%M") %>
                      </span>
                    <% end %>
                  </div>
                </div>
              </label>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-slate-500">
            <%= t("session_limit.edit.no_sessions", default: "アクティブなセッションがありません。") %>
          </p>
        <% end %>
      </div>

      <div class="flex items-center justify-between gap-4 pt-4">
        <%= f.submit t("session_limit.edit.submit", default: "選択したセッションを無効化してログイン"),
                     class: "inline-flex items-center justify-center rounded-xl bg-amber-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-amber-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-600 transition-all active:scale-95" %>
        <%= link_to t("session_limit.edit.cancel", default: "キャンセル"),
                    new_sign_app_in_path,
                    class: "inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition-all active:scale-95" %>
      </div>
    <% end %>
  </div>
</section>
