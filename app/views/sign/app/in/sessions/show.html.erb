<% content_for :page_title, t("sign.app.in.session.title") %>
<div>
  <h1><%= t("sign.app.in.session.title") %></h1>

  <% if current_session_restricted? %>
    <div>
      <div>
        <div>
          <p>
            <%= t("sign.app.in.session.restricted_notice") %>
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <p><%= t("sign.app.in.session.description") %></p>

  <%= form_with url: sign_app_in_session_path, method: :patch do |form| %>
    <% if @active_sessions.present? %>
      <div>
        <div>
          <h2>
            <%= t("sign.app.in.session.active_sessions") %>
            <span>
              (<%= @active_sessions.count %>/<%= UserToken::MAX_SESSIONS_PER_USER %>)
            </span>
          </h2>
        </div>
        <ul>
          <% @active_sessions.each do |session| %>
            <li>
              <div>
                <p>
                  <%= t("sign.app.in.session.session_label") %>
                  <% if session.public_id == @current_session_public_id %>
                    <span>
                      <%= t("sign.app.in.session.current") %>
                    </span>
                  <% end %>
                </p>
                <p>
                  <%= t("sign.app.in.session.created_at") %>: <%= l(session.created_at, format: :short) %>
                </p>
                <% if session.last_used_at %>
                  <p>
                    <%= t("sign.app.in.session.last_used_at") %>: <%= l(session.last_used_at, format: :short) %>
                  </p>
                <% end %>
              </div>
              <div>
                <% if session.public_id != @current_session_public_id %>
                  <label>
                    <%= check_box_tag "revoke_refs[]", session.signed_ref, false %>
                    <span><%= t("sign.app.in.session.revoke") %></span>
                  </label>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @restricted_sessions.present? %>
      <div>
        <div>
          <h2>
            <%= t("sign.app.in.session.restricted_sessions") %>
          </h2>
        </div>
        <ul>
          <% @restricted_sessions.each do |session| %>
            <li>
              <div>
                <p>
                  <%= t("sign.app.in.session.pending_session") %>
                  <% if session.public_id == @current_session_public_id %>
                    <span>
                      <%= t("sign.app.in.session.current") %>
                    </span>
                  <% end %>
                </p>
                <p>
                  <%= t("sign.app.in.session.created_at") %>: <%= l(session.created_at, format: :short) %>
                </p>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <% if current_session_restricted? %>
        <%= link_to t("sign.app.in.session.cancel"),
                    sign_app_in_session_path,
                    method: :delete,
                    data: { turbo_method: :delete, turbo_confirm: t("sign.app.in.session.cancel_confirm") } %>
      <% end %>

      <%= form.submit t("sign.app.in.session.revoke_selected") %>
    </div>
  <% end %>
</div>
