<% title t("sign.app.configuration.passkeys.new.page_title") %>

<div>
  <div>
    <h1><%= t("sign.app.configuration.passkeys.new.page_title") %></h1>
    <p><%= t("sign.app.configuration.passkeys.new.description") %></p>
  </div>

  <div
       data-controller="passkey-registration"
       data-passkey-registration-options-url-value="<%= options_sign_app_configuration_passkeys_path %>"
       data-passkey-registration-verification-url-value="<%= verification_sign_app_configuration_passkeys_path %>">

    <div>
      <label for="description">
        <%= t("sign.app.configuration.passkeys.new.description_label") %>
      </label>
      <input type="text"
             id="description"
             data-passkey-registration-target="description"
             placeholder="<%= t("sign.app.configuration.passkeys.new.description_placeholder") %>"
             maxlength="100">
    </div>

    <p data-passkey-registration-target="error" class="hidden"></p>
    <p data-passkey-registration-target="status" class="hidden"></p>

    <div>
      <button type="button"
              data-action="click->passkey-registration#register">
        <%= t("sign.app.configuration.passkeys.new.submit") %>
      </button>
      <%= link_to t("sign.common.cancel"), sign_app_configuration_passkeys_path %>
    </div>
  </div>
</div>
