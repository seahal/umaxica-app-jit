<%= render "shared/page_header",
           title: t('sign.app.configuration.passkey.index.title'),
           description: t('sign.app.configuration.passkey.index.description'),
           up_to: sign_app_configuration_path %>

<div class="sm:flex sm:items-center justify-end mb-4">
  <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
    <%= link_to t('controller.sign.app.v1.passkey.new'), new_sign_app_configuration_passkey_path, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto" %>
  </div>
</div>

  <div class="mt-8 flex flex-col">
    <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
        <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
          <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6"><%= t('activerecord.attributes.user_passkey.description') %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900"><%= t('activerecord.attributes.user_passkey.created_at') %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900"><%= t('activerecord.attributes.user_passkey.last_used_at') %></th>
              <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                <span class="sr-only">アクション</span>
              </th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
            <% @passkeys.each do |passkey| %>
              <tr>
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 sm:pl-6"><%= passkey.description %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= l(passkey.created_at, format: :short) %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500"><%= passkey.respond_to?(:last_used_at) && passkey.last_used_at ? l(passkey.last_used_at, format: :short) : '-' %></td>
                <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                  <%= link_to t('actions.edit'), edit_sign_app_configuration_passkey_path(passkey), class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
                  <%= link_to t('actions.destroy'), sign_app_configuration_passkey_path(passkey), data: { turbo_method: :delete, turbo_confirm: t('messages.confirm_destroy') }, class: "text-red-600 hover:text-red-900" %>
                </td>
              </tr>
            <% end %>
            <% if @passkeys.empty? %>
              <tr>
                <td colspan="4" class="px-6 py-10 text-center text-sm text-gray-500 italic">
                  パスキーは登録されていません。
                </td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
