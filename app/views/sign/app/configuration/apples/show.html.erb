<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
  <div class="md:grid md:grid-cols-3 md:gap-6">
    <div class="md:col-span-1">
      <div class="px-4 sm:px-0">
        <h3 class="text-lg font-medium leading-6 text-gray-900"><%= t('controller.sign.app.setting.index.apple') %></h3>
        <p class="mt-1 text-sm text-gray-600">
          Apple IDを使用してこのアカウントにログインできます。
        </p>
      </div>
    </div>

    <div class="mt-5 md:col-span-2 md:mt-0">
      <div class="shadow sm:overflow-hidden sm:rounded-md">
        <div class="space-y-6 bg-white px-4 py-5 sm:p-6">
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <svg class="h-10 w-10 text-black" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.05 20.28c-.96.95-2.21 1.5-3.53 1.5-1.28 0-2.32-.45-3.14-.45-.84 0-2.01.44-3.14.44-1.33 0-2.62-.64-3.64-1.63-2.12-2.04-2.12-6.57 0-8.61a5.08 5.08 0 014.28-1.55c1.02 0 1.83.33 2.51.33.64 0 1.63-.38 2.81-.38.96 0 2.21.32 3.03 1.01-3.1 1.68-2.6 6.37.52 7.34zM12.03 7.25c-.13-1.99 1.51-3.8 3.33-3.95.23 1.99-1.57 3.86-3.33 3.95z"/>
                </svg>
              </div>
              <div class="ml-4">
                <h4 class="text-sm font-bold text-gray-900">Apple</h4>
                <% if current_user.user_social_apple %>
                  <p class="text-xs text-green-600 font-medium">連携済み</p>
                <% else %>
                  <p class="text-xs text-gray-500 font-medium">未連携</p>
                <% end %>
              </div>
            </div>
            <div>
              <% if current_user.user_social_apple %>
                <%= button_to t('actions.disconnect'), sign_app_social_unlink_path(provider: "apple"), method: :delete, class: "inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-medium text-red-600 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
              <% else %>
                <%= link_to t('actions.connect'), sign_app_social_start_path(provider: "apple", intent: "link"), data: { turbo: false }, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-3 py-1.5 text-xs font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
              <% end %>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 px-4 py-3 text-right sm:px-6">
          <%= link_to t('sign.app.configuration.show.back'), sign_app_configuration_path, class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
        </div>
      </div>
    </div>
  </div>
</div>
