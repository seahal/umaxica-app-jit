<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to sign_app_configuration_path, class: "inline-flex items-center gap-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>

  <div class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-zinc-900 dark:text-white tracking-tight font-outfit"><%= t('sign.app.configuration.apple.show.title') %></h1>
    <p class="mt-2 text-base sm:text-lg text-zinc-500 dark:text-zinc-400"><%= t('sign.app.configuration.apple.show.description') %></p>
  </div>

  <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden shadow-sm">
    <div class="p-6 sm:p-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="flex-shrink-0 bg-black dark:bg-white/10 p-3 rounded-xl ring-1 ring-zinc-200 dark:ring-zinc-700">
            <svg class="h-10 w-10 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.05 20.28c-.96.95-2.21 1.5-3.53 1.5-1.28 0-2.32-.45-3.14-.45-.84 0-2.01.44-3.14.44-1.33 0-2.62-.64-3.64-1.63-2.12-2.04-2.12-6.57 0-8.61a5.08 5.08 0 014.28-1.55c1.02 0 1.83.33 2.51.33.64 0 1.63-.38 2.81-.38.96 0 2.21.32 3.03 1.01-3.1 1.68-2.6 6.37.52 7.34zM12.03 7.25c-.13-1.99 1.51-3.8 3.33-3.95.23 1.99-1.57 3.86-3.33 3.95z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-lg font-bold text-zinc-900 dark:text-white">Apple</h4>
            <% if current_user.user_social_apple %>
              <div class="flex items-center gap-2 mt-1">
                <span class="flex h-2 w-2 rounded-full bg-green-500"></span>
                <p class="text-sm text-zinc-600 dark:text-zinc-400 font-medium"><%= t('sign.app.configuration.apple.show.linked') %></p>
              </div>
            <% else %>
              <div class="flex items-center gap-2 mt-1">
                <span class="flex h-2 w-2 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
                <p class="text-sm text-zinc-500 dark:text-zinc-500 font-medium"><%= t('sign.app.configuration.apple.show.unlinked') %></p>
              </div>
            <% end %>
          </div>
        </div>

        <div class="w-full sm:w-auto">
          <% if current_user.user_social_apple %>
            <%= button_to t('actions.disconnect'), sign_app_social_unlink_path(provider: "apple"), method: :delete, class: "w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-900/20 px-4 py-2 text-sm font-semibold text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900" %>
          <% else %>
            <%= button_to sign_app_social_start_path(provider: "apple", intent: "link"), method: :post, data: { turbo: false }, class: "w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/20 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900" do %>
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
              <%= t('actions.connect') %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
