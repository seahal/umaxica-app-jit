<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to sign_app_configuration_secrets_path, class: "inline-flex items-center gap-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>
  <div class="md:grid md:grid-cols-3 md:gap-6">
    <div class="md:col-span-1">
      <div class="px-4 sm:px-0">
        <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-gray-100"><%= t('.title') %></h3>
        <p class="mt-1 text-sm text-gray-600 dark:text-gray-400"><%= t('.description') %></p>
      </div>
    </div>
    <div class="mt-5 md:col-span-2 md:mt-0">
      <%= form_with(model: @secret, url: sign_app_configuration_secrets_path, class: "shadow sm:overflow-hidden sm:rounded-md") do |form| %>
        <div class="space-y-6 bg-white dark:bg-gray-800 px-4 py-5 sm:p-6">
          <% if @secret.errors.any? %>
            <div class="rounded-md bg-red-50 dark:bg-red-900/50 p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <!-- Heroicon name: mini/x-circle -->
                  <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-red-800 dark:text-red-200"><%= t('errors.template.header', model: @secret.model_name.human, count: @secret.errors.count) %></h3>
                  <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                    <ul role="list" class="list-disc pl-5 space-y-1">
                      <% @secret.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div class="flex items-start gap-3">
            <%= check_box_tag :acknowledged, "1", false, class: "mt-1 h-4 w-4 rounded border-gray-300 dark:border-gray-600 dark:bg-gray-700 text-indigo-600 focus:ring-indigo-500 dark:focus:ring-offset-gray-800" %>
            <%= label_tag :acknowledged, t('.acknowledgement_label'), class: "text-sm font-medium text-gray-700 dark:text-gray-300" %>
          </div>

          <div class="rounded-md border border-amber-200 bg-amber-50 dark:border-amber-700 dark:bg-amber-900/30 px-4 py-3">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700 dark:text-amber-400">Secret</p>
            <p class="mt-1 text-sm text-amber-900 dark:text-amber-100 font-mono"><%= @raw_secret %></p>
            <p class="mt-1 text-xs text-amber-700 dark:text-amber-400"><%= t('.secret_display_notice') %></p>
          </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700/50 px-4 py-3 text-right sm:px-6">

          <%= form.submit t('actions.save'), class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
