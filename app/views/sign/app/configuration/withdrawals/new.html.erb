<h1><%= t("sign.app.configuration.withdrawal.new.title", default: "Withdrawal") %></h1>
<p><%= t("sign.app.configuration.withdrawal.new.description", default: "Are you sure you want to withdraw?") %></p>

<%= form_with url: sign_app_configuration_withdrawal_path, method: :post, local: true do |f| %>
  <div>
    <%= f.check_box :confirm_create_recovery_code %>
    <%= f.label :confirm_create_recovery_code, t("sign.app.configuration.withdrawal.new.recovery_code_label", default: "Confirm create recovery code") %>
  </div>
  <%= render "concern/cloudflare_turnstile" %>
  <%= f.submit t("sign.app.configuration.withdrawal.new.submit", default: "Withdraw"), class: "btn btn-danger" %>
<% end %>
