<% content_for :page_title, t("sign.app.configuration.withdrawal.recovery.page_title", default: "Withdrawal recovery") %>

<h1><%= t("sign.app.configuration.withdrawal.recovery.page_title", default: "Withdrawal recovery") %></h1>

<p>
  <%= t(
        "sign.app.configuration.withdrawal.recovery.deadline",
        default: "Recovery deadline: %{date}",
        date: l(@recovery_deadline, format: :long),
      ) %>
</p>

<% if @recoverable %>
  <p><%= t("sign.app.configuration.withdrawal.recovery.available", default: "Your account can still be recovered.") %></p>

  <%= button_to t("sign.app.configuration.withdrawal.recovery.submit", default: "Recover account"),
                sign_app_configuration_withdrawal_path(ri: params[:ri]),
                method: :post,
                data: { turbo_confirm: t("sign.app.configuration.withdrawal.recovery.confirm", default: "Recover this account?") } %>
<% else %>
  <p><%= t("sign.app.configuration.withdrawal.recovery.unavailable", default: "Recovery period has expired.") %></p>
<% end %>

<p>
  <%= link_to t("actions.back"), sign_app_configuration_path(ri: params[:ri]) %>
</p>
