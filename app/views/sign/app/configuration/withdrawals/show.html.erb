<%= render "shared/page_header",
           title: t("sign.app.configuration.withdrawal.show.title"),
           description: "アカウントの利用停止または完全な削除を行えます。",
           up_to: sign_app_configuration_path %>

<div class="space-y-6 text-left">
  <div class="flex items-center gap-2">
    <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-semibold text-primary">
      <%= t("sign.app.configuration.withdrawal.show.active") %>
    </span>
  </div>

  <%= render "shared/ui/card", title: t("sign.app.configuration.withdrawal.show.temporary_withdrawal") do %>
    <div class="space-y-4">
      <p class="text-sm text-muted-fg leading-relaxed">
        <%= t("sign.app.configuration.withdrawal.show.temporary_notice") %>
      </p>

      <%= render "shared/ui/alert" do %>
        <p>利用停止中は、サービスのすべての機能が制限されます。</p>
      <% end %>

      <%= button_to sign_app_configuration_withdrawal_path,
                    method: :patch,
                    form: { class: "w-full" },
                    class: "w-full inline-flex items-center justify-center rounded-lg bg-muted px-4 py-2 text-sm font-semibold text-fg hover:bg-muted/80 transition-colors min-h-[44px]",
                    data: { confirm: t("sign.app.configuration.withdrawal.show.confirm_withdrawal") } do %>
        <%= t("sign.app.configuration.withdrawal.show.withdraw_button") %>
      <% end %>
    </div>
  <% end %>

  <%= render "shared/ui/card", title: t("sign.app.configuration.withdrawal.show.permanent_deletion") do %>
    <div class="space-y-4">
      <p class="text-sm text-muted-fg leading-relaxed">
        <%= t("sign.app.configuration.withdrawal.show.permanent_notice") %>
      </p>

      <%= render "shared/ui/alert", variant: :danger do %>
        <p>警告: この操作は二度と元に戻せません。</p>
      <% end %>

      <%= button_to sign_app_configuration_withdrawal_path,
                    method: :delete,
                    form: { class: "w-full" },
                    class: "w-full inline-flex items-center justify-center rounded-lg bg-danger px-4 py-2 text-sm font-semibold text-danger-fg hover:opacity-90 transition-colors min-h-[44px]",
                    data: { confirm: t("sign.app.configuration.withdrawal.show.confirm_deletion") } do %>
        <%= t("sign.app.configuration.withdrawal.show.delete_button") %>
      <% end %>
    </div>
  <% end %>
</div>
