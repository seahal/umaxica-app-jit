<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to sign_app_configuration_path, class: "inline-flex items-center gap-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>

  <div class="mb-8">
    <div class="flex items-center gap-4 mb-2">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-zinc-900 dark:text-white tracking-tight font-outfit"><%= t("sign.app.configuration.withdrawal.show.title") %></h1>
      <span class="inline-flex items-center rounded-full bg-green-100 dark:bg-green-900/30 px-3 py-1 text-sm font-medium text-green-800 dark:text-green-400">
        <%= t("sign.app.configuration.withdrawal.show.active") %>
      </span>
    </div>
    <p class="text-base sm:text-lg text-zinc-500 dark:text-zinc-400"><%= t("sign.app.configuration.withdrawal.show.description") %></p>
  </div>

  <div class="space-y-6 sm:space-y-8">
    <!-- Temporary Withdrawal -->
    <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden shadow-sm">
      <div class="p-6 sm:p-8">
        <div class="md:grid md:grid-cols-3 md:gap-8">
          <div class="md:col-span-1 mb-6 md:mb-0">
            <h3 class="text-lg font-bold leading-6 text-zinc-900 dark:text-white"><%= t("sign.app.configuration.withdrawal.show.temporary_withdrawal") %></h3>
            <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
              <%= t("sign.app.configuration.withdrawal.show.temporary_notice") %>
            </p>
          </div>
          <div class="md:col-span-2">
            <div class="rounded-xl bg-amber-50 dark:bg-amber-900/20 p-4 mb-6 border border-amber-100 dark:border-amber-900/30">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-amber-500 dark:text-amber-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625l6.28-10.875zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="ml-3">
                  <p class="text-sm font-bold text-amber-800 dark:text-amber-200"><%= t("sign.app.configuration.withdrawal.show.temporary_warning") %></p>
                </div>
              </div>
            </div>
            <%= button_to t("sign.app.configuration.withdrawal.show.withdraw_button"),
                          sign_app_configuration_withdrawal_path,
                          method: :patch,
                          class: "w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-amber-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-amber-700 transition-colors focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900",
                          data: { confirm: t("sign.app.configuration.withdrawal.show.confirm_withdrawal") } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
