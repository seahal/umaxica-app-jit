<div>
  <div>
    <div>
      <div>
        <h3>
          <%= t('sign.app.configuration.email.new.page_title') %>
        </h3>
        <p>
          <%= t('sign.app.configuration.email.new.description') %>
        </p>
      </div>
    </div>

    <div>
      <%= form_with(model: @user_email, url: sign_app_configuration_emails_path) do |form| %>
        <div>
          <% if @user_email.errors.any? %>
            <div>
              <div>
                <div>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div>
                  <h3>
                    <%= t('errors.template.header', model: @user_email.model_name.human, count: @user_email.errors.count) %>
                  </h3>
                  <div>
                    <ul role="list">
                      <% @user_email.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div>
            <div>
              <%= form.label :address, t('activerecord.attributes.user_email.address') %>
              <div>
                <%= form.email_field :address, placeholder: "you@example.com" %>
              </div>
              <p>
                <%= t('sign.app.configuration.email.new.help_text') %>
              </p>
            </div>
          </div>
        </div>
        <div>
          <%= link_to t('actions.cancel'), sign_app_configuration_emails_path %>
          <%= form.submit t('actions.submit') %>
        </div>
      <% end %>
    </div>
  </div>
</div>
