<%= render "shared/page_header",
           title: t('sign.app.configuration.email.index.title'),
           description: t('sign.app.configuration.email.index.description'),
           up_to: sign_app_configuration_path %>

<div class="sm:flex sm:items-center justify-end mb-4">
  <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
    <%= link_to t('sign.app.configuration.email.index.new_link'), new_sign_app_configuration_email_path, class: "inline-flex items-center justify-center rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 px-5 py-2.5 text-sm font-bold text-white shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 hover:-translate-y-0.5 transition-all duration-300" %>
  </div>
</div>

  <div class="mt-8 flex flex-col">
    <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
        <div class="overflow-hidden shadow-xl ring-1 ring-black/5 dark:ring-white/10 rounded-2xl bg-white dark:bg-zinc-900">
          <table class="min-w-full divide-y divide-zinc-200 dark:divide-zinc-800">
            <thead class="bg-zinc-50 dark:bg-zinc-800/50">
            <tr>
              <th scope="col" class="py-4 pl-6 pr-3 text-left text-xs font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
                <%= t('activerecord.attributes.user_email.address') %>
              </th>
              <th scope="col" class="px-3 py-4 text-left text-xs font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
                <%= t('activerecord.attributes.user_email.status') %>
              </th>
              <th scope="col" class="relative py-3.5 pl-3 pr-6">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
            </thead>
            <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800 bg-white dark:bg-zinc-900">
            <% @user_emails.each do |email| %>
              <tr class="group hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors duration-200">
                <td class="whitespace-nowrap py-4 pl-6 pr-3 text-sm font-medium text-zinc-900 dark:text-white">
                  <%= email.address %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm">
                  <% if email.user_email_status_id == UserEmailStatus::VERIFIED %>
                      <span class="inline-flex items-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-2.5 py-0.5 text-xs font-medium text-emerald-800 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-800">
                        認証済み
                      </span>
                  <% else %>
                      <span class="inline-flex items-center rounded-full bg-amber-100 dark:bg-amber-900/30 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:text-amber-400 border border-amber-200 dark:border-amber-800">
                        未認証
                      </span>
                  <% end %>
                </td>
                <td class="relative whitespace-nowrap py-4 pl-3 pr-6 text-right text-sm font-medium">
                  <%# delete or edit actions here %>
                </td>
              </tr>
            <% end %>
            <% if @user_emails.empty? %>
              <tr>
                <td colspan="3" class="px-6 py-16 text-center text-sm text-zinc-500 dark:text-zinc-400">
                  <div class="flex flex-col items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-zinc-300 dark:text-zinc-600 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <p>メールアドレスは登録されていません。</p>
                  </div>
                </td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
