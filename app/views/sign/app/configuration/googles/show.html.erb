<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-10">
  <!-- Back Link -->
  <div class="mb-6">
    <%= link_to sign_app_configuration_path, class: "inline-flex items-center gap-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>

  <div class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-zinc-900 dark:text-white tracking-tight font-outfit"><%= t('sign.app.configuration.google.show.title') %></h1>
    <p class="mt-2 text-base sm:text-lg text-zinc-500 dark:text-zinc-400"><%= t('sign.app.configuration.google.show.description') %></p>
  </div>

  <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden shadow-sm">
    <div class="p-6 sm:p-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4">
          <div class="flex-shrink-0 bg-white p-3 rounded-xl ring-1 ring-zinc-200 dark:ring-zinc-700">
            <svg class="h-10 w-10" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </div>
          <div>
            <h4 class="text-lg font-bold text-zinc-900 dark:text-white">Google</h4>
            <% if current_user.user_social_google %>
              <div class="flex items-center gap-2 mt-1">
                <span class="flex h-2 w-2 rounded-full bg-green-500"></span>
                <p class="text-sm text-zinc-600 dark:text-zinc-400 font-medium"><%= t('sign.app.configuration.google.show.linked') %></p>
              </div>
            <% else %>
              <div class="flex items-center gap-2 mt-1">
                <span class="flex h-2 w-2 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
                <p class="text-sm text-zinc-500 dark:text-zinc-500 font-medium"><%= t('sign.app.configuration.google.show.unlinked') %></p>
              </div>
            <% end %>
          </div>
        </div>

        <div class="w-full sm:w-auto">
          <% if current_user.user_social_google %>
            <%= button_to t('actions.disconnect'), sign_app_social_unlink_path(provider: "google_oauth2"), method: :delete, class: "w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-red-50 dark:bg-red-900/20 px-4 py-2 text-sm font-semibold text-red-600 dark:text-red-400 border border-red-200 dark:border-red-800 hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900" %>
          <% else %>
            <%= button_to sign_app_social_start_path(provider: "google_oauth2", intent: "link"), method: :post, data: { turbo: false }, class: "w-full sm:w-auto inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors shadow-lg shadow-blue-500/20 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-900" do %>
              <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
              <%= t('actions.connect') %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
