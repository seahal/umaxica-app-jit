<% content_for :page_title, 'Sessions' %>
<%= link_to t('sign.app.configuration.show.back'), sign_app_configuration_path %>

<% if @sessions.any? %>
  <div>
    <table>
      <thead>
      <tr>
        <th>Session</th>
        <th>Kind</th>
        <th>Last activity</th>
        <th>Created</th>
        <th>Refresh expires</th>
        <th></th>
      </tr>
      </thead>
      <tbody>
      <% @sessions.each do |session| %>
        <% current_session = session.public_id == current_session_public_id %>
        <tr class="<%= "bg-slate-50 font-semibold" if current_session %>">
          <td>
            <div>
              <span><%= session.public_id %></span>
              <% if current_session %>
                    <span>
                      current
                    </span>
              <% end %>
            </div>
            <p><%= session.user_token_status_id %></p>
          </td>
          <td><%= session.user_token_kind_id %></td>
          <td>
            <%= l(session.last_used_at || session.created_at, format: :short) %>
          </td>
          <td><%= l(session.created_at, format: :short) %></td>
          <td><%= l(session.refresh_expires_at, format: :short) %></td>
          <td>
            <% unless current_session %>
              <%= button_to "Revoke", sign_app_configuration_session_path(session.public_id),
                            method: :delete,
                            data: { confirm: "Revoke this session?" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p>No active sessions were found.</p>
<% end %>
