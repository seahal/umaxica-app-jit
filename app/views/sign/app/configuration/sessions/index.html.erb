<div class="space-y-6">
  <div>
    <%= link_to sign_app_configuration_path, class: "inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-indigo-600 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>
  <header>
    <h1 class="text-2xl font-semibold"><%= t("sign.app.configuration.sessions.index.title") %></h1>
    <p class="text-sm text-slate-600"><%= t("sign.app.configuration.sessions.index.description") %></p>

  </header>

  <% if @sessions.any? %>
    <div class="overflow-x-auto rounded border border-slate-200">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("sign.app.configuration.sessions.index.table.session") %></th>
          <th class="px-4 py-3"><%= t("sign.app.configuration.sessions.index.table.kind") %></th>
          <th class="px-4 py-3"><%= t("sign.app.configuration.sessions.index.table.last_activity") %></th>
          <th class="px-4 py-3"><%= t("sign.app.configuration.sessions.index.table.created") %></th>
          <th class="px-4 py-3"><%= t("sign.app.configuration.sessions.index.table.refresh_expires") %></th>
          <th class="px-4 py-3"></th>
        </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
        <% @sessions.each do |session| %>
          <% current_session = session.public_id == current_session_public_id %>
          <tr class="<%= "bg-slate-50 font-semibold" if current_session %>">
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <span><%= session.public_id %></span>
                <% if current_session %>
                    <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-800">
                      <%= t("sign.app.configuration.sessions.index.current") %>
                    </span>
                <% end %>
              </div>
              <p class="text-xs text-slate-500"><%= session.user_token_status_id %></p>
            </td>
            <td class="px-4 py-3"><%= session.user_token_kind_id %></td>
            <td class="px-4 py-3">
              <%= l(session.last_used_at || session.created_at, format: :short) %>
            </td>
            <td class="px-4 py-3"><%= l(session.created_at, format: :short) %></td>
            <td class="px-4 py-3"><%= l(session.refresh_expires_at, format: :short) %></td>
            <td class="px-4 py-3">
              <% unless current_session %>
                <% confirm_message = t("sign.app.configuration.sessions.index.revoke_confirm") %>
                <%= button_to t("sign.app.configuration.sessions.index.revoke"), sign_app_configuration_session_path(session.public_id),
                              method: :delete,
                              data: {
                                confirm: confirm_message,
                                turbo_confirm: confirm_message
                              },
                              class: "text-xs font-semibold text-rose-700 underline underline-offset-2" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-slate-600"><%= t("sign.app.configuration.sessions.index.empty") %></p>
  <% end %>

  <p class="text-sm text-slate-600">
    <%= link_to t("sign.app.configuration.sessions.index.sign_out_current", default: "現在のセッションを切る場合はこちら"),
                edit_sign_app_out_path(ri: params[:ri]),
                class: "font-semibold text-indigo-600 hover:text-indigo-700 underline underline-offset-2" %>
  </p>
</div>
