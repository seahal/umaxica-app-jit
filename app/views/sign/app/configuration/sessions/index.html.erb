<div class="space-y-6">
  <header>
    <h1 class="text-2xl font-semibold">Active sessions</h1>
    <p class="text-sm text-slate-600">
      Sessions displayed here can be revoked immediately. The session marked with “current” is the browser you are using.
    </p>
  </header>

  <% if @sessions.any? %>
    <div class="overflow-x-auto rounded border border-slate-200">
      <table class="min-w-full divide-y divide-slate-200 text-sm">
        <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-4 py-3">Session</th>
            <th class="px-4 py-3">Kind</th>
            <th class="px-4 py-3">Last activity</th>
            <th class="px-4 py-3">Created</th>
            <th class="px-4 py-3">Refresh expires</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% @sessions.each do |session| %>
            <% current_session = session.public_id == current_session_public_id %>
            <tr class="<%= "bg-slate-50 font-semibold" if current_session %>">
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <span><%= session.public_id %></span>
                  <% if current_session %>
                    <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-800">
                      current
                    </span>
                  <% end %>
                </div>
                <p class="text-xs text-slate-500"><%= session.user_token_status_id %></p>
              </td>
              <td class="px-4 py-3"><%= session.user_token_kind_id %></td>
              <td class="px-4 py-3">
                <%= l(session.last_used_at || session.created_at, format: :short) %>
              </td>
              <td class="px-4 py-3"><%= l(session.created_at, format: :short) %></td>
              <td class="px-4 py-3"><%= l(session.refresh_expires_at, format: :short) %></td>
              <td class="px-4 py-3">
                <% unless current_session %>
                  <%= button_to "Revoke", sign_app_configuration_session_path(session.public_id),
                    method: :delete,
                    data: { confirm: "Revoke this session?" },
                    class: "text-xs font-semibold text-rose-700 underline underline-offset-2" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-slate-600">No active sessions were found.</p>
  <% end %>
</div>
