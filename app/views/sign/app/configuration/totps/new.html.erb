<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to sign_app_configuration_totps_path, class: "inline-flex items-center gap-2 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>
  <div class="md:grid md:grid-cols-3 md:gap-6">
    <div class="md:col-span-1">
      <div class="px-4 sm:px-0">
        <h3 class="text-xl font-bold leading-6 text-zinc-900 dark:text-white font-outfit tracking-tight">
          <%= t('sign.app.configuration.totp.new.page_title') %>
        </h3>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
          <%= t('sign.app.configuration.totp.new.description') %>
        </p>
      </div>
    </div>

    <div class="mt-5 md:col-span-2 md:mt-0">
      <%= form_with model: @totp, url: sign_app_configuration_totps_path, class: "shadow-xl rounded-2xl overflow-hidden" do |form| %>
        <div class="space-y-6 bg-white dark:bg-zinc-900 px-4 py-5 sm:p-6 border border-zinc-200 dark:border-zinc-800">
          <% if @totp.errors.any? %>
            <div class="rounded-xl bg-red-50 dark:bg-red-900/20 p-4 border border-red-100 dark:border-red-900/30">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-500 dark:text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-bold text-red-800 dark:text-red-200">
                    <%= t('errors.template.header', model: @totp.model_name.human, count: @totp.errors.count) %>
                  </h3>
                  <div class="mt-2 text-sm text-red-700 dark:text-red-300">
                    <ul role="list" class="list-disc pl-5 space-y-1">
                      <% @totp.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div class="flex flex-col items-center justify-center p-6 bg-zinc-50 dark:bg-zinc-800/50 rounded-xl border-2 border-dashed border-zinc-300 dark:border-zinc-700">
            <!-- QR Code container explicitly white for readability -->
            <div class="bg-white p-4 rounded-xl shadow-sm">
              <%= image_tag "data:image/png;base64, #{Base64.strict_encode64(@png.to_s)}", alt: "QR Code", class: "w-48 h-48" %>
            </div>
            <p class="mt-4 text-xs text-zinc-500 dark:text-zinc-400 text-center">
              QRコードがスキャンできない場合は、認証アプリに手動でシークレットを入力してください。
            </p>
          </div>

          <div class="grid grid-cols-1 gap-6">
            <div>
              <%= form.label :title, t('activerecord.attributes.user_one_time_password.title'), class: "block text-xs font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1" %>
              <div class="mt-1">
                <%= form.text_field :title, class: "block w-full rounded-xl border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-zinc-900 dark:text-white placeholder-zinc-400 focus:border-blue-500 focus:bg-white dark:focus:bg-zinc-800 focus:ring-4 focus:ring-blue-500/10 transition-all duration-300 sm:text-sm py-2.5", maxlength: 32, placeholder: t('messages.totp_title_placeholder') %>
              </div>
              <p class="mt-2 text-xs text-zinc-500 dark:text-zinc-400">
                <%= t('sign.app.configuration.totp.new.title_hint') %>
              </p>
            </div>

            <div>
              <%= form.label :first_token, "認証コード", class: "block text-xs font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-1" %>
              <div class="mt-1">
                <%= form.text_field :first_token, placeholder: "000000", class: "block w-full rounded-xl border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-zinc-900 dark:text-white placeholder-zinc-400 focus:border-blue-500 focus:bg-white dark:focus:bg-zinc-800 focus:ring-4 focus:ring-blue-500/10 transition-all duration-300 sm:text-sm tracking-[0.2em] text-center text-lg py-3 font-mono", maxlength: 6, inputmode: "numeric", pattern: "[0-9]*" %>
              </div>
              <p class="mt-2 text-xs text-zinc-500 dark:text-zinc-400">認証アプリに表示されている6桁のコードを入力してください。</p>
            </div>
          </div>
        </div>

        <div class="bg-zinc-50 dark:bg-zinc-800/80 px-4 py-4 text-right sm:px-6 border-t border-zinc-200 dark:border-zinc-800 flex items-center justify-end gap-3">

          <%= form.submit t('actions.save'), class: "inline-flex justify-center rounded-xl border border-transparent bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 py-2.5 px-5 text-sm font-bold text-white shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
