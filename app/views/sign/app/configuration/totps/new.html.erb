<div>
  <div>
    <div>
      <div>
        <h3>
          <%= t('sign.app.configuration.totp.new.page_title') %>
        </h3>
        <p>
          <%= t('sign.app.configuration.totp.new.description') %>
        </p>
      </div>
    </div>

    <div>
      <%= form_with model: @totp, url: sign_app_configuration_totps_path do |form| %>
        <div>
          <% if @totp.errors.any? %>
            <div>
              <div>
                <div>
                  <h3>
                    <%= t('errors.template.header', model: @totp.model_name.human, count: @totp.errors.count) %>
                  </h3>
                  <div>
                    <ul role="list">
                      <% @totp.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div>
            <!-- QR Code container explicitly white for readability -->
            <div>
              <%= image_tag "data:image/png;base64, #{Base64.strict_encode64(@png.to_s)}", alt: "QR Code" %>
            </div>
            <p>
              QRコードがスキャンできない場合は、認証アプリに手動でシークレットを入力してください。
            </p>
          </div>

          <div>
            <div>
              <%= form.label :title, t('activerecord.attributes.user_one_time_password.title') %>
              <div>
                <%= form.text_field :title, maxlength: 32, placeholder: t('messages.totp_title_placeholder') %>
              </div>
              <p>
                <%= t('sign.app.configuration.totp.new.title_hint') %>
              </p>
            </div>

            <div>
              <%= form.label :first_token, "認証コード" %>
              <div>
                <%= form.text_field :first_token, placeholder: "000000", maxlength: 6, inputmode: "numeric", pattern: "[0-9]*" %>
              </div>
              <p>認証アプリに表示されている6桁のコードを入力してください。</p>
            </div>
          </div>
        </div>

        <div>
          <%= link_to t('actions.cancel'), sign_app_configuration_totps_path %>
          <%= form.submit t('actions.save') %>
        </div>
      <% end %>
    </div>
  </div>
</div>
