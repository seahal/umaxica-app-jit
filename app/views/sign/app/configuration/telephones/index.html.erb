<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-6">
    <%= link_to sign_app_configuration_path, class: "inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-indigo-600 transition-colors duration-300" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
      </svg>
      <span><%= t("sign.app.configuration.show.back") %></span>
    <% end %>
  </div>
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-xl font-semibold text-gray-900 dark:text-white"><%= t('sign.app.configuration.telephone.index.title') %></h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-400"><%= t('sign.app.configuration.telephone.index.description') %></p>
    </div>
    <% if @user_telephones.count < UserTelephone::MAX_TELEPHONES_PER_USER %>
      <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <%= link_to t('sign.app.configuration.telephone.index.new_link'), new_sign_app_configuration_telephone_path, class: "inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto" %>
      </div>
    <% end %>
  </div>

  <div class="mt-8 flex flex-col">
    <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
      <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
        <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 dark:ring-white/10 md:rounded-lg">
          <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-800">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 dark:text-gray-100 sm:pl-6"><%= t('activerecord.attributes.user_telephone.number') %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-100"><%= t('activerecord.attributes.user_telephone.status') %></th>
              <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                <span class="sr-only"><%= t('actions.actions') %></span>
              </th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-900">
            <% @user_telephones.each do |telephone| %>
              <tr>
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 dark:text-gray-100 sm:pl-6"><%= telephone.number %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">
                  <% if telephone.user_telephone_status_id == Sign::App::TelephoneRegistrationFlow::TELEPHONE_STATUSES[:verified] %>
                      <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 dark:bg-green-900/30 dark:text-green-300">
                        <%= t('sign.app.configuration.telephone.index.verified') %>
                      </span>
                  <% else %>
                      <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">
                        <%= t('sign.app.configuration.telephone.index.unverified') %>
                      </span>
                  <% end %>
                </td>
                <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                  <%= button_to t('actions.delete'),
                                sign_app_configuration_telephone_path(telephone),
                                method: :delete,
                                form: { data: { turbo_confirm: t('sign.app.configuration.telephone.destroy.confirm') } },
                                class: "text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" %>
                </td>
              </tr>
            <% end %>
            <% if @user_telephones.empty? %>
              <tr>
                <td colspan="3" class="px-6 py-10 text-center text-sm text-gray-500 dark:text-gray-400 italic">
                  <%= t('sign.app.configuration.telephone.index.empty') %>
                </td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
