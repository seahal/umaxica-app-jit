<% title t("sign.app.verification.edit.title") %>

<div>
  <h1><%= t("sign.app.verification.edit.title") %></h1>
  <p><%= t("sign.app.verification.edit.description") %></p>

  <% if @verification_errors&.any? %>
    <div>
      <%= @verification_errors.to_sentence %>
    </div>
  <% end %>

  <%= form_with url: sign_app_verification_totp_path(ri: params[:ri]), method: :post, data: { turbo: false } do |f| %>
    <div>
      <%= f.label :code, t("sign.app.verification.edit.code_label") %>
      <%= f.text_field :code, inputmode: "numeric", autocomplete: "one-time-code", placeholder: t("sign.app.verification.edit.code_placeholder"), name: "verification[code]" %>
    </div>

    <div>
      <%= f.submit t("sign.app.verification.edit.submit") %>
    </div>
  <% end %>

  <div>
    <%= link_to t("sign.app.verification.edit.back"), sign_app_verification_path(ri: params[:ri]) %>
  </div>
</div>
