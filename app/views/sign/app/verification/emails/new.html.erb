<% title t("sign.app.verification.new.title") %>

<div>
  <h1><%= t("sign.app.verification.new.title") %></h1>
  <p><%= t("sign.app.verification.new.description") %></p>

  <% if @verification_errors&.any? %>
    <div>
      <%= @verification_errors.to_sentence %>
    </div>
  <% end %>

  <%= form_with url: sign_app_verification_emails_path(ri: params[:ri]), method: :post, data: { turbo: false } do |f| %>
    <div>
      <%= f.submit t("sign.app.verification.new.methods.email_otp") %>
    </div>
  <% end %>

  <div>
    <%= link_to t("sign.app.verification.edit.back"), sign_app_verification_path(ri: params[:ri]) %>
  </div>
</div>
