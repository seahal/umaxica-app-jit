<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>

<div>
  <div></div>

  <div>
    <header>
      <span>
        Docs
      </span>
      <h1>
        <%= code_name %> Staff Docs
      </h1>
      <p>
        社内スタッフ向けの運用・トレーニング資料をまとめています。現場向けの手順やFAQを中心に整理しています。
      </p>
      <div>
        <%= link_to "Help Center", help_org_root_url %>
      </div>
    </header>

    <section>
      <div>
        <h2>クイックステータス</h2>
        <dl>
          <div>
            <dt>Current language</dt>
            <dd><%= I18n.locale %></dd>
          </div>
          <div>
            <dt>TimeZone</dt>
            <dd><%= params[:tz].to_s.downcase == "utc" ? "utc" : "jst" %></dd>
          </div>
          <div>
            <dt>Hello</dt>
            <dd><%= I18n.t "hello" %></dd>
          </div>
          <div>
            <dt>Tokyo time</dt>
            <dd><%= Time.current.in_time_zone("Tokyo") %></dd>
          </div>
          <div>
            <dt>Local time</dt>
            <dd><%= to_localetime Time.current, "jst" %></dd>
          </div>
        </dl>
      </div>

      <div>
        <h2>ナビゲーション</h2>
        <p>
          日次業務のチェックリスト、研修資料、社内連絡の情報をこのハブから参照できます。
        </p>
        <div>
          <span>Playbook</span>
          <span>Training</span>
          <span>FAQ</span>
          <span>Incidents</span>
        </div>
      </div>
    </section>
  </div>
</div>
