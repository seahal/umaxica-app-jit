<% content_for :page_title, 'クイックステータス' %>
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>

<div>
  <div></div>

  <div>
    <header>
      <span>
        Docs
      </span>
      <h1>
        <%= code_name %> Corporate Docs
      </h1>
      <p>
        法人向けの運用・連携ガイドを整理したドキュメントです。社内手順やコンプライアンス情報もここから確認できます。
      </p>
      <div>
        <%= link_to "Help Center", help_com_root_url %>
      </div>
    </header>

    <section>
      <div>
        <h2>クイックステータス</h2>
        <dl>
          <div>
            <dt>Current language</dt>
            <dd><%= I18n.locale %></dd>
          </div>
          <div>
            <dt>TimeZone</dt>
            <dd><%= params[:tz].to_s.downcase == "utc" ? "utc" : "jst" %></dd>
          </div>
          <div>
            <dt>Hello</dt>
            <dd><%= I18n.t "hello" %></dd>
          </div>
          <div>
            <dt>Tokyo time</dt>
            <dd><%= Time.current.in_time_zone("Tokyo") %></dd>
          </div>
          <div>
            <dt>Local time</dt>
            <dd><%= to_localetime Time.current, "jst" %></dd>
          </div>
        </dl>
      </div>

      <div>
        <h2>ナビゲーション</h2>
        <p>
          部署横断で利用するドキュメントを整理しています。管理者向け情報はここから追加できます。
        </p>
        <div>
          <span>Policy</span>
          <span>Operations</span>
          <span>Integrations</span>
          <span>Security</span>
        </div>
      </div>
    </section>
  </div>
</div>
