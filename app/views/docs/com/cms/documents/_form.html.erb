<%= form_with(model: document, url: document.persisted? ? docs_com_cms_document_path(document) : docs_com_cms_documents_path, local: false) do |form| %>
  <% if document.errors.any? %>
    <div>
      <div>
        <div>
          <h3>
            <%= pluralize(document.errors.count, "error") %> prohibited this document from being saved:
          </h3>
          <div>
            <ul>
              <% document.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <div>
      <%= form.label :permalink %>
      <%= form.text_field :permalink,
                          placeholder: "example_document",
                          pattern: "[A-Za-z0-9_]{1,200}" %>
      <p>Only alphanumeric characters and underscores allowed (max 200 chars)</p>
    </div>

    <div>
      <%= form.label :response_mode %>
      <%= form.select :response_mode,
                      options_for_select([["HTML", "html"], ["Text", "text"], ["PDF", "pdf"], ["Redirect", "redirect"]], document.response_mode),
                      {} %>
    </div>

    <div id="redirect-url-field" style="<%= 'display: none;' unless document.response_mode == 'redirect' %>">
      <%= form.label :redirect_url %>
      <%= form.url_field :redirect_url,
                         placeholder: "https://example.com" %>
    </div>

    <div>
      <div>
        <%= form.label :published_at %>
        <%= form.datetime_local_field :published_at %>
      </div>

      <div>
        <%= form.label :expires_at %>
        <%= form.datetime_local_field :expires_at %>
      </div>
    </div>

    <div>
      <%= form.label :position %>
      <%= form.number_field :position,
                            value: document.position || 0 %>
      <p>Lower numbers appear first in listings</p>
    </div>

    <hr>

    <h4>Content</h4>

    <div>
      <%= form.label :title %>
      <% title_value = begin
                         document.persisted? ? document.latest_version.title : nil
                       rescue
                         nil
                       end %>
      <%= form.text_field :title,
                          value: title_value,
                          placeholder: "Document Title" %>
    </div>

    <div>
      <%= form.label :description %>
      <% description_value = begin
                               document.persisted? ? document.latest_version.description : nil
                             rescue
                               nil
                             end %>
      <%= form.text_area :description,
                         value: description_value,
                         rows: 3,
                         placeholder: "Brief description" %>
    </div>

    <div>
      <%= form.label :body %>
      <% body_value = begin
                        document.persisted? ? document.latest_version.body : nil
                      rescue
                        nil
                      end %>
      <%= form.text_area :body,
                         value: body_value,
                         rows: 15,
                         placeholder: "Document body content" %>
    </div>

    <div>
      <%= link_to "Cancel",
                  document.persisted? ? docs_com_cms_document_path(document) : docs_com_cms_documents_path %>
      <%= form.submit document.persisted? ? "Update Document" : "Create Document" %>
    </div>
  </div>
<% end %>

<script>
    document.addEventListener('turbo:load', function () {
        const responseModeSelect = document.querySelector('#com_document_response_mode');
        const redirectUrlField = document.querySelector('#redirect-url-field');

        if (responseModeSelect) {
            responseModeSelect.addEventListener('change', function () {
                if (this.value === 'redirect') {
                    redirectUrlField.style.display = 'block';
                } else {
                    redirectUrlField.style.display = 'none';
                }
            });
        }
    });
</script>
