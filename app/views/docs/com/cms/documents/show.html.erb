<div>
  <div>
    <%= link_to "← Back to Documents", docs_com_cms_documents_path %>
  </div>

  <%= turbo_frame_tag dom_id(@document) do %>
    <div>
      <div>
        <div>
          <h1>
            <% begin %>
              <%= @document.latest_version.title %>
            <% rescue ActiveRecord::RecordNotFound %>
              <span class="italic">Untitled Document</span>
            <% end %>
          </h1>
          <p>Permalink:
            <code><%= @document.permalink %></code></p>
        </div>
        <div>
          <%= link_to "Edit", edit_docs_com_cms_document_path(@document),
                      data: { turbo_frame: "modal" } %>

          <% if @document.status_id == "DRAFT" %>
            <%= button_to "Publish", publish_docs_com_cms_document_path(@document),
                          method: :post,
                          data: { turbo_stream: true } %>
          <% elsif @document.status_id == "PUBLISHED" %>
            <%= button_to "Unpublish", unpublish_docs_com_cms_document_path(@document),
                          method: :post,
                          data: { turbo_stream: true } %>
          <% end %>

          <%= button_to "Delete", docs_com_cms_document_path(@document),
                        method: :delete,
                        data: { turbo_confirm: "Are you sure?", turbo_method: :delete } %>
        </div>
      </div>

      <div>
        <div>
          <label>Status</label>
          <% if @document.status_id == "PUBLISHED" %>
            <span>
              Published
            </span>
          <% elsif @document.status_id == "DRAFT" %>
            <span>
              Draft
            </span>
          <% else %>
            <span>
              <%= @document.status_id %>
            </span>
          <% end %>
        </div>
        <div>
          <label>Response Mode</label>
          <p><%= @document.response_mode %></p>
        </div>
        <div>
          <label>Published At</label>
          <p><%= @document.published_at.strftime("%Y-%m-%d %H:%M:%S") if @document.published_at %></p>
        </div>
        <div>
          <label>Expires At</label>
          <p><%= @document.expires_at.strftime("%Y-%m-%d %H:%M:%S") if @document.expires_at %></p>
        </div>
        <% if @document.redirect_url.present? %>
          <div>
            <label>Redirect URL</label>
            <p><%= @document.redirect_url %></p>
          </div>
        <% end %>
      </div>

      <% begin %>
        <% latest = @document.latest_version %>
        <div>
          <h2>Current Content</h2>
          <div>
            <% if latest.description.present? %>
              <div>
                <label>Description</label>
                <p><%= latest.description %></p>
              </div>
            <% end %>
            <% if latest.body.present? %>
              <div>
                <label>Body</label>
                <div>
                  <%= simple_format latest.body %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% rescue ActiveRecord::RecordNotFound %>
        <div>
          <p class="italic">No content versions available</p>
        </div>
      <% end %>

      <div>
        <h2>Version History</h2>
        <div>
          <table>
            <thead>
            <tr>
              <th>Created At</th>
              <th>Title</th>
              <th>Response Mode
              </th>
              <th>Edited By</th>
            </tr>
            </thead>
            <tbody>
            <% @versions.each do |version| %>
              <tr>
                <td>
                  <%= version.created_at.strftime("%Y-%m-%d %H:%M:%S") %>
                </td>
                <td>
                  <%= version.title %>
                </td>
                <td>
                  <%= version.response_mode %>
                </td>
                <td>
                  <%= version.edited_by_type %>
                </td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%= turbo_frame_tag "modal" %>
