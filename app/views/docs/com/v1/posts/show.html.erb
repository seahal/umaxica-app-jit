<% content_for :page_title, 'Recent Versions' %>
<%= turbo_frame_tag "document_detail" do %>
  <article>
    <!-- Document Header -->
    <div>
      <div>
        <div>
          <h1>
            <% begin %>
              <%= @version.title %>
            <% rescue ActiveRecord::Encryption::Errors::Decryption %>
              <%= @document.permalink %>
            <% end %>
          </h1>

          <% begin %>
            <% if @version.description.present? %>
              <p>
                <%= @version.description %>
              </p>
            <% end %>
          <% rescue ActiveRecord::Encryption::Errors::Decryption %>
          <% end %>

          <div>
            <span>
              <code><%= @document.permalink %></code>
            </span>
            <% if @document.published_at %>
              <span>
                <%= @document.published_at.strftime("%Y-%m-%d") %>
              </span>
            <% end %>
          </div>
        </div>

        <div>
          <% if @document.status_id == ComDocumentStatus::ACTIVE %>
            <span>
              Active
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Document Content -->
    <div>
      <% begin %>
        <% if @version.body.present? %>
          <div>
            <%= simple_format(@version.body, {}, sanitize: true) %>
          </div>
        <% else %>
          <p class="italic">No content available.</p>
        <% end %>
      <% rescue ActiveRecord::Encryption::Errors::Decryption %>
        <p class="italic">Content unavailable (encryption error).</p>
      <% end %>
    </div>

    <!-- Document Meta Information -->
    <div>
      <div>
        <div>
          <strong>Document ID:</strong>
          <div><%= @document.id %></div>
        </div>

        <div>
          <strong>Response Mode:</strong>
          <div><%= @document.response_mode.upcase %></div>
        </div>

        <div>
          <strong>Last Updated:</strong>
          <div>
            <%= @version.created_at.strftime("%Y-%m-%d %H:%M") %>
          </div>
        </div>

        <% if @document.expires_at && @document.expires_at < 100.years.from_now %>
          <div>
            <strong>Expires:</strong>
            <div>
              <%= @document.expires_at.strftime("%Y-%m-%d") %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Version History -->
    <div>
      <h3>Recent Versions</h3>

      <div>
        <% @document.com_document_versions.order(created_at: :desc).limit(5).each_with_index do |version, index| %>
          <div class="<%= index == 0 ? 'bg-blue-50 border-l-2 border-blue-500' : 'bg-gray-50' %>">
            <div>
              <% if index == 0 %>
                <span>
                  ●
                </span>
              <% else %>
                <span>
                  <%= @document.com_document_versions.count - index %>
                </span>
              <% end %>
            </div>

            <div>
              <div>
                <% begin %>
                  <%= version.title || "Untitled" %>
                <% rescue ActiveRecord::Encryption::Errors::Decryption %>
                  Untitled
                <% end %>
              </div>
              <div>
                <%= version.created_at.strftime("%Y-%m-%d %H:%M") %>
                <% if version.edited_by_type.present? %>
                  · <%= version.edited_by_type %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @document.com_document_versions.count > 5 %>
        <div>
          <%= @document.com_document_versions.count - 5 %> more versions
        </div>
      <% end %>
    </div>
  </article>
<% end %>
