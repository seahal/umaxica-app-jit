<div>
  <div>
    <!-- Left Panel: Document List -->
    <div>
      <div>
        <h1><%= t("docs.posts.index.title") %></h1>

        <%= form_with url: docs_com_v1_posts_path, method: :get, local: true do |f| %>
          <div>
            <%= text_field_tag :q, params[:q], autocomplete: "off",
                               placeholder: t("docs.posts.index.search_placeholder") %>
            <%= submit_tag t("docs.posts.index.search_button") %>
          </div>
        <% end %>

        <div>
          <% if @query.present? && @query != "all" %>
            <%= t("docs.posts.index.search_found", count: @total_count) %>
            | <%= link_to t("docs.posts.index.search_all"),
                          docs_com_v1_posts_path %>
          <% else %>
            <%= t("docs.posts.index.count", count: @total_count) %>
          <% end %>
        </div>
      </div>

      <% if @documents.any? %>
        <div>
          <% @documents.each do |document| %>
            <div>
              <%= link_to docs_com_v1_post_path(document.permalink),
                          data: { turbo_frame: "document_detail" } do %>
                <h3>
                  <% begin %>
                    <%= document.latest_version.title %>
                  <% rescue ActiveRecord::RecordNotFound, ActiveRecord::Encryption::Errors::Decryption %>
                    <%= document.permalink %>
                  <% end %>
                </h3>
                <div>
                  <code><%= document.permalink %></code>
                  <% if document.status_id == ComDocumentStatus::ACTIVE %>
                    <span>●</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Pagination -->
        <% if @total_pages> 1 %>
          <div>
            <nav>
              <ul>
                <% if @page> 1 %>
                  <li>
                    <%= link_to "‹",
                                docs_com_v1_posts_path(q: @query, page: @page - 1) %>
                  </li>
                <% end %>

                <% (1..@total_pages).each do |page_num| %>
                  <li>
                    <% if page_num == @page %>
                      <span><%= page_num %></span>
                    <% else %>
                      <%= link_to page_num,
                                  docs_com_v1_posts_path(q: @query, page: page_num) %>
                    <% end %>
                  </li>
                <% end %>

                <% if @page < @total_pages %>
                  <li>
                    <%= link_to "›",
                                docs_com_v1_posts_path(q: @query, page: @page + 1) %>
                  </li>
                <% end %>
              </ul>
            </nav>
          </div>
        <% end %>
      <% else %>
        <div>
          <p><%= t("docs.posts.index.empty") %></p>
        </div>
      <% end %>
    </div>

    <!-- Right Panel: Document Detail (Turbo Frame) -->
    <div>
      <%= turbo_frame_tag "document_detail" do %>
        <div>
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3><%= t("docs.posts.index.select_title") %></h3>
          <p>
            <%= t("docs.posts.index.select_description") %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
