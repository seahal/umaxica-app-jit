<% content_for :page_title, 'クイックステータス' %>
<% code_name = ENV.fetch("BRAND_NAME") { ENV.fetch("NAME") } %>

<div>
  <div></div>

  <div>
    <header>
      <span>
        Docs
      </span>
      <h1>
        <%= code_name %> App Documentation
      </h1>
      <p>
        API 仕様、運用ガイド、UI の挙動をまとめたリファレンスです。必要な情報へすぐ辿り着けるように設計しています。
      </p>
      <div>
        <%= link_to "Help Center", help_app_root_url %>
      </div>
    </header>

    <section>
      <div>
        <h2>クイックステータス</h2>
        <dl>
          <div>
            <dt>Current language</dt>
            <dd><%= I18n.locale %></dd>
          </div>
          <div>
            <dt>TimeZone</dt>
            <dd><%= params[:tz].to_s.downcase == "utc" ? "utc" : "jst" %></dd>
          </div>
          <div>
            <dt>Hello</dt>
            <dd><%= I18n.t "hello" %></dd>
          </div>
          <div>
            <dt>Tokyo time</dt>
            <dd><%= Time.current.in_time_zone("Tokyo") %></dd>
          </div>
          <div>
            <dt>Local time</dt>
            <dd><%= to_localetime Time.current, "jst" %></dd>
          </div>
        </dl>
      </div>

      <div>
        <h2>ナビゲーション</h2>
        <p>
          主要なユースケースからドキュメントを辿れます。必要に応じて検索やリンクを追加してください。
        </p>
        <div>
          <span>API</span>
          <span>Guides</span>
          <span>Release Notes</span>
          <span>FAQ</span>
        </div>
      </div>
    </section>
  </div>
</div>
