<div>
  <div>
    <div>
      <div>
        <h1><%= t("docs.posts.index.title") %></h1>

        <div>
          <%= t("docs.posts.index.count", count: @posts.size) %>
        </div>
      </div>

      <% if @posts.any? %>
        <div>
          <% @posts.each do |post| %>
            <div>
              <%= link_to docs_app_v1_post_path(post[:id]),
                          data: { turbo_frame: "document_detail" } do %>
                <h3>
                  <%= post[:title] %>
                </h3>
                <% timestamp = post[:updated_at] || post[:published_at] %>
                <% if timestamp.present? %>
                  <div>
                    <%= l(timestamp, format: :long) %>
                  </div>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div>
          <p><%= t("docs.posts.index.empty") %></p>
        </div>
      <% end %>
    </div>

    <div>
      <%= turbo_frame_tag "document_detail" do %>
        <div>
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h3><%= t("docs.posts.index.select_title") %></h3>
          <p>
            <%= t("docs.posts.index.select_description") %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
