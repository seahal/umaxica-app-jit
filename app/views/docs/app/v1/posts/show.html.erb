<%= turbo_frame_tag "document_detail" do %>
  <article>
    <div>
      <div>
        <div>
          <h1><%= @post[:title] %></h1>
          <div>
            <span>
              <code><%= @post[:id] %></code>
            </span>
            <% if @post[:updated_at].present? %>
              <span><%= @post[:updated_at].strftime("%Y-%m-%d") %></span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div>
      <div>
        <%= simple_format(@post[:body], {}, sanitize: true) %>
      </div>
    </div>
  </article>
<% end %>
