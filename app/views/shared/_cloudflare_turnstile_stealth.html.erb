<%# Cloudflare Turnstile — stealth (invisible) mode %>
<%# Usage: render "cloudflare_turnstile_stealth" %>
<%# Token is set as hidden field "cf-turnstile-response" on form submit. %>
<% stealth_id = "cf-turnstile-stealth-#{SecureRandom.hex(4)}" %>
<% site_key = Jit::Security::TurnstileConfig.stealth_site_key %>

<% if site_key.blank? %>
  <!-- Cloudflare Turnstile stealth site key is missing. Set credentials or CLOUDFLARE_TURNSTILE_SITE_STEALTH_KEY. -->
<% else %>
  <input type="hidden" name="cf-turnstile-response" id="<%= stealth_id %>-response" value="" autocomplete="off" />

  <script nonce="<%= content_security_policy_nonce %>">
      (function () {
          const hiddenField = document.getElementById(<%= "#{stealth_id}-response".to_json.html_safe %>);
          if (!hiddenField) return;

          const form = hiddenField.closest('form');
          if (!form) {
              console.error('Turnstile stealth: no parent form found for', hiddenField.id);
              return;
          }

          const siteKey = <%= site_key.to_json.html_safe %>;
          let widgetId = null;

          function ensureScript(callback) {
              if (window.turnstileScriptLoaded) {
                  callback();
                  return;
              }

              if (!window.turnstileScriptLoading) {
                  window.turnstileScriptLoading = true;
                  const s = document.createElement('script');
                  s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
                  s.nonce = <%= content_security_policy_nonce.to_json %>;
                  s.async = true;
                  s.onload = function () {
                      window.turnstileScriptLoaded = true;
                      window.turnstileScriptLoading = false;
                      callback();
                  };
                  s.onerror = function () {
                      console.error('Failed to load Turnstile script');
                      window.turnstileScriptLoading = false;
                  };
                  document.head.appendChild(s);
              } else {
                  var iv = setInterval(function () {
                      if (window.turnstileScriptLoaded) {
                          clearInterval(iv);
                          callback();
                      }
                  }, 100);
              }
          }

          function initWidget() {
              if (typeof turnstile === 'undefined') return;

              // Render an invisible widget to obtain a token
              var container = document.createElement('div');
              container.style.display = 'none';
              form.appendChild(container);

              widgetId = turnstile.render(container, {
                  sitekey: siteKey,
                  size: 'invisible',
                  callback: function (token) {
                      hiddenField.value = token;
                  },
                  'error-callback': function () {
                      console.error('Turnstile stealth error');
                  },
                  'expired-callback': function () {
                      hiddenField.value = '';
                  }
              });
          }

          form.addEventListener('submit', function (e) {
              // If we already have a valid token, allow submission
              if (hiddenField.value !== '') return;

              // Prevent default, request a fresh token, then re-submit
              e.preventDefault();

              ensureScript(function () {
                  if (widgetId == null) initWidget();

                  // Execute / refresh the challenge
                  if (typeof turnstile !== 'undefined' && widgetId != null) {
                      turnstile.execute(widgetId);
                  }

                  // Wait for the token to arrive, then re-submit
                  var attempts = 0;
                  var poll = setInterval(function () {
                      attempts++;
                      if (hiddenField.value !== '') {
                          clearInterval(poll);
                          form.submit();
                      } else if (attempts > 50) { // ~5 seconds
                          clearInterval(poll);
                          console.error('Turnstile stealth: timed out waiting for token');
                          form.submit(); // submit anyway; server-side will reject
                      }
                  }, 100);
              });
          });

          // Eagerly load the script and render the widget so the token is ready before submit
          ensureScript(initWidget);
      })();
  </script>
<% end %>
