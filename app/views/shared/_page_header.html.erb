<%#
  title (必須)
  description (任意)
  up_to (任意)
  up_label (任意)
  up_fallback (任意)
%>

<div class="mb-8" data-controller="history-back">
  <div class="flex flex-col gap-2">
    <div class="mt-2 space-y-1">
      <h1 class="text-2xl font-bold tracking-tight text-fg"><%= title %></h1>
      <% if local_assigns[:description] %>
        <p class="text-muted-fg text-sm leading-relaxed"><%= description %></p>
      <% end %>
    </div>
  </div>
</div>
