<div class="rounded-lg border border-border bg-card text-card-fg shadow-sm overflow-hidden <%= local_assigns[:class] %>">
  <% if local_assigns[:title] %>
    <div class="flex flex-col space-y-1.5 p-6">
      <h3 class="text-lg font-semibold leading-none tracking-tight"><%= title %></h3>
      <% if local_assigns[:description] %>
        <p class="text-sm text-muted-fg"><%= description %></p>
      <% end %>
    </div>
  <% end %>
  <div class="<%= local_assigns[:title] ? 'p-6 pt-0' : 'p-6' %>">
    <%= yield %>
  </div>
</div>
