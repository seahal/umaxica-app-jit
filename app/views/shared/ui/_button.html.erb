<%
  variant ||= :primary
  type ||= :button
  classes = "inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold transition-colors disabled:opacity-50 disabled:pointer-events-none min-h-[44px] min-w-[44px]"

  variant_classes = {
    primary: "bg-primary text-primary-fg hover:opacity-90",
    secondary: "bg-muted text-muted-fg hover:bg-muted/80",
    outline: "border border-border bg-transparent hover:bg-muted text-fg",
    danger: "bg-danger text-danger-fg hover:opacity-90",
    ghost: "hover:bg-muted text-fg"
  }[variant.to_sym]
%>

<% if local_assigns[:href] %>
  <% link_options = { class: "#{classes} #{variant_classes} #{local_assigns[:class]}" } %>
  <% link_options[:data] = local_assigns[:data] if local_assigns[:data] %>
  <%= link_to href, link_options do %>
    <%= local_assigns[:label] || yield %>
  <% end %>
<% else %>
  <button type="<%= type %>"
          class="<%= classes %> <%= variant_classes %> <%= local_assigns[:class] %>"
          <%= "disabled" if local_assigns[:disabled] %>
          <% if local_assigns[:data] %>
            <% data.each do |k, v| %>
              data-<%= k %>="<%= v %>"
            <% end %>
          <% end %>>
    <%= local_assigns[:label] || yield %>
  </button>
<% end %>
