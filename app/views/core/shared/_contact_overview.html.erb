<section class="rounded-md border border-slate-200 bg-white p-4 shadow-sm">
  <% {
       "Contact ID" => contact.public_id,
       "Category" => contact.try(:category_id),
       "Status" => contact.try(:contact_status_title),
       "Email" => contact.try(:email_address),
       "Telephone" => contact.try(:telephone_number),
       "Created at" => contact.created_at&.strftime("%Y-%m-%d %H:%M"),
       "Updated at" => contact.updated_at&.strftime("%Y-%m-%d %H:%M")
     }.each do |label, value| %>
    <div class="flex items-center justify-between border-b border-slate-100 py-2 text-sm last:border-0">
      <span class="font-medium text-slate-700"><%= label %></span>
      <span class="text-slate-900"><%= value || "-" %></span>
    </div>
  <% end %>
</section>
