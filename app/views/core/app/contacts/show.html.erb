<h1><%= title "Contact request overview" %></h1>

<section>
  <p>
    Use this lightweight page to confirm the request identifier that the customer shared with you
    and make sure the inquiry is still in the intake pipeline.
  </p>

  <%= render "core/shared/contact_overview", contact: @contact %>

  <div>
    <%= link_to "Open edit helper", edit_core_app_contact_path(@contact) %>
    <%= link_to "Start another request", new_core_app_contact_path %>
  </div>
</section>
