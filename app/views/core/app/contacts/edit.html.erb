<h1><%= title "Contact request helper" %></h1>

<section>
  <p>
    We do not support editing an existing request directly from the portal yet.
    Share the reference below with the support team so they can update the conversation on your behalf.
  </p>

  <%= render "core/shared/contact_overview", contact: @contact %>

  <% if @contact_categories.present? %>
    <div>
      <h2>Available categories</h2>
      <p>Choose the closest match when creating a follow-up request.</p>
      <ul>
        <% @contact_categories.each do |category| %>
          <li><%= category.id %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= link_to "Back to details", main_app_contact_path(@contact) %>
    <%= link_to "Create follow-up request", new_main_app_contact_path %>
  </div>
</section>
