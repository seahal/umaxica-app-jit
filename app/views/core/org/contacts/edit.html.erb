<h1><%= title "Organization contact helper" %></h1>

<section>
  <p>
    Updates are currently coordinated by the account success team.
    Share the reference below or create a new ticket if the scope changed.
  </p>

  <%= render "core/shared/contact_overview", contact: @contact %>

  <% if @contact_categories.present? %>
    <div>
      <h2>Suggested categories</h2>
      <p>Select one of the available options when you file a revised request.</p>
      <ul>
        <% @contact_categories.each do |category| %>
          <li><%= category.id %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= link_to "Back to details", core_org_contact_path(@contact) %>
    <%= link_to "Create follow-up request", new_core_org_contact_path %>
  </div>
</section>
