<% title t("sign.app.verification.edit.title") %>

<div>
  <h1><%= t("sign.app.verification.edit.title") %></h1>
  <p><%= t("sign.app.verification.edit.description") %></p>

  <% if @verification_errors&.any? %>
    <div>
      <%= @verification_errors.to_sentence %>
    </div>
  <% end %>

  <%= form_with url: sign_com_verification_passkey_path(ri: params[:ri]), method: :post, data: { turbo: false } do |f| %>
    <% options_json = @passkey_request_options ? json_escape(@passkey_request_options.to_json) : "" %>
    <%= f.hidden_field :scope, value: params.dig(:verification, :scope).presence || params[:scope], name: "verification[scope]" %>
    <%= f.hidden_field :return_to, value: params.dig(:verification, :return_to).presence || params[:return_to], name: "verification[return_to]" %>
    <div
      data-controller="reauth-passkey"
      data-reauth-passkey-options-value="<%= options_json %>"
      data-reauth-passkey-challenge-id-value="<%= @passkey_challenge_id.to_s %>">

      <%= f.hidden_field :challenge_id, value: @passkey_challenge_id.to_s, data: { "reauth-passkey-target": "challengeId" }, name: "verification[challenge_id]" %>
      <%= f.hidden_field :credential_json, value: "", data: { "reauth-passkey-target": "credentialJson" }, name: "verification[credential_json]" %>

      <button type="button"
              data-action="click->reauth-passkey#authenticate">
        <%= t("sign.app.verification.edit.authenticate_with_passkey") %>
      </button>
      <p data-reauth-passkey-target="error" class="hidden"></p>
      <p data-reauth-passkey-target="status" class="hidden"></p>
    </div>
  <% end %>

  <div>
    <%= link_to t("sign.app.verification.edit.back"),
                sign_com_verification_path(
                  ri: params[:ri],
                  scope: params.dig(:verification, :scope).presence || params[:scope],
                  return_to: params.dig(:verification, :return_to).presence || params[:return_to]
                ) %>
  </div>
</div>
