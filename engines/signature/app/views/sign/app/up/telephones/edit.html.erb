<% content_for :page_title, 'Showing sample' %>
<% content_for :title, "Showing sample" %>

<div>
  <h1>Showing sample</h1>

  <%= form_with model: @user_telephone, url: sign_app_up_telephone_path(@user_telephone), method: :patch, data: { turbo: false } do |form| %>

    <% if @user_telephone.errors.any? %>
      <div id="error_explanation">
        <h2><%= pluralize(@user_telephone.errors.count, "error") %> prohibited this sample from being saved:</h2>

        <ul>
          <% @user_telephone.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :pass_code %>
      <%= form.text_field :pass_code,
                          maxlength: 6,
                          autocomplete: "one-time-code",
                          inputmode: "numeric",
                          pattern: "[0-9]{6}" %>
    </div>

    <%= form.submit %>
  <% end %>

  <div>
    <%= button_to t("sign.app.registration.telephone.edit.resend_code"),
                  resend_sign_app_up_telephones_path(ri: params[:ri]),
                  method: :post %>
  </div>

  <div>
    <%= link_to t("controller.sign.app.registration.telephone.edit.return_page"), new_sign_app_up_path %>
  </div>

</div>
