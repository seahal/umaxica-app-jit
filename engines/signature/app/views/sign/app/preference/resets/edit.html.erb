<% content_for :page_title, t('apex.app.preference.resets.title') %>

<section>
  <h1>
    <%= t("apex.app.preference.resets.title") %>
  </h1>

  <p>
    <%= t("apex.app.preference.resets.description") %>
  </p>

  <%= form_with url: sign_app_preference_reset_path, method: :delete do |f| %>
    <% if @preference&.errors&.any? %>
      <div>
        <ul>
          <% @preference.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= check_box_tag :confirm_reset, "1", @preference&.confirm_reset == "1", required: true %>
      <%= label_tag :confirm_reset, t("apex.app.preference.resets.confirm") %>
    </div>

    <div>
      <%= f.submit t("apex.app.preference.resets.button"),
                   data: {
                     turbo_submits_with: t("apex.app.preferences.submitting") } %>
      <%= link_to t("apex.app.preference.resets.back"),
                  sign_app_preference_url %>
    </div>
  <% end %>
</section>
