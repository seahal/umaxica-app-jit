<% content_for :page_title, t("session_limit.edit.page_title") %>

<section>
  <div>
    <div></div>

    <div>
      <div>
        <h1>
          <%= t("session_limit.edit.title") %>
        </h1>
      </div>
      <p>
        <%= t("session_limit.edit.description") %>
      </p>
    </div>

    <% if flash[:alert].present? %>
      <div>
        <div>
          <p><%= flash[:alert] %></p>
        </div>
      </div>
    <% end %>

    <%= form_with url: identity.sign_org_in_session_path, method: :patch do |f| %>
      <div>
        <h2>
          <%= t("session_limit.edit.active_sessions") %>
        </h2>

        <% if @active_sessions.present? %>
          <div>
            <% @active_sessions.each do |session| %>
              <label data-session-checkbox class="ring-2 ring-transparent checked:ring-amber-500">
                <input type="radio"
                       name="ref"
                       value="<%= session.id %>">
                <div>
                  <div>
                  <span>
                    <%= t("session_limit.edit.session_label") %>
                    #<%= "#{session.public_id.first(8)}..." %>
                  </span>
                  </div>
                  <div>
                  <span>
                    <%= t("session_limit.edit.created_at") %>:
                    <%= localized_session_timestamp(session.created_at) %>
                  </span>
                    <% if session.last_used_at %>
                    <span>
                      <%= t("session_limit.edit.last_used") %>:
                      <%= localized_session_timestamp(session.last_used_at) %>
                    </span>
                    <% end %>
                  </div>
                </div>
              </label>
            <% end %>
          </div>
        <% else %>
          <p>
            <%= t("session_limit.edit.no_sessions") %>
          </p>
        <% end %>
      </div>

      <div>
        <%= f.submit t("session_limit.edit.submit") %>
        <%= link_to t("session_limit.edit.back"),
                    identity.new_sign_org_in_path %>
      </div>
    <% end %>

    <%= button_to t("session_limit.edit.cancel_logout"),
                  identity.sign_org_in_session_path,
                  method: :delete,
                  form: { data: { turbo_confirm: t("session_limit.edit.cancel_logout_confirm") } } %>
  </div>
</section>
