<% title t("sign.org.in.mfa.passkey.title") %>

<div>
  <h1><%= t("sign.org.in.mfa.passkey.title") %></h1>
  <p><%= t("sign.org.in.mfa.passkey.description") %></p>

  <%= form_with url: identity.sign_org_in_challenge_passkey_path, method: :post, data: { turbo: false } do |f| %>
    <% options_json = @passkey_request_options ? json_escape(@passkey_request_options.to_json) : "" %>
    <div
      data-controller="reauth-passkey"
      data-reauth-passkey-options-value="<%= options_json %>"
      data-reauth-passkey-challenge-id-value="<%= @passkey_challenge_id.to_s %>">

      <%= f.hidden_field :challenge_id, value: @passkey_challenge_id.to_s, data: { "reauth-passkey-target": "challengeId" }, name: "mfa_passkey_form[challenge_id]" %>
      <%= f.hidden_field :credential_json, value: "", data: { "reauth-passkey-target": "credentialJson" }, name: "mfa_passkey_form[credential_json]" %>

      <button type="button"
              data-action="click->reauth-passkey#authenticate">
        <%= t("sign.org.in.mfa.passkey.authenticate") %>
      </button>
      <p data-reauth-passkey-target="error" class="hidden"></p>
      <p data-reauth-passkey-target="status" class="hidden"></p>
    </div>
  <% end %>

  <div>
    <%= link_to t("sign.org.in.mfa.passkey.back"), identity.sign_org_in_challenge_path %>
  </div>
</div>
