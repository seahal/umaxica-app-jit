<% content_for :page_title, 'Sessions' %>
<%= link_to t('sign.org.configuration.show.back'), identity.sign_org_configuration_path(ri: params[:ri]) %>
<% has_other_sessions = @sessions.any? { |session| session.public_id != current_session_public_id } %>
<% if has_other_sessions %>
  <div>
    <%= button_to t('sign.org.configuration.sessions.revoke.others_button'),
                  others_sign_org_configuration_sessions_path,
                  method: :delete,
                  data: {
                    confirm: t('sign.org.configuration.sessions.revoke.others_confirm')
                  } %>
  </div>
<% end %>

<% if @sessions.any? %>
  <div>
    <table>
      <thead>
      <tr>
        <th>Session</th>
        <th>Kind</th>
        <th>Binding</th>
        <th>Last activity</th>
        <th>Created</th>
        <th>Refresh expires</th>
        <th></th>
      </tr>
      </thead>
      <tbody>
      <% @sessions.each do |session| %>
        <% current_session = session.public_id == current_session_public_id %>
        <tr class="<%= 'bg-slate-50 font-semibold' if current_session %>">
          <td>
            <div>
              <span><%= session.public_id %></span>
              <% if current_session %>
                <span>
                  current
                </span>
              <% end %>
            </div>
            <p><%= session.staff_token_status_id %></p>
          </td>
          <td><%= session.staff_token_kind_id %></td>
          <td><%= session.dbsc_enabled? ? "DBSC" : "NORMAL" %></td>
          <td><%= l(session.last_used_at || session.created_at, format: :short) %></td>
          <td><%= l(session.created_at, format: :short) %></td>
          <td><%= l(session.refresh_expires_at, format: :short) %></td>
          <td>
            <% unless current_session %>
              <%= button_to 'Revoke', identity.sign_org_configuration_session_path(session.public_id),
                            method: :delete,
                            data: { confirm: 'Revoke this session?' } %>
            <% end %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p>No active sessions were found.</p>
<% end %>
