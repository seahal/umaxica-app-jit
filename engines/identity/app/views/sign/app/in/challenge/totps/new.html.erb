<% title t("sign.app.in.mfa.totp.title") %>

<div>
  <div>
    <h1><%= t("sign.app.in.mfa.totp.title") %></h1>
    <p><%= t("sign.app.in.mfa.totp.description") %></p>
  </div>

  <%= form_with model: @totp_form,
                url: identity.sign_app_in_challenge_totp_path,
                data: { turbo: false } do |f| %>
    <% if @totp_form.errors.any? %>
      <div>
        <h2><%= t("errors.messages.validation_failed") %></h2>
        <ul>
          <% @totp_form.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :token, t("sign.app.in.mfa.totp.token_label") %>
      <%= f.text_field :token,
                       placeholder: "123456",
                       maxlength: 6,
                       inputmode: "numeric",
                       autocomplete: "one-time-code",
                       pattern: "[0-9]{6}" %>
    </div>

    <div>
      <%= f.submit t("sign.app.in.mfa.totp.submit") %>
      <%= link_to t("sign.app.in.mfa.totp.back"), identity.sign_app_in_challenge_path %>
    </div>
  <% end %>
</div>
