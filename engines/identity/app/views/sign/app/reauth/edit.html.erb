<% title t("sign.app.reauth.edit.title") %>

<div>
  <h1><%= t("sign.app.reauth.edit.title") %></h1>
  <p><%= t("sign.app.reauth.edit.description") %></p>

  <% if @reauth_session.errors.any? %>
    <div>
      <%= @reauth_session.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= form_with model: @reauth_session, url: identity.sign_app_verification_path(ri: params[:ri]), method: :patch, data: { turbo: false } do |f| %>
    <% if @reauth_session.method == "passkey" %>
      <% options_json = @passkey_request_options ? json_escape(@passkey_request_options.to_json) : "" %>
      <div
        data-controller="reauth-passkey"
        data-reauth-passkey-options-value="<%= options_json %>"
        data-reauth-passkey-challenge-id-value="<%= @passkey_challenge_id.to_s %>">

        <%= f.hidden_field :challenge_id, value: @passkey_challenge_id.to_s, data: { "reauth-passkey-target": "challengeId" } %>
        <%= f.hidden_field :credential_json, value: "", data: { "reauth-passkey-target": "credentialJson" } %>

        <button type="button"
                data-action="click->reauth-passkey#authenticate">
          <%= t("sign.app.reauth.edit.authenticate_with_passkey") %>
        </button>
        <p data-reauth-passkey-target="error" class="hidden"></p>
        <p data-reauth-passkey-target="status" class="hidden"></p>
      </div>
    <% else %>
      <div>
        <%= f.label :code, t("sign.app.reauth.edit.code_label") %>
        <%= f.text_field :code,
                         inputmode: "numeric",
                         autocomplete: "one-time-code",
                         placeholder: t("sign.app.reauth.edit.code_placeholder"),
                         maxlength: 6,
                         pattern: "[0-9]{6}" %>
      </div>

      <div>
        <%= f.submit t("sign.app.reauth.edit.submit") %>
      </div>
    <% end %>
  <% end %>

  <div>
    <%= link_to t("sign.app.reauth.edit.cancel"), identity.sign_app_verification_path(ri: params[:ri]), data: { turbo_method: :delete, turbo_confirm: t("sign.app.reauth.edit.confirm_cancel") } %>
  </div>
</div>
