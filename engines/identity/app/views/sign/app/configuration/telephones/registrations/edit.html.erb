<% content_for :page_title, '確認コードの入力' %>
<div>
  <div>
    <h1>確認コードの入力</h1>
    <p>SMSで届いた確認コードを入力してください。</p>
  </div>

  <div>
    <%= form_with model: @user_telephone,
                  url: identity.sign_app_configuration_telephones_registration_path,
                  method: :patch do |form| %>
      <% if @user_telephone.errors.any? %>
        <div>
          <h2><%= pluralize(@user_telephone.errors.count, "error") %></h2>
          <ul>
            <% @user_telephone.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :pass_code %>
        <%= form.text_field :pass_code,
                            maxlength: 6,
                            autocomplete: "one-time-code",
                            inputmode: "numeric",
                            pattern: "[0-9]{6}" %>
      </div>

      <div>
        <%= form.submit t("actions.submit") %>
      </div>
    <% end %>

    <div>
      <%= link_to t("actions.cancel"), identity.sign_app_configuration_telephones_path %>
    </div>
  </div>
</div>
