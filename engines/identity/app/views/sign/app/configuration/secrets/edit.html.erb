<% content_for :page_title, t('.title') %>
<div>
  <div>
    <%= render "shared/ui/button", variant: :ghost, href: identity.sign_app_configuration_path, label: "← #{t('actions.back')}" %>
  </div>

  <div>
    <div>
      <div>
        <h3><%= t('.title') %></h3>
        <p><%= t('.description') %></p>
      </div>
    </div>
    <div>
      <%= form_with(model: @secret, url: identity.sign_app_configuration_secret_path(@secret), method: :patch) do |form| %>
        <div>
          <% if @secret.errors.any? %>
            <div>
              <div>
                <div>
                  <h3><%= t('errors.template.header', model: @secret.model_name.human, count: @secret.errors.count) %></h3>
                  <div>
                    <ul role="list">
                      <% @secret.errors.full_messages.each do |message| %>
                        <li><%= message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div>
            <div>
              <%= form.label :name %>
              <div>
                <%= form.text_field :name %>
              </div>
            </div>
          </div>
        </div>
        <div>
          <%= link_to t('actions.cancel'), identity.sign_app_configuration_secrets_path %>
          <%= form.submit t('actions.update') %>
        </div>
      <% end %>
    </div>
  </div>
</div>
