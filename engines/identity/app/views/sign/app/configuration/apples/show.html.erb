<% content_for :page_title, t('controller.sign.app.setting.index.apple') %>
<%= link_to t('sign.app.configuration.show.back'), identity.sign_app_configuration_path %>

<div>
  <div>
    <div>
      <h3><%= t('controller.sign.app.setting.index.apple') %></h3>
      <p>
        Apple IDを使用してこのアカウントにログインできます。
      </p>
    </div>
  </div>

  <div>
    <div>
      <div>
        <div>
          <div>
            <div>
              <svg fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.05 20.28c-.96.95-2.21 1.5-3.53 1.5-1.28 0-2.32-.45-3.14-.45-.84 0-2.01.44-3.14.44-1.33 0-2.62-.64-3.64-1.63-2.12-2.04-2.12-6.57 0-8.61a5.08 5.08 0 014.28-1.55c1.02 0 1.83.33 2.51.33.64 0 1.63-.38 2.81-.38.96 0 2.21.32 3.03 1.01-3.1 1.68-2.6 6.37.52 7.34zM12.03 7.25c-.13-1.99 1.51-3.8 3.33-3.95.23 1.99-1.57 3.86-3.33 3.95z" />
              </svg>
            </div>
            <div>
              <h4>Apple</h4>
              <% if current_user.user_social_apple %>
                <p>連携済み</p>
              <% else %>
                <p>未連携</p>
              <% end %>
            </div>
          </div>
          <div>
            <% if current_user.user_social_apple %>
              <% unlink_allowed = current_user.login_methods_remaining?(excluding_provider: "apple") %>
              <%= button_to t('actions.disconnect'),
                            identity.sign_app_social_unlink_path(provider: "apple"),
                            method: :delete,
                            disabled: !unlink_allowed %>
              <p><%= t("auth.step_up.required") %></p>
              <% unless unlink_allowed %>
                <p><%= t("errors.social_auth.insufficient_login_methods") %></p>
              <% end %>
            <% else %>
              <%= link_to t('actions.connect'), identity.new_sign_app_social_session_path(provider: "apple", intent: "link"), data: { turbo: false } %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
