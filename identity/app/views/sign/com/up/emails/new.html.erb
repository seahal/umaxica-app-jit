<% content_for :page_title, t("sign.app.registration.email.new.page_title") %>
<div>
  <div>
    <h2><%= t("sign.app.registration.email.new.page_title") %></h2>
  </div>

  <div>
    <%= form_with model: @user_email, url: identity.sign_com_up_emails_path, method: :post, data: { turbo: false } do |form| %>
      <%= hidden_field_tag :rd, params[:rd] if params[:rd].present? %>

      <% if @user_email.errors.any? %>
        <div>
          <div>
            <div>
              <h3><%= pluralize(@user_email.errors.count, "error") %>
                prohibited this sample from being saved:</h3>
              <div>
                <ul role="list">
                  <% @user_email.errors.each do |error| %>
                    <li><%= error.full_message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <div>
        <%= form.label :raw_address, CustomerEmail.human_attribute_name(:address) %>
        <div>
          <%= form.email_field :raw_address, autocomplete: "email", required: true %>
        </div>
      </div>

      <div>
        <div>
          <%= form.check_box :confirm_policy %>
        </div>
        <div>
          <%= form.label :confirm_policy, "利用規約に同意する" %>
        </div>
      </div>

      <div>
        <%= render "shared/cloudflare_turnstile" %>
      </div>

      <div>
        <%= form.submit %>
      </div>
    <% end %>

    <div>
      <div>
        <div>
          <%= link_to t("sign.app.registration.email.new.link_to_sign_in"), identity.new_sign_com_in_path(ri: params[:ri]) %>
        </div>
      </div>
    </div>
  </div>
</div>
