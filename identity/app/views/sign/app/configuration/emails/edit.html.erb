<% content_for :page_title, t("sign.app.configuration.email.edit.title") %>
<div>
  <div>
    <h1><%= t("sign.app.configuration.email.edit.title") %></h1>
  </div>

  <div>
    <div>
      <p><%= @user_email.address %></p>
    </div>

    <div>
      <%= button_to t("sign.app.configuration.email.index.delete"),
                    identity.sign_app_configuration_email_path(@user_email),
                    method: :delete,
                    data: { turbo_confirm: t("sign.app.configuration.email.index.delete_confirm") } %>
    </div>
    <div>
      <%= link_to t("sign.app.common.cancel"), identity.sign_app_configuration_emails_path %>
    </div>
  </div>
</div>
